    "NSMicrophoneUsageDescription": {
      "comment": "Privacy - Microphone Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Pindrop needs microphone access to transcribe your voice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necesita acceso al micrófono para transcribir tu voz."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindropは音声を文字起こしするためにマイクへのアクセスが必要です。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop precisa de acesso ao microfone para transcrever sua voz."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necessita dell'accesso al microfono per trascrivere la tua voce."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop heeft toegang tot de microfoon nodig om je stem te kunnen transcriberen."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 귀하의 음성을 텍스트로 변환하려면 마이크 액세스 권한이 필요합니다."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un sesinizi yazıya dökebilmesi için mikrofona erişmesi gerekiyor."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "comment": "Privacy - Speech Recognition Usage Description",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Pindrop uses on-device speech recognition to transcribe your audio without sending data to any server."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop usa el reconocimiento de voz local para transcribir tu audio sin enviar datos a ningún servidor."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindropは、データをサーバーに送信することなく音声を文字起こしするためにオンデバイス音声認識を使用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pindrop usa reconhecimento de voz local para transcrever seu áudio sem enviar dados para nenhum servidor."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop usa il riconoscimento vocale locale per trascrivere il tuo audio senza inviare dati a nessun server."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop gebruikt spraakherkenning op het apparaat om je audio te transcriberen zonder gegevens naar een server te sturen."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop은 서버에 데이터를 전송하지 않고 오디오를 텍스트로 변환하기 위해 온디바이스 음성 인식을 사용합니다."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop, herhangi bir sunucuya veri göndermeden sesinizi yazıya dökmek için cihaz üzerinde konuşma tanıma kullanır."
          }
        }
      }
    },
    "NSAudioCaptureUsageDescription": {
      "comment": "Privacy - System Audio Capture Usage Description",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Pindrop needs system audio access to transcribe calls, meetings, and other app audio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necesita acceso al audio del sistema para transcribir llamadas, reuniones y otro audio de apps."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindropは通話、会議、その他のアプリ音声を文字起こしするためにシステムオーディオへのアクセスが必要です。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pindrop precisa de acesso ao áudio do sistema para transcrever chamadas, reuniões e outros áudios de apps."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop ha bisogno dell'accesso all'audio di sistema per trascrivere chiamate, riunioni e altro audio delle app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop heeft toegang tot systeemaudio nodig om gesprekken, vergaderingen en ander app-audio te transcriberen."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 통화, 회의 및 기타 앱 오디오를 텍스트로 변환하려면 시스템 오디오 접근 권한이 필요합니다."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un aramaları, toplantıları ve diğer uygulama seslerini yazıya dökebilmesi için sistem sesine erişmesi gerekir."
          }
        }
      }
    }
  },
  "version": "1.1"
}
