    "nsaudiocaptureusagedescription": {
      "comment": "nsaudiocaptureusagedescription",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج Pindrop إلى الوصول إلى صوت النظام لنسخ المكالمات والاجتماعات وصوت التطبيقات الأخرى."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কল, মিটিং এবং অন্যান্য অ্যাপ অডিও প্রতিলিপি করার জন্য Pindrop-এর সিস্টেম অডিও অ্যাক্সেস প্রয়োজন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop potřebuje systémový přístup ke zvuku, aby mohl přepisovat hovory, schůzky a další zvuky aplikací."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop har brug for adgang til systemlyd for at transskribere opkald, møder og anden app-lyd."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs system audio access to transcribe calls, meetings, and other app audio."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs system audio access to transcribe calls, meetings, and other app audio."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Pindrop χρειάζεται πρόσβαση στον ήχο του συστήματος για τη μεταγραφή κλήσεων, συσκέψεων και άλλου ήχου εφαρμογών."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necesita acceso al audio del sistema para transcribir llamadas, reuniones y otro audio de apps."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop tarvitsee järjestelmän äänen pääsyn puheluiden, kokousten ja muiden sovellusten äänien litterointiin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs system audio access to transcribe calls, meetings, and other app audio."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop זקוק לגישה לאודיו של המערכת כדי לתמלל שיחות, פגישות ואודיו אחר של אפליקציות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कॉल, मीटिंग और अन्य ऐप ऑडियो को ट्रांसक्राइब करने के लिए पिनड्रॉप को सिस्टम ऑडियो एक्सेस की आवश्यकता होती है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pindrop-nak rendszerhang-hozzáférésre van szüksége a hívások, értekezletek és egyéb alkalmazáshangok átírásához."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop memerlukan akses audio sistem untuk menyalin panggilan, rapat, dan audio aplikasi lainnya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop ha bisogno dell'accesso all'audio di sistema per trascrivere chiamate, riunioni e altro audio delle app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindropは通話、会議、その他のアプリ音声を文字起こしするためにシステムオーディオへのアクセスが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 통화, 회의 및 기타 앱 오디오를 텍스트로 변환하려면 시스템 오디오 접근 권한이 필요합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop memerlukan akses audio sistem untuk menyalin panggilan, mesyuarat dan audio apl lain."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop trenger systemlydtilgang for å transkribere anrop, møter og annen applyd."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop heeft toegang tot systeemaudio nodig om gesprekken, vergaderingen en ander app-audio te transcriberen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop potrzebuje dostępu do dźwięku systemowego, aby transkrybować rozmowy, spotkania i inne dźwięki z aplikacji."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pindrop precisa de acesso ao áudio do sistema para transcrever chamadas, reuniões e outros áudios de apps."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop are nevoie de acces audio la sistem pentru a transcrie apeluri, întâlniri și alte aplicații audio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop необходим доступ к системному звуку для расшифровки звонков, встреч и звука других приложений."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop behöver systemljudåtkomst för att transkribera samtal, möten och annat appljud."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop ต้องการการเข้าถึงเสียงของระบบเพื่อถอดเสียงการโทร การประชุม และเสียงอื่นๆ ของแอป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un aramaları, toplantıları ve diğer uygulama seslerini yazıya dökebilmesi için sistem sesine erişmesi gerekir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop потребує доступу до системного аудіо, щоб транскрибувати дзвінки, зустрічі й аудіо з інших програм."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop cần quyền truy cập vào âm thanh hệ thống để chép lời cuộc gọi, cuộc họp và âm thanh ứng dụng khác."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop 需要系統音訊存取權限，才能轉錄通話、會議和其他應用程式音訊。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs system audio access to transcribe calls, meetings, and other app audio."
          }
        }
      }
    },
