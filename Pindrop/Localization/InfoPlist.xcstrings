    "nsmicrophoneusagedescription": {
      "comment": "nsmicrophoneusagedescription",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to transcribe your voice."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to transcribe your voice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necesita acceso al micrófono para transcribir tu voz."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to transcribe your voice."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necessita dell'accesso al microfono per trascrivere la tua voce."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindropは音声を文字起こしするためにマイクへのアクセスが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 귀하의 음성을 텍스트로 변환하려면 마이크 액세스 권한이 필요합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop heeft toegang tot de microfoon nodig om je stem te kunnen transcriberen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop precisa de acesso ao microfone para transcrever sua voz."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un sesinizi yazıya dökebilmesi için mikrofona erişmesi gerekiyor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to transcribe your voice."
          }
        }
      }
    },
    "nsspeechrecognitionusagedescription": {
      "comment": "nsspeechrecognitionusagedescription",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop uses on-device speech recognition to transcribe your audio without sending data to any server."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop uses on-device speech recognition to transcribe your audio without sending data to any server."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop usa el reconocimiento de voz local para transcribir tu audio sin enviar datos a ningún servidor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop uses on-device speech recognition to transcribe your audio without sending data to any server."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop usa il riconoscimento vocale locale per trascrivere il tuo audio senza inviare dati a nessun server."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindropは、データをサーバーに送信することなく音声を文字起こしするためにオンデバイス音声認識を使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop은 서버에 데이터를 전송하지 않고 오디오를 텍스트로 변환하기 위해 온디바이스 음성 인식을 사용합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop gebruikt spraakherkenning op het apparaat om je audio te transcriberen zonder gegevens naar een server te sturen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pindrop usa reconhecimento de voz local para transcrever seu áudio sem enviar dados para nenhum servidor."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop, herhangi bir sunucuya veri göndermeden sesinizi yazıya dökmek için cihaz üzerinde konuşma tanıma kullanır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop uses on-device speech recognition to transcribe your audio without sending data to any server."
          }
        }
      }
    }
  }
}
