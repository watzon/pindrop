    "nsmicrophoneusagedescription": {
      "comment": "nsmicrophoneusagedescription",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج Pindrop إلى الوصول إلى الميكروفون لنسخ صوتك."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার ভয়েস প্রতিলিপি করার জন্য Pindrop-এর মাইক্রোফোন অ্যাক্সেস প্রয়োজন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop potřebuje přístup k mikrofonu, aby mohl přepsat váš hlas."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop har brug for mikrofonadgang for at transskribere din stemme."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to transcribe your voice."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to transcribe your voice."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Pindrop χρειάζεται πρόσβαση στο μικρόφωνο για να μεταγράψει τη φωνή σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necesita acceso al micrófono para transcribir tu voz."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop tarvitsee mikrofonin pääsyn äänesi litteroimiseen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to transcribe your voice."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop זקוק לגישה למיקרופון כדי לתמלל את הקול שלך."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी आवाज़ को ट्रांसक्रिप्ट करने के लिए पिनड्रॉप को माइक्रोफ़ोन एक्सेस की आवश्यकता होती है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pindrop-nak mikrofon-hozzáférésre van szüksége a hangjának átírásához."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop memerlukan akses mikrofon untuk menyalin suara Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necessita dell'accesso al microfono per trascrivere la tua voce."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
