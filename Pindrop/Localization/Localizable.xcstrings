    "pindrop_is_ready_to_use_click_the_menu_bar_icon": {
      "comment": "pindrop_is_ready_to_use_click_the_menu_bar_icon",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop جاهز للاستخدام.\nانقر على أيقونة شريط القائمة للبدء."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পিনড্রপ ব্যবহারের জন্য প্রস্তুত।\n\nশুরু করতে মেনু বার আইকনে ক্লিক করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop je připraven k použití.\nZačněte kliknutím na ikonu panelu nabídek."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop er klar til brug.\nKlik på menulinjeikonet for at komme i gang."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop ist bereit zur Verwendung.\nKlicken Sie auf das Menüleisten-Symbol, um zu beginnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop is ready to use.\nClick the menu bar icon to get started."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Pindrop είναι έτοιμο για χρήση.\nΚάντε κλικ στο εικονίδιο της γραμμής μενού για να ξεκινήσετε."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop está listo para usar.\nHaz clic en el icono de la barra de menús para empezar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop on käyttövalmis.\nAloita napsauttamalla valikkopalkin kuvaketta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop est prêt à être utilisé.\nCliquez sur l'icône de la barre de menus pour commencer."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop מוכן לשימוש.\nלחץ על סמל שורת התפריטים כדי להתחיל."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिनड्रॉप उपयोग के लिए तैयार है।\nआरंभ करने के लिए मेनू बार आइकन पर क्लिक करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop használatra kész.\nA kezdéshez kattintson a menüsor ikonjára."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop siap digunakan.\nKlik ikon bilah menu untuk memulai."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop è pronto per l'uso.\nFare clic sull'icona della barra dei menu per iniziare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピンドロップを使用する準備ができました。\nメニューバーのアイコンをクリックして開始します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "핀드롭을 사용할 준비가 되었습니다.\n시작하려면 메뉴 표시줄 아이콘을 클릭하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop sedia untuk digunakan.\nKlik ikon bar menu untuk bermula."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop er klar til bruk.\nKlikk på menylinjeikonet for å komme i gang."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop is klaar voor gebruik.\nKlik op het menubalkpictogram om aan de slag te gaan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop jest gotowy do użycia.\nKliknij ikonę paska menu, aby rozpocząć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pindrop está pronto para uso.\nClique no ícone da barra de menu para começar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop este gata de utilizare.\nFaceți clic pe pictograma barei de meniu pentru a începe."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пиндроп готов к использованию.\nНажмите значок в строке меню, чтобы начать."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop är redo att användas.\nKlicka på menyradens ikon för att komma igång."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "พินดรอปพร้อมใช้งานแล้ว\nคลิกไอคอนแถบเมนูเพื่อเริ่มต้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop kullanıma hazırdır.\nBaşlamak için menü çubuğu simgesini tıklayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop готовий до використання.\nЩоб розпочати, натисніть значок панелі меню."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop đã sẵn sàng để sử dụng.\nNhấp vào biểu tượng thanh menu để bắt đầu."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop 已準備好使用。\n點選選單欄圖示開始使用。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop 已准备好使用。\n点击菜单栏图标开始使用。"
          }
        }
      }
    },
