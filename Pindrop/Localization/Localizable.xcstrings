          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizzato durante l'acquisizione di note tramite tasto di scelta rapida. Può aggiungere la formattazione del markdown per contenuti più lunghi."
          }
        },
        "ja": {
