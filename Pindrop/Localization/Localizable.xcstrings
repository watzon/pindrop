    "Used when capturing notes via hotkey. Can add markdown formatting for longer content.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird beim Erfassen von Notizen über Tastenkürzel verwendet. Kann Markdown-Formatierung für längeren Inhalt hinzufügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used when capturing notes via hotkey. Can add markdown formatting for longer content."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se usa al capturar notas mediante atajo de teclado. Puede añadir formato markdown para contenido más extenso."
          }
        },
        "fr": {
          "stringUnit": {
