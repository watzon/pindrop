    "attach_logs_from_this_folder_when_filing_a_githu": {
      "comment": "attach_logs_from_this_folder_when_filing_a_githu",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بإرفاق السجلات من هذا المجلد عند تقديم مشكلة GitHub."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub সমস্যা ফাইল করার সময় এই ফোল্ডার থেকে লগ সংযুক্ত করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Při vyplňování problému na GitHubu připojte protokoly z této složky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedhæft logfiler fra denne mappe, når du indgiver et GitHub-problem."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie Protokolle aus diesem Ordner bei, wenn Sie ein GitHub-Issue erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Attach logs from this folder when filing a GitHub issue."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επισυνάψτε αρχεία καταγραφής από αυτόν τον φάκελο κατά την υποβολή ενός ζητήματος στο GitHub."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjunta los registros de esta carpeta al crear una incidencia en GitHub."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Liitä lokit tästä kansiosta, kun ilmoitat GitHub-ongelman."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joignez les journaux de ce dossier lors de la création d'une issue GitHub."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "צרף יומנים מתיקיה זו בעת הגשת בעיית GitHub."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub समस्या दर्ज करते समय इस फ़ोल्डर से लॉग संलग्न करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Csatoljon naplókat ebből a mappából, amikor GitHub-problémát jelent be."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lampirkan log dari folder ini saat mengajukan masalah GitHub."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Allega i log da questa cartella quando invii un problema su GitHub."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub の問題を提出する場合は、このフォルダーのログを添付してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub 문제를 제출할 때 이 폴더의 로그를 첨부하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lampirkan log daripada folder ini apabila memfailkan isu GitHub."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg ved logger fra denne mappen når du arkiverer et GitHub-problem."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg logboeken uit deze map toe wanneer u een GitHub-probleem indient."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dołącz dzienniki z tego folderu podczas zgłaszania problemu z GitHubem."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Anexe logs desta pasta ao registrar um problema no GitHub."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Atașați jurnalele din acest folder atunci când depuneți o problemă GitHub."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прикрепите журналы из этой папки при регистрации проблемы на GitHub."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bifoga loggar från den här mappen när du arkiverar ett GitHub-problem."
          }
        },
        "th": {
