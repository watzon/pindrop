    "type_text_directly_into_the_active_app_when_poss": {
      "comment": "type_text_directly_into_the_active_app_when_poss",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتب النص مباشرةً في التطبيق النشط عندما يكون ذلك ممكنًا"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সম্ভব হলে সক্রিয় অ্যাপে সরাসরি টেক্সট টাইপ করুন"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokud je to možné, zadejte text přímo do aktivní aplikace"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indtast tekst direkte i den aktive app, når det er muligt"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geben Sie Text direkt in die aktive App ein, wenn möglich"
