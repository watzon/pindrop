            "value": "Drücken Sie, um die Aufnahme zu starten, drücken Sie erneut, um den Notizeditor zu öffnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press to start recording, press again to open note editor"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa para empezar a grabar y vuelve a pulsar para abrir el editor de notas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez pour commencer l'enregistrement, appuyez à nouveau pour ouvrir l'éditeur de notes"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
