    "add_a_provider_to_start_using_ai_enhancement": {
      "comment": "add_a_provider_to_start_using_ai_enhancement",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف موفرًا لبدء استخدام تحسين الذكاء الاصطناعي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "AI বর্ধিতকরণ ব্যবহার শুরু করতে একটি প্রদানকারী যোগ করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Chcete-li začít používat vylepšení AI, přidejte poskytovatele."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilføj en udbyder for at begynde at bruge AI-forbedring."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie einen Anbieter hinzu, um mit der KI-Erweiterung zu beginnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a provider to start using AI enhancement."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε έναν πάροχο για να αρχίσετε να χρησιμοποιείτε τη βελτίωση AI."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregue un proveedor para comenzar a utilizar la mejora de la IA."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisää palveluntarjoaja aloittaaksesi AI-parannuksen käytön."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un fournisseur pour commencer à utiliser l'amélioration de l'IA."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הוסף ספק כדי להתחיל להשתמש בשיפור AI."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एआई एन्हांसमेंट का उपयोग शुरू करने के लिए एक प्रदाता जोड़ें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjon hozzá egy szolgáltatót az AI-javítás használatának megkezdéséhez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan penyedia untuk mulai menggunakan peningkatan AI."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un fornitore per iniziare a utilizzare il miglioramento dell'intelligenza artificiale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 拡張機能の使用を開始するには、プロバイダーを追加します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 향상 기능을 사용하려면 공급자를 추가하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan pembekal untuk mula menggunakan peningkatan AI."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til en leverandør for å begynne å bruke AI-forbedring."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg een provider toe om AI-verbetering te gaan gebruiken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj dostawcę, aby rozpocząć korzystanie z ulepszeń AI."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione um provedor para começar a usar o aprimoramento de IA."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Adăugați un furnizor pentru a începe să utilizați îmbunătățirea AI."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте поставщика, чтобы начать использовать улучшения AI."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till en leverantör för att börja använda AI-förbättring."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่มผู้ให้บริการเพื่อเริ่มใช้การปรับปรุง AI"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapay zeka geliştirmesini kullanmaya başlamak için bir sağlayıcı ekleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додайте постачальника, щоб почати використовувати вдосконалення ШІ."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm nhà cung cấp để bắt đầu sử dụng tính năng nâng cao AI."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增提供商以開始使用 AI 增強功能。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加提供商以开始使用 AI 增强功能。"
          }
        }
      }
    },
    "add_custom_words_to_improve_transcription_accura": {
      "comment": "add_custom_words_to_improve_transcription_accura",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف كلمات مخصصة لتحسين دقة النسخ للمصطلحات أو الأسماء أو المصطلحات المتخصصة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "বিশেষ পদ, নাম বা শব্দার্থের জন্য প্রতিলিপি নির্ভুলতা উন্নত করতে কাস্টম শব্দ যোগ করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidejte vlastní slova, abyste zlepšili přesnost přepisu specializovaných termínů, jmen nebo žargonu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilføj tilpassede ord for at forbedre transskriptionsnøjagtigheden for specialiserede termer, navne eller jargon."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie benutzerdefinierte Wörter hinzu, um die Transkriptionsgenauigkeit für Fachbegriffe, Namen oder Jargon zu verbessern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add custom words to improve transcription accuracy for specialized terms, names, or jargon."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε προσαρμοσμένες λέξεις για να βελτιώσετε την ακρίβεια μεταγραφής για εξειδικευμένους όρους, ονόματα ή ορολογία."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade palabras personalizadas para mejorar la precisión de la transcripción en términos especializados, nombres o jerga."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisää mukautettuja sanoja parantaaksesi erikoistermien, nimien tai ammattislangen transkription tarkkuutta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des mots personnalisés pour améliorer la précision de la transcription pour les termes spécialisés, noms ou jargon."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הוסף מילים מותאמות אישית כדי לשפר את דיוק התמלול עבור מונחים, שמות או ז'רגון מיוחדים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "विशिष्ट शब्दों, नामों या शब्दजाल के लिए प्रतिलेखन सटीकता में सुधार करने के लिए कस्टम शब्द जोड़ें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjon hozzá egyéni szavakat a speciális kifejezések, nevek vagy szakzsargonok átírási pontosságának javítása érdekében."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan kata khusus untuk meningkatkan akurasi transkripsi untuk istilah, nama, atau jargon khusus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi parole personalizzate per migliorare la precisione della trascrizione di termini specializzati, nomi o gergo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カスタム単語を追加して、専門用語、名前、専門用語の文字起こしの精度を向上させます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "특수 용어, 이름 또는 전문 용어에 대한 전사 정확도를 높이려면 사용자 정의 단어를 추가하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan perkataan tersuai untuk meningkatkan ketepatan transkripsi bagi istilah, nama atau jargon khusus."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til tilpassede ord for å forbedre transkripsjonsnøyaktigheten for spesialiserte termer, navn eller sjargong."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg aangepaste woorden toe om de nauwkeurigheid van de transcriptie voor gespecialiseerde termen, namen of jargon te verbeteren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj niestandardowe słowa, aby poprawić dokładność transkrypcji specjalistycznych terminów, nazw lub żargonu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione palavras personalizadas para melhorar a precisão da transcrição de termos, nomes ou jargões especializados."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Adăugați cuvinte personalizate pentru a îmbunătăți acuratețea transcripției pentru termeni, nume sau jargon specializați."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляйте собственные слова, чтобы повысить точность транскрипции специализированных терминов, имен или жаргона."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till anpassade ord för att förbättra transkriptionsnoggrannheten för specialiserade termer, namn eller jargong."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่มคำที่กำหนดเองเพื่อปรับปรุงความแม่นยำในการถอดเสียงสำหรับคำศัพท์ ชื่อ หรือศัพท์เฉพาะทาง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Özel terimler, adlar veya jargonun transkripsiyon doğruluğunu artırmak için özel kelimeler ekleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додайте власні слова, щоб покращити точність транскрипції спеціальних термінів, імен або жаргону."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm các từ tùy chỉnh để cải thiện độ chính xác của bản ghi cho các thuật ngữ, tên hoặc biệt ngữ chuyên ngành."
          }
        },
        "zh-Hant": {
