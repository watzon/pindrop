            "value": "يتم تعطيل النسخ المتدفق أثناء تمكين تحسين الذكاء الاصطناعي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "AI উন্নত করার সময় স্ট্রিমিং ট্রান্সক্রিপশন অক্ষম করা আছে।"
          }
