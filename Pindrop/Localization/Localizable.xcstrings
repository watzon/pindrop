    "append_a_space_after_each_transcription_for_seam": {
      "comment": "append_a_space_after_each_transcription_for_seam",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف مسافة بعد كل نسخة للإملاء السلس."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "বিরামহীন শ্রুতিলিপির জন্য প্রতিটি ট্রান্সক্রিপশনের পরে একটি স্থান যুক্ত করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Za každým přepisem přidejte mezeru pro bezproblémový diktát."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilføj et mellemrum efter hver transskription for problemfri diktering."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie nach jeder Transkription ein Leerzeichen für nahtlose Diktierung hinzu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Append a space after each transcription for seamless dictation."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε ένα κενό μετά από κάθε μεταγραφή για απρόσκοπτη υπαγόρευση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un espacio después de cada transcripción para un dictado fluido."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisää välilyönti jokaisen transkription jälkeen saumattoman sanelun varmistamiseksi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un espace après chaque transcription pour un dictée fluide."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הוסף רווח לאחר כל תמלול להכתבה חלקה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निर्बाध श्रुतलेख के लिए प्रत्येक प्रतिलेखन के बाद एक स्थान जोड़ें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tegyen szóközt minden átírás után a zökkenőmentes diktálás érdekében."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan spasi setelah setiap transkripsi untuk pendiktean yang lancar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi uno spazio dopo ogni trascrizione per una dettatura senza interruzioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "シームレスなディクテーションのために、各文字起こしの後にスペースを追加します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원활한 받아쓰기를 위해 각 텍스트 변환 뒤에 공백을 추가하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan ruang selepas setiap transkripsi untuk imlak yang lancar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til et mellomrom etter hver transkripsjon for sømløs diktering."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg na elke transcriptie een spatie toe voor naadloos dicteren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodawaj spację po każdej transkrypcji, aby zapewnić płynne dyktowanie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acrescente um espaço após cada transcrição para um ditado perfeito."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Adăugați un spațiu după fiecare transcriere pentru o dictare fără întreruperi."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте пробел после каждой транскрипции для плавной диктовки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till ett blanksteg efter varje transkription för sömlös diktering."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เติมช่องว่างหลังการถอดเสียงแต่ละครั้งเพื่อให้เขียนตามคำบอกได้อย่างราบรื่น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kusursuz dikte için her transkripsiyondan sonra bir boşluk ekleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додайте пробіл після кожної транскрипції для безперебійного диктування."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm một khoảng trắng sau mỗi lần phiên âm để đọc chính tả liền mạch."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在每次轉錄後附加一個空格，以實現無縫聽寫。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在每次转录后附加一个空格，以实现无缝听写。"
          }
        }
      }
    },
