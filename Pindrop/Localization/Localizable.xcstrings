        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई मॉडल उपलब्ध नहीं. रीफ़्रेश करने का प्रयास करें या मैन्युअल रूप से मॉडल आईडी दर्ज करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincsenek elérhető modellek. Próbálja meg a Frissítést, vagy adja meg manuálisan a modellazonosítót."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada model yang tersedia. Coba Refresh atau masukkan ID model secara manual."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun modello disponibile Prova ad aggiornare o inserisci manualmente un ID modello."
