    "theme_changes_apply_live_across_the_workspace_se": {
      "comment": "theme_changes_apply_live_across_the_workspace_se",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تطبيق تغييرات السمات مباشرة عبر مساحة العمل والإعدادات ومحرر الملاحظات والمؤشرات العائمة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "থিম পরিবর্তনগুলি কর্মক্ষেত্র, সেটিংস, নোট এডিটর এবং ভাসমান সূচক জুড়ে লাইভ প্রযোজ্য।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Změny motivu se projeví na pracovní ploše, v nastavení, v editoru poznámek a v plovoucích indikátorech."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Temaændringer gælder live på tværs af arbejdsområdet, indstillinger, noteeditor og flydende indikatorer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Designänderungen werden live im gesamten Arbeitsbereich, in den Einstellungen, im Notizeditor und in den schwebenden Indikatoren angewendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Theme changes apply live across the workspace, settings, note editor, and floating indicators."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι αλλαγές θέματος εφαρμόζονται ζωντανά στον χώρο εργασίας, τις ρυθμίσεις, το πρόγραμμα επεξεργασίας σημειώσεων και τις κινούμενες ενδείξεις."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los cambios de tema se aplican en vivo en el espacio de trabajo, ajustes, editor de notas e indicadores flotantes."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Teeman muutokset ovat voimassa työtilassa, asetuksissa, muistiinpanoeditorissa ja kelluvissa ilmaisimissa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les changements de thème s'appliquent en direct dans tout l'espace de travail, les paramètres, l'éditeur de notes et les indicateurs flottants."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שינויי ערכת נושא חלים בשידור חי על פני סביבת העבודה, ההגדרות, עורך הערות ומחוונים צפים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "थीम परिवर्तन कार्यक्षेत्र, सेटिंग्स, नोट संपादक और फ़्लोटिंग संकेतकों पर लाइव लागू होते हैं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A téma módosításai élőben érvényesek a munkaterületen, a beállításokon, a jegyzetszerkesztőben és a lebegő indikátorokon."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Perubahan tema berlaku langsung di seluruh ruang kerja, pengaturan, editor catatan, dan indikator mengambang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modifiche al tema vengono applicate in tempo reale nell'area di lavoro, nelle impostazioni, nell'editor delle note e negli indicatori mobili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テーマの変更は、ワークスペース、設定、ノートエディター、フローティングインジケーター全体にライブで適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "테마 변경 사항은 작업 공간, 설정, 노트 편집기 및 플로팅 표시기에 실시간으로 적용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Perubahan tema digunakan secara langsung merentas ruang kerja, tetapan, editor nota dan penunjuk terapung."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Temaendringer gjelder direkte på tvers av arbeidsområdet, innstillinger, notatredigering og flytende indikatorer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Themawijzigingen zijn live van toepassing op de werkruimte, instellingen, notitie-editor en zwevende indicatoren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zmiany motywu obowiązują w całym obszarze roboczym, ustawieniach, edytorze notatek i ruchomych wskaźnikach."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As alterações de tema são aplicadas ao vivo na área de trabalho, nas configurações, no editor de notas e nos indicadores flutuantes."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Modificările temei se aplică live în spațiul de lucru, setări, editor de note și indicatori flotanți."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Изменения темы применяются в реальном времени во всей рабочей области, настройках, редакторе заметок и плавающих индикаторах."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Temaändringar gäller direkt i arbetsytan, inställningarna, anteckningsredigeraren och flytande indikatorer."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การเปลี่ยนแปลงธีมมีผลใช้งานจริงทั่วทั้งพื้นที่ทำงาน การตั้งค่า ตัวแก้ไขบันทึกย่อ และตัวบ่งชี้แบบลอย"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tema değişiklikleri, çalışma alanı, ayarlar, not düzenleyici ve kayan göstergeler genelinde canlı olarak uygulanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Зміни теми застосовуються в робочій області, налаштуваннях, редакторі нотаток і плаваючих індикаторах."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các thay đổi về chủ đề áp dụng trực tiếp trên không gian làm việc, cài đặt, trình chỉnh sửa ghi chú và chỉ báo nổi."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "主題更改實時應用於整個工作區、設定、筆記編輯器和浮動指示器。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主题更改实时应用于整个工作区、设置、笔记编辑器和浮动指示器。"
          }
        }
      }
    },
