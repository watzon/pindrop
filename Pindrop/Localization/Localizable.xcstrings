    "requires_a_fast_provider_apple_foundation_models": {
      "comment": "requires_a_fast_provider_apple_foundation_models",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب مزودًا سريعًا (يُوصى باستخدام نماذج Apple Foundation). سيقوم موفرو السحابة بإصدار استدعاء API واحد لكل توقف مؤقت."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একটি দ্রুত প্রদানকারী প্রয়োজন (অ্যাপল ফাউন্ডেশন মডেল প্রস্তাবিত)। ক্লাউড প্রদানকারীরা প্রতি বিরতিতে একটি API কল ইস্যু করবে।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyžaduje rychlého poskytovatele (doporučeny modely Apple Foundation). Poskytovatelé cloudu vydají jedno volání API na pauzu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kræver en hurtig udbyder (Apple Foundation-modeller anbefales). Cloud-udbydere vil udstede et API-kald pr. pause."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfordert einen schnellen Anbieter (Apple Foundation Models empfohlen). Cloud-Anbieter geben pro Pause einen API-Aufruf aus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Requires a fast provider (Apple Foundation Models recommended). Cloud providers will issue one API call per pause."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απαιτεί έναν γρήγορο πάροχο (συνιστώνται τα μοντέλα Apple Foundation). Οι πάροχοι cloud θα εκδίδουν μία κλήση API ανά παύση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Requires a fast provider (Apple Foundation Models recommended). Los proveedores de la nube emitirán una llamada API por pausa."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Edellyttää nopeaa toimittajaa (Apple Foundation -malleja suositellaan). Pilvipalveluntarjoajat lähettävät yhden API-kutsun taukoa kohden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nécessite un fournisseur rapide (modèles Apple Foundation recommandés). Les fournisseurs de cloud émettront un appel API par pause."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "דורש ספק מהיר (מומלצים דגמי Apple Foundation). ספקי ענן יוציאו קריאת API אחת לכל הפסקה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक तेज़ प्रदाता की आवश्यकता है (Apple फाउंडेशन मॉडल अनुशंसित)। क्लाउड प्रदाता प्रति विराम एक एपीआई कॉल जारी करेंगे।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Gyors szolgáltatót igényel (Apple Foundation Models ajánlott). A felhőszolgáltatók szünetenként egy API-hívást adnak ki."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Membutuhkan penyedia yang cepat (disarankan Apple Foundation Models). Penyedia cloud akan mengeluarkan satu panggilan API per jeda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Richiede un fornitore veloce (consigliato Apple Foundation Models). I fornitori di servizi cloud emetteranno una chiamata API per ogni pausa."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高速プロバイダーが必要です (Apple Foundation モデルを推奨)。クラウド プロバイダーは、一時停止ごとに 1 つの API 呼び出しを発行します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빠른 공급자가 필요합니다(Apple Foundation Models 권장). 클라우드 제공업체는 일시 중지당 하나의 API 호출을 발행합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memerlukan pembekal yang pantas (Model Yayasan Apple disyorkan). Pembekal awan akan mengeluarkan satu panggilan API setiap jeda."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Krever en rask leverandør (Apple Foundation-modeller anbefales). Skyleverandører vil utstede ett API-kall per pause."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vereist een snelle provider (Apple Foundation Models aanbevolen). Cloudproviders zullen één API-oproep per pauze doen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wymaga szybkiego dostawcy (zalecane modele Apple Foundation). Dostawcy usług w chmurze będą wysyłać jedno wywołanie API na każdą pauzę."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requer um provedor rápido (recomenda-se modelos Apple Foundation). Os provedores de nuvem emitirão uma chamada de API por pausa."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Necesită un furnizor rapid (se recomandă modelele Apple Foundation). Furnizorii de cloud vor lansa un apel API pe pauză."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Требуется быстрый поставщик (рекомендуются модели Apple Foundation). Облачные провайдеры будут выполнять один вызов API за паузу."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kräver en snabb leverantör (Apple Foundation-modeller rekommenderas). Molnleverantörer kommer att utfärda ett API-anrop per paus."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ต้องมีผู้ให้บริการที่รวดเร็ว (แนะนำรุ่น Apple Foundation) ผู้ให้บริการคลาวด์จะทำการเรียก API หนึ่งครั้งต่อการหยุดชั่วคราว"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hızlı bir sağlayıcı gerektirir (Apple Foundation Modelleri önerilir). Bulut sağlayıcıları her duraklatma için bir API çağrısı yayınlayacaktır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Потрібен швидкий постачальник (рекомендуються моделі Apple Foundation). Хмарні постачальники надсилатимуть один виклик API за паузу."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yêu cầu nhà cung cấp nhanh (khuyến nghị sử dụng Apple Foundation Models). Các nhà cung cấp đám mây sẽ thực hiện một lệnh gọi API cho mỗi lần tạm dừng."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "需要快速提供者（推薦 Apple Foundation Models）。雲提供商將在每次暫停時發出一次 API 呼叫。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要快速提供者（推荐 Apple Foundation Models）。云提供商将在每次暂停时发出一次 API 调用。"
          }
        }
      }
    },
