    "used_when_capturing_notes_via_hotkey_can_add_mar": {
      "comment": "used_when_capturing_notes_via_hotkey_can_add_mar",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم عند التقاط الملاحظات عبر مفتاح التشغيل السريع. يمكن إضافة تنسيق تخفيض السعر لمحتوى أطول."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "হটকির মাধ্যমে নোট ক্যাপচার করার সময় ব্যবহৃত হয়। দীর্ঘ বিষয়বস্তুর জন্য মার্কডাউন বিন্যাস যোগ করতে পারেন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Používá se při pořizování poznámek pomocí klávesové zkratky. Pro delší obsah lze přidat formátování markdown."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruges til at fange noter via genvejstast. Kan tilføje markdown-formatering for længere indhold."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird beim Erfassen von Notizen über Tastenkürzel verwendet. Kann Markdown-Formatierung für längeren Inhalt hinzufügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used when capturing notes via hotkey. Can add markdown formatting for longer content."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιείται κατά τη λήψη σημειώσεων μέσω πλήκτρου πρόσβασης. Μπορεί να προσθέσει μορφοποίηση σήμανσης για μεγαλύτερο περιεχόμενο."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se usa al capturar notas mediante atajo de teclado. Puede añadir formato markdown para contenido más extenso."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käytetään muistiinpanojen tallentamiseen pikanäppäimellä. Voidaan lisätä merkintämuotoilua pidemmälle sisällölle."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisé lors de la capture de notes via raccourci. Peut ajouter du formatage markdown pour du contenu plus long."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "משמש בעת לכידת הערות באמצעות מקש קיצור. יכול להוסיף עיצוב סימון לתוכן ארוך יותר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हॉटकी के माध्यम से नोट्स कैप्चर करते समय उपयोग किया जाता है। लंबी सामग्री के लिए मार्कडाउन फ़ॉर्मेटिंग जोड़ सकते हैं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Jegyzetek gyorsbillentyűvel történő rögzítésekor használatos. Lecsökkenthető formázást adhat hozzá a hosszabb tartalomhoz."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Digunakan saat mengambil catatan melalui hotkey. Dapat menambahkan format penurunan harga untuk konten yang lebih panjang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizzato durante l'acquisizione di note tramite tasto di scelta rapida. Può aggiungere la formattazione del markdown per contenuti più lunghi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホットキー経由でメモをキャプチャするときに使用します。長いコンテンツにマークダウン形式を追加できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축키를 통해 메모를 캡처할 때 사용됩니다. 더 긴 콘텐츠에 마크다운 형식을 추가할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Digunakan semasa menangkap nota melalui hotkey. Boleh menambah pemformatan turun untuk kandungan yang lebih panjang."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Brukes når du fanger notater via hurtigtast. Kan legge til markdown-formatering for lengre innhold."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wordt gebruikt bij het vastleggen van notities via een sneltoets. Kan markdown-opmaak toevoegen voor langere inhoud."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Używane podczas przechwytywania notatek za pomocą klawisza skrótu. Można dodać formatowanie przecen dla dłuższych treści."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Usado ao capturar notas via tecla de atalho. Pode adicionar formatação de redução para conteúdo mais longo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Folosit la capturarea notelor prin taste rapide. Poate adăuga formatare de reducere pentru conținut mai lung."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используется при захвате заметок с помощью горячей клавиши. Можно добавить форматирование уценки для более длинного контента."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Används för att fånga anteckningar via snabbtangent. Kan lägga till markdown-formatering för längre innehåll."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้เมื่อบันทึกโน้ตผ่านปุ่มลัด สามารถเพิ่มการจัดรูปแบบมาร์กดาวน์สำหรับเนื้อหาที่ยาวขึ้นได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayol tuşuyla not alırken kullanılır. Daha uzun içerik için işaretleme biçimlendirmesi eklenebilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовується під час захоплення нотаток за допомогою гарячої клавіші. Можна додати форматування розмітки для довшого вмісту."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Được sử dụng khi ghi chú bằng phím nóng. Có thể thêm định dạng đánh dấu cho nội dung dài hơn."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在使用快捷鍵捕獲筆記時使用。可以為較長的內容新增 Markdown 格式。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在使用快捷键捕获笔记时使用。可以为较长的内容添加 Markdown 格式。"
          }
        }
      }
    },
