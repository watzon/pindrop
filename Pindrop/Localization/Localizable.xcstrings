          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надсилається до моделі AI під час обробки диктування для прямого вставлення тексту."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gửi đến mô hình AI khi xử lý chính tả để chèn văn bản trực tiếp."
          }
        },
        "zh-Hant": {
          "stringUnit": {
