    "drop_a_file_or_paste_a_link_to_create_a_diarized": {
      "comment": "drop_a_file_or_paste_a_link_to_create_a_diarized",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بإسقاط ملف أو لصق رابط لإنشاء نسخة يومية ومختومة بالوقت."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ডায়েরাইজড, টাইমস্ট্যাম্পড ট্রান্সক্রিপ্ট তৈরি করতে একটি ফাইল ড্রপ করুন বা একটি লিঙ্ক পেস্ট করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přetažením souboru nebo vložením odkazu vytvořte diarizovaný přepis s časovým razítkem."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Slip en fil, eller indsæt et link for at oprette en dagbog, tidsstemplet transskription."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie eine Datei ab oder fügen Sie einen Link ein, um eine diarisierte, zeitgestempelte Transkription zu erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drop a file or paste a link to create a diarized, timestamped transcript."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αποθέστε ένα αρχείο ή επικολλήστε έναν σύνδεσμο για να δημιουργήσετε μια ημερολογιακή μεταγραφή με χρονική σήμανση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Suelta un archivo o pega un enlace para crear una transcripción con diarización y marcas de tiempo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pudota tiedosto tai liitä linkki luodaksesi päiväkirjallinen, aikaleimattu transkriptio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déposez un fichier ou collez un lien pour créer une transcription avec diarisation et horodatage."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שחרר קובץ או הדבק קישור כדי ליצור תמליל יומן עם חותמת זמן."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक डायरीकृत, टाइमस्टैम्प्ड प्रतिलेख बनाने के लिए एक फ़ाइल छोड़ें या एक लिंक चिपकाएँ।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Húzzon egy fájlt vagy illesszen be egy hivatkozást naplózott, időbélyegzett átirat létrehozásához."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Letakkan file atau tempelkan tautan untuk membuat transkrip yang diari dan diberi stempel waktu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rilascia un file o incolla un collegamento per creare una trascrizione diarizzata e con timestamp."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルをドロップするかリンクを貼り付けて、タイムスタンプ付きの日記付きトランスクリプトを作成します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일을 삭제하거나 링크를 붙여넣어 타임스탬프가 지정된 스크립트를 생성하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lepaskan fail atau tampalkan pautan untuk membuat transkrip diari dan bercap masa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Slipp en fil eller lim inn en lenke for å lage en diaries, tidsstemplet transkripsjon."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zet een bestand neer of plak een link om een ​​transcript met een dagboek en een tijdstempel te maken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Upuść plik lub wklej link, aby utworzyć transkrypcję z diariuszem i znacznikiem czasu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Solte um arquivo ou cole um link para criar uma transcrição com carimbo de data e hora."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aruncați un fișier sau inserați un link pentru a crea o transcriere diarizată, marcată de timp."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите файл или вставьте ссылку, чтобы создать дневниковую расшифровку с отметкой времени."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Släpp en fil eller klistra in en länk för att skapa ett diariefört, tidsstämplat transkript."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "วางไฟล์หรือวางลิงก์เพื่อสร้างบันทึกประจำวันและบันทึกเวลา"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Günlüğe alınmış, zaman damgalı bir transkript oluşturmak için bir dosya bırakın veya bir bağlantı yapıştırın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетягніть файл або вставте посилання, щоб створити стенограму щоденника з позначкою часу."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thả tệp hoặc dán liên kết để tạo bản ghi được đánh dấu thời gian, được ghi nhật ký."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "拖放檔案或貼上連結以建立帶說話人分離和時間戳的轉錄。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖放文件或粘贴链接以创建带说话人分离和时间戳的转录。"
          }
        }
      }
    },
