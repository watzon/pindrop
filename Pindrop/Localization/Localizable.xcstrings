    "choose_between_parakeet_cross_version_downloaded": {
      "comment": "choose_between_parakeet_cross_version_downloaded",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر بين Parakeet (الإصدار المشترك، النموذج الذي تم تنزيله) وApple SpeechTranscriber (macOS 26+، يأتي مع نظام التشغيل)."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Parakeet (ক্রস-সংস্করণ, ডাউনলোড করা মডেল) এবং Apple SpeechTranscriber (macOS 26+, OS সহ জাহাজ) এর মধ্যে বেছে নিন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte si mezi Parakeet (křížová verze, stažený model) a Apple SpeechTranscriber (macOS 26+, dodává se s OS)."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg mellem Parakeet (cross-version, downloadet model) og Apple SpeechTranscriber (macOS 26+, leveres med OS)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle zwischen Parakeet (versionsübergreifend, heruntergeladenes Modell) und Apple SpeechTranscriber (macOS 26+, mit dem System ausgeliefert)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose between Parakeet (cross-version, downloaded model) and Apple SpeechTranscriber (macOS 26+, ships with the OS)."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε μεταξύ του Parakeet (διασταυρούμενη έκδοση, ληφθέν μοντέλο) και του Apple SpeechTranscriber (macOS 26+, αποστέλλεται με το λειτουργικό σύστημα)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige entre Parakeet (compatible con varias versiones, modelo descargado) y Apple SpeechTranscriber (macOS 26+, incluido con el sistema)."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse Parakeet (ristiversio, ladattu malli) tai Apple SpeechTranscriber (macOS 26+, toimitetaan käyttöjärjestelmän mukana)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez entre Parakeet (multiversion, modèle téléchargé) et Apple SpeechTranscriber (macOS 26+, fourni avec le système)."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר בין Parakeet (גרסה צולבת, דגם שהורד) לבין Apple SpeechTranscriber (macOS 26+, נשלח עם מערכת ההפעלה)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पैराकीट (क्रॉस-वर्जन, डाउनलोड किया गया मॉडल) और ऐप्पल स्पीचट्रांसक्राइबर (मैकओएस 26+, ओएस के साथ जहाज) के बीच चुनें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válasszon a Parakeet (több verzió, letöltött modell) és az Apple SpeechTranscriber (macOS 26+, az operációs rendszerrel együtt) közül."
          }
        },
        "id": {
          "stringUnit": {
