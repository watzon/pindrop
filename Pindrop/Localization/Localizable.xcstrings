        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음하기 전에 설정에서 Whisper 모델을 다운로드하세요.nn모델을 다운로드하려면 설정 → 모델로 이동하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
