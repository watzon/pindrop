    "Let Pindrop quietly learn vocabulary from the corrections you make over time.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lassen Sie Pindrop im Hintergrund Vokabular aus den Korrekturen lernen, die Sie im Laufe der Zeit vornehmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let Pindrop quietly learn vocabulary from the corrections you make over time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deja que Pindrop aprenda vocabulario silenciosamente de las correcciones que hagas con el tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laissez Pindrop apprendre tranquillement le vocabulaire à partir des corrections que vous faites au fil du temps."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lascia che Pindrop impari tranquillamente il vocabolario dalle correzioni che apporti nel tempo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop は、時間をかけて修正した単語を静かに学習させてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 시간이 지남에 따라 수정한 내용을 통해 조용히 단어를 학습하게 하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Laat Pindrop rustig de woordenschat leren van de correcties die u in de loop van de tijd aanbrengt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixe o Pindrop aprender silenciosamente o vocabulário com as correções que você faz ao longo do tempo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
