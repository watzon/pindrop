    "remove_and_clear_any_assignments_that_reference": {
      "comment": "remove_and_clear_any_assignments_that_reference",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد إزالة \"%@\" ومسح أي مهام تشير إليه؟ سيتم حذف بيانات الاعتماد المخزنة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" সরান এবং এটির উল্লেখ করে এমন কোনো অ্যাসাইনমেন্ট সাফ করবেন? সঞ্চিত শংসাপত্র মুছে ফেলা হবে."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odebrat „%@“ a vymazat všechna přiřazení, která na něj odkazují? Uložené přihlašovací údaje budou smazány."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fjern \"%@\" og ryd alle tildelinger, der henviser til den? Gemte legitimationsoplysninger bliver slettet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ entfernen und alle Zuweisungen löschen, die darauf verweisen? Gespeicherte Zugangsdaten werden gelöscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove \"%@\" and clear any assignments that reference it? Stored credentials will be deleted."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Να καταργηθεί το \"%@\" και να διαγραφούν τυχόν εργασίες που αναφέρονται σε αυτό; Τα αποθηκευμένα διαπιστευτήρια θα διαγραφούν."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Eliminar \"%@\" y borrar cualquier asignación que haga referencia a él? Se eliminarán las credenciales almacenadas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Poistetaanko \"%@\" ja tyhjennetäänkö siihen viittaavat tehtävät? Tallennetut tunnistetiedot poistetaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer « %@ » et effacer toutes les affectations qui y font référence ? Les informations d'identification stockées seront supprimées."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "האם להסיר את \"%@\" ולנקות את כל המטלות שמתייחסות אליו? אישורים מאוחסנים יימחקו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" हटाएं और इसका संदर्भ देने वाले किसी भी असाइनमेंट को साफ़ करें? संग्रहीत क्रेडेंशियल हटा दिए जाएंगे."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Eltávolítja a(z) \"%@\" elemet, és töröl minden olyan hozzárendelést, amely erre hivatkozik? A tárolt hitelesítő adatok törlődnek."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hapus \"%@\" dan hapus semua tugas yang mereferensikannya? Kredensial yang disimpan akan dihapus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovere \"%@\" e cancellare tutte le assegnazioni che fanno riferimento ad esso? Le credenziali archiviate verranno eliminate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」を削除し、それを参照する割り当てをクリアしますか?保存されている認証情報は削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\"을 제거하고 이를 참조하는 모든 할당을 지우시겠습니까? 저장된 자격 증명이 삭제됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Alih keluar \"%@\" dan kosongkan sebarang tugasan yang merujuknya? Bukti kelayakan yang disimpan akan dipadamkan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vil du fjerne «%@» og fjerne eventuelle oppgaver som refererer til det? Lagret legitimasjon vil bli slettet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' verwijderen en alle toewijzingen wissen die ernaar verwijzen? Opgeslagen inloggegevens worden verwijderd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunąć „%@” i wyczyścić wszystkie przypisania, które się do niego odwołują? Przechowywane dane uwierzytelniające zostaną usunięte."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remover \"%@\" e limpar todas as atribuições que fazem referência a ele? As credenciais armazenadas serão excluídas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminați „%@” și ștergeți toate sarcinile care fac referire la el? Acreditările stocate vor fi șterse."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить «%@» и очистить все назначения, которые ссылаются на него? Сохраненные учетные данные будут удалены."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta bort \"%@\" och rensa alla tilldelningar som refererar till det? Lagrade referenser kommer att raderas."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบ \"%@\" และล้างการมอบหมายที่อ้างถึงหรือไม่ ข้อมูลรับรองที่เก็บไว้จะถูกลบ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" kaldırılsın ve ona başvuran tüm atamalar silinsin mi? Saklanan kimlik bilgileri silinecek."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Видалити \"%@\" та видалити всі призначення, які посилаються на нього? Збережені облікові дані буде видалено."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa \"%@\" và xóa mọi bài tập tham chiếu đến nó? Thông tin đăng nhập được lưu trữ sẽ bị xóa."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除“%@”並清除引用它的所有作業？儲存的憑據將被刪除。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除“%@”并清除引用它的所有作业？存储的凭据将被删除。"
          }
        }
      }
    },
