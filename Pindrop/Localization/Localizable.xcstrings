    "Please download a Whisper model in Settings before recording.\n\nGo to Settings → Models to download a model.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte laden Sie ein Whisper-Modell in den Einstellungen herunter, bevor Sie aufnehmen.\n\nGehen Sie zu Einstellungen → Modelle, um ein Modell herunterzuladen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please download a Whisper model in Settings before recording.\n\nGo to Settings → Models to download a model."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descarga un modelo de Whisper en Ajustes antes de grabar.\n\nVe a Ajustes → Modelos para descargar un modelo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez télécharger un modèle Whisper dans les Paramètres avant d'enregistrer.\n\nAllez dans Paramètres → Modèles pour télécharger un modèle."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scarica un modello Whisper in Impostazioni prima di registrare.\n\nVai su Impostazioni → Modelli per scaricare un modello."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音する前に、設定で Whisper モデルをダウンロードしてください。\n\n[設定] → [モデル] に移動してモデルをダウンロードします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음하기 전에 설정에서 Whisper 모델을 다운로드하세요.\n\n설정 → 모델로 이동하여 모델을 다운로드하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Download een Whisper-model in Instellingen voordat u gaat opnemen.\n\nGa naar Instellingen → Modellen om een ​​model te downloaden."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Baixe um modelo Whisper em Configurações antes de gravar.\n\nVá para Configurações → Modelos para baixar um modelo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在录制前在设置中下载 Whisper 模型。\n\n前往设置 → 模型下载模型。"
          }
        },
