          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ส่งไปยังโมเดล AI เมื่อประมวลผลคำสั่งสำหรับการแทรกข้อความโดยตรง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
