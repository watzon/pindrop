    "Pindrop needs a few permissions to work.\nYour privacy is always respected.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop benötigt einige Berechtigungen, um zu funktionieren.\nIhre Privatsphäre wird immer respektiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs a few permissions to work.\nYour privacy is always respected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necesita algunos permisos para funcionar.\nTu privacidad siempre se respeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop a besoin de quelques autorisations pour fonctionner.\nVotre vie privée est toujours respectée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necessita di alcune autorizzazioni per funzionare.\nLa tua privacy è sempre rispettata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop が動作するには、いくつかの権限が必要です。\nあなたのプライバシーは常に尊重されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 작동하려면 몇 가지 권한이 필요합니다.\n귀하의 개인 정보는 항상 존중됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop heeft een paar machtigingen nodig om te werken.\nUw privacy wordt altijd gerespecteerd."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop precisa de algumas permissões para funcionar.\nSua privacidade é sempre respeitada."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop 需要一些权限才能工作。\n您的隐私始终受到尊重。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un çalışması için birkaç izne ihtiyacı var.\nGizliliğinize her zaman saygı duyulur."
          }
        }
      }
    },
