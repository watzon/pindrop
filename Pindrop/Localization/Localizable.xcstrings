    "optional_used_for_auto_generated_titles_and_summ": {
      "comment": "optional_used_for_auto_generated_titles_and_summ",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختياري - يُستخدم للعناوين والملخصات التي يتم إنشاؤها تلقائيًا عند استيراد نسخ الوسائط."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ঐচ্ছিক — মিডিয়া ট্রান্সক্রিপশন আমদানিতে স্বয়ংক্রিয়ভাবে তৈরি শিরোনাম এবং সারাংশের জন্য ব্যবহৃত হয়।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Volitelné – používá se pro automaticky generované tituly a souhrny při importech přepisů médií."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Valgfrit – bruges til automatisk genererede titler og resuméer på medietransskriptionsimport."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional – wird für automatisch generierte Titel und Zusammenfassungen beim Import von Medientranskriptionen verwendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional — used for auto-generated titles and summaries on media transcription imports."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προαιρετικό — χρησιμοποιείται για τίτλους και περιλήψεις που δημιουργούνται αυτόματα στις εισαγωγές μεταγραφής μέσων."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcional: se utiliza para títulos y resúmenes generados automáticamente en importaciones de transcripciones de medios."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valinnainen – käytetään automaattisesti luotuihin nimikkeisiin ja tiivistelmiin median litteraattien tuonnista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Facultatif : utilisé pour les titres et les résumés générés automatiquement lors des importations de transcriptions multimédias."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אופציונלי - משמש עבור כותרות וסיכומים שנוצרו אוטומטית על ייבוא ​​של תמלול מדיה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वैकल्पिक - मीडिया ट्रांसक्रिप्शन आयात पर स्वचालित रूप से जेनरेट किए गए शीर्षक और सारांश के लिए उपयोग किया जाता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem kötelező – automatikusan generált címekhez és összefoglalókhoz használják a médiaátiratok importálásakor."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Opsional — digunakan untuk judul dan ringkasan yang dibuat secara otomatis pada impor transkripsi media."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facoltativo: utilizzato per titoli e riepiloghi generati automaticamente sulle importazioni di trascrizioni multimediali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オプション — メディア文字起こしインポート時に自動生成されたタイトルと概要に使用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택 사항 - 미디어 전사 가져오기에 대한 자동 생성 제목 및 요약에 사용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilihan — digunakan untuk tajuk yang dijana secara automatik dan ringkasan pada import transkripsi media."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Valgfritt – brukes for automatisk genererte titler og sammendrag på medietranskripsjonsimport."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Optioneel: wordt gebruikt voor automatisch gegenereerde titels en samenvattingen bij het importeren van mediatranscripties."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcjonalne — używane w przypadku automatycznie generowanych tytułów i podsumowań importowanych transkrypcji multimediów."
          }
        },
        "pt-BR": {
          "stringUnit": {
