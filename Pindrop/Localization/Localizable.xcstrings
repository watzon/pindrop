    "transcriptions_in_this_folder_will_be_kept_and_m": {
      "comment": "transcriptions_in_this_folder_will_be_kept_and_m",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم الاحتفاظ بالنسخ الموجودة في هذا المجلد وإعادتها إلى المكتبة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই ফোল্ডারে ট্রান্সক্রিপশন রাখা হবে এবং লাইব্রেরিতে ফিরিয়ে আনা হবে।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přepisy v této složce budou zachovány a přesunuty zpět do knihovny."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Transskriptioner i denne mappe vil blive opbevaret og flyttet tilbage til biblioteket."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkriptionen in diesem Ordner werden behalten und in die Bibliothek verschoben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcriptions in this folder will be kept and moved back to the library."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι μεταγραφές σε αυτόν τον φάκελο θα διατηρηθούν και θα μετακινηθούν πίσω στη βιβλιοθήκη."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las transcripciones de esta carpeta se conservarán y volverán a moverse a la biblioteca."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämän kansion transkriptiot säilytetään ja siirretään takaisin kirjastoon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les transcriptions dans ce dossier seront conservées et déplacées vers la bibliothèque."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התמלולים בתיקייה זו יישמרו ויעברו חזרה לספרייה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस फ़ोल्डर में ट्रांसक्रिप्शन को रखा जाएगा और लाइब्रेरी में वापस ले जाया जाएगा।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az ebben a mappában lévő átiratok megmaradnak, és visszakerülnek a könyvtárba."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkripsi dalam folder ini akan disimpan dan dipindahkan kembali ke perpustakaan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le trascrizioni in questa cartella verranno conservate e spostate nella libreria."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このフォルダー内の文字起こしは保存され、ライブラリに戻されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 폴더의 스크립트는 보관되어 라이브러리로 다시 이동됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkripsi dalam folder ini akan disimpan dan dialihkan kembali ke pustaka."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkripsjoner i denne mappen vil bli oppbevart og flyttet tilbake til biblioteket."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcripties in deze map worden bewaard en terug naar de bibliotheek verplaatst."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkrypcje w tym folderze zostaną zachowane i przeniesione z powrotem do biblioteki."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As transcrições nesta pasta serão mantidas e movidas de volta para a biblioteca."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Trancrierile din acest dosar vor fi păstrate și mutate înapoi în bibliotecă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Транскрипции в этой папке будут сохранены и возвращены в библиотеку."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkriptioner i denna mapp kommer att sparas och flyttas tillbaka till biblioteket."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การถอดเสียงเป็นคำในโฟลเดอร์นี้จะถูกเก็บและย้ายกลับไปยังไลบรารี"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu klasördeki transkripsiyonlar saklanacak ve kütüphaneye geri taşınacaktır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Транскрипції в цій папці буде збережено та переміщено назад до бібліотеки."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các bản ghi trong thư mục này sẽ được lưu giữ và chuyển trở lại thư viện."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此資料夾中的轉錄將被保留並移回庫中。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文件夹中的转录将被保留并移回库中。"
          }
        }
      }
    },
