          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo provider sarà disponibile in un aggiornamento futuro.\nPer ora, prova OpenAI o utilizza un endpoint personalizzato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロバイダーは将来のアップデートで利用可能になる予定です。\n現時点では、OpenAI を試すか、カスタム エンドポイントを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 공급자는 향후 업데이트에서 사용할 수 있습니다.\n지금은 OpenAI를 사용해 보거나 사용자 지정 엔드포인트를 사용하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze provider zal beschikbaar zijn in een toekomstige update.\nProbeer voorlopig OpenAI of gebruik een aangepast eindpunt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este provedor estará disponível em uma atualização futura.\nPor enquanto, experimente o OpenAI ou use um endpoint personalizado."
