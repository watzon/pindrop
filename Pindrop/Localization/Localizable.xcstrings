    "Theme changes apply live across the workspace, settings, note editor, and floating indicators.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Designänderungen werden live im gesamten Arbeitsbereich, in den Einstellungen, im Notizeditor und in den schwebenden Indikatoren angewendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Theme changes apply live across the workspace, settings, note editor, and floating indicators."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los cambios de tema se aplican en vivo en el espacio de trabajo, ajustes, editor de notas e indicadores flotantes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les changements de thème s'appliquent en direct dans tout l'espace de travail, les paramètres, l'éditeur de notes et les indicateurs flottants."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modifiche al tema vengono applicate in tempo reale nell'area di lavoro, nelle impostazioni, nell'editor delle note e negli indicatori mobili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テーマの変更は、ワークスペース、設定、ノートエディター、フローティングインジケーター全体にライブで適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "테마 변경 사항은 작업 공간, 설정, 노트 편집기 및 플로팅 표시기에 실시간으로 적용됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Themawijzigingen zijn live van toepassing op de werkruimte, instellingen, notitie-editor en zwevende indicatoren."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As alterações de tema são aplicadas ao vivo na área de trabalho, nas configurações, no editor de notas e nos indicadores flutuantes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主题更改实时应用于整个工作区、设置、笔记编辑器和浮动指示器。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tema değişiklikleri, çalışma alanı, ayarlar, not düzenleyici ve kayan göstergeler genelinde canlı olarak uygulanır."
          }
        }
      }
    },
