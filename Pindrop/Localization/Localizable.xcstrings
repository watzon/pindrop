    "press_once_to_start_again_to_stop": {
      "comment": "press_once_to_start_again_to_stop",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط مرة واحدة للبدء، ومرة ​​أخرى للتوقف"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "শুরু করতে একবার টিপুন, আবার থামাতে"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jedním stisknutím spustíte, dalším stisknutím zastavíte"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk én gang for at starte, igen for at stoppe"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einmal drücken zum Starten, erneut zum Stoppen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press once to start, again to stop"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πατήστε μία φορά για να ξεκινήσετε, ξανά για να σταματήσετε"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Press once to start, again to stop"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Paina kerran aloittaaksesi, uudelleen lopettaaksesi"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez une fois pour démarrer, à nouveau pour arrêter"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לחץ פעם אחת כדי להתחיל, שוב כדי לעצור"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शुरू करने के लिए एक बार दबाएँ, रोकने के लिए दोबारा दबाएँ"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nyomja meg egyszer az indításhoz, újra a leállításhoz"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan sekali untuk memulai, tekan sekali lagi untuk berhenti"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premere una volta per avviare, un'altra per interrompere"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一度押すと開始し、もう一度押すと停止します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 번 누르면 시작되고 다시 누르면 중지됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan sekali untuk memulakan, sekali lagi untuk berhenti"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk én gang for å starte, igjen for å stoppe"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Druk één keer om te starten, nogmaals om te stoppen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij raz, aby rozpocząć, ponownie, aby zatrzymać"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione uma vez para iniciar, novamente para parar"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Apăsați o dată pentru a începe, din nou pentru a opri"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите один раз, чтобы начать, еще раз, чтобы остановить"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck en gång för att starta, igen för att stoppa"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กดหนึ่งครั้งเพื่อเริ่มต้น กดอีกครั้งเพื่อหยุด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Başlamak için bir kez, durdurmak için bir kez daha basın"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Натисніть один раз, щоб почати, ще раз, щоб зупинити"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn một lần để bắt đầu, nhấn lần nữa để dừng"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次開始，再按一次停止"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次开始，再按一次停止"
          }
        }
      }
