    "smaller_models_are_faster_but_less_accurate_nsta": {
      "comment": "smaller_models_are_faster_but_less_accurate_nsta",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعتبر الموديلات الأصغر حجمًا أسرع ولكنها أقل دقة. ابدأ باستخدام القاعدة للحصول على أفضل توازن."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ছোট মডেলগুলি দ্রুত কিন্তু কম নির্ভুল৷ n সেরা ব্যালেন্সের জন্য বেস দিয়ে শুরু করুন৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Menší modely jsou rychlejší, ale méně přesné.nZačněte s Base pro nejlepší vyvážení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindre modeller er hurtigere, men mindre præcise.nStart med Base for den bedste balance."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleinere Modelle sind schneller aber weniger genau.nStarten Sie mit Base für die beste Balance."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Smaller models are faster but less accurate.nStart with Base for the best balance."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα μικρότερα μοντέλα είναι πιο γρήγορα αλλά λιγότερο ακριβή.nΞεκινήστε με το Base για την καλύτερη ισορροπία."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Smaller models are faster but less accurate.nStart with Base for the best balance."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pienemmät mallit ovat nopeampia, mutta vähemmän tarkkoja.nAloita Base saadaksesi parhaan tasapainon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modèles plus petits sont plus rapides mais moins précis.nCommencez avec Base pour le meilleur équilibre."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "דגמים קטנים יותר מהירים יותר אך פחות מדויקים. nהתחל עם Base לקבלת האיזון הטוב ביותר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "छोटे मॉडल तेज़ लेकिन कम सटीक होते हैं। सर्वोत्तम संतुलन के लिए बेस से शुरुआत करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kisebb modellek gyorsabbak, de kevésbé pontosak.nKezdje a Base-szal a legjobb egyensúly érdekében."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Model yang lebih kecil lebih cepat namun kurang akurat. Mulailah dengan Base untuk keseimbangan terbaik."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I modelli più piccoli sono più veloci ma meno precisi. nInizia con Base per il miglior equilibrio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "小さいモデルは高速ですが、精度が低くなります。最適なバランスを得るには、Base から始めてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작은 모델은 더 빠르지만 정확도가 떨어집니다.n최상의 균형을 위해 베이스로 시작하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Model yang lebih kecil lebih pantas tetapi kurang tepat.nMulakan dengan Base untuk keseimbangan terbaik."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindre modeller er raskere, men mindre nøyaktige.nStart med Base for best balanse."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleinere modellen zijn sneller maar minder nauwkeurig.nBegin met Base voor de beste balans."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mniejsze modele są szybsze, ale mniej dokładne.nZacznij od wersji podstawowej, aby uzyskać najlepszą równowagę."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelos menores são mais rápidos, mas menos precisos.nComece com Base para obter o melhor equilíbrio."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelele mai mici sunt mai rapide, dar mai puțin precise.nÎncepeți cu Base pentru cel mai bun echilibru."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Меньшие модели работают быстрее, но менее точны. Для достижения наилучшего баланса начните с Base."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindre modeller är snabbare men mindre exakta.nBörja med Base för bästa balans."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รุ่นเล็กจะเร็วกว่าแต่แม่นยำน้อยกว่าnเริ่มต้นด้วย Base เพื่อความสมดุลที่ดีที่สุด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha küçük modeller daha hızlıdır ancak daha az doğrudur.nEn iyi denge için Base ile başlayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Менші моделі швидші, але менш точні.nПочніть із Base для найкращого балансу."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các mô hình nhỏ hơn sẽ nhanh hơn nhưng kém chính xác hơn.nHãy bắt đầu với Base để có độ cân bằng tốt nhất."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "較小的模型更快但準確度較低。n從 Base 開始以獲得最佳平衡。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较小的模型更快但准确度较低。n从 Base 开始以获得最佳平衡。"
          }
        }
      }
    },
