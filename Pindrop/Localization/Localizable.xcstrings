    "streaming_transcription_currently_supports_engli": {
      "comment": "streaming_transcription_currently_supports_engli",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يدعم النسخ المتدفق حاليًا اللغة الإنجليزية فقط، بغض النظر عن اللغة المحددة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্ট্রিমিং ট্রান্সক্রিপশন বর্তমানে শুধুমাত্র ইংরেজি সমর্থন করে, নির্বাচিত ভাষা নির্বিশেষে।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přepis streamování aktuálně podporuje pouze angličtinu, bez ohledu na vybraný jazyk."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Streamingtransskription understøtter i øjeblikket kun engelsk, uanset det valgte sprog."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Streaming-Transkription unterstützt derzeit nur Englisch, unabhängig von der ausgewählten Sprache."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Streaming transcription currently supports English only, regardless of the selected language."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η μεταγραφή ροής υποστηρίζει προς το παρόν μόνο αγγλικά, ανεξάρτητα από την επιλεγμένη γλώσσα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La transcripción en streaming actualmente solo admite inglés, independientemente del idioma seleccionado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Suoratoiston transkriptio tukee tällä hetkellä vain englantia valitusta kielestä riippumatta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La transcription en streaming ne prend actuellement en charge que l’anglais, quelle que soit la langue sélectionnée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "תמלול סטרימינג תומך כרגע באנגלית בלבד, ללא קשר לשפה שנבחרה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्ट्रीमिंग ट्रांसक्रिप्शन वर्तमान में चयनित भाषा की परवाह किए बिना केवल अंग्रेजी का समर्थन करता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A streaming átírás jelenleg csak az angol nyelvet támogatja, függetlenül a kiválasztott nyelvtől."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkripsi streaming saat ini hanya mendukung bahasa Inggris, apa pun bahasa yang dipilih."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La trascrizione in streaming attualmente supporta solo l'inglese, indipendentemente dalla lingua selezionata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ストリーミング文字起こしは現在、選択した言語に関係なく英語のみをサポートしています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스트리밍 전사는 현재 선택한 언어와 관계없이 영어만 지원합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkripsi penstriman pada masa ini menyokong bahasa Inggeris sahaja, tanpa mengira bahasa yang dipilih."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Streaming-transkripsjon støtter for øyeblikket kun engelsk, uavhengig av valgt språk."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Streamingtranscriptie ondersteunt momenteel alleen Engels, ongeacht de geselecteerde taal."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkrypcja strumieniowa obsługuje obecnie wyłącznie język angielski, niezależnie od wybranego języka."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A transcrição em streaming atualmente oferece suporte apenas ao inglês, independentemente do idioma selecionado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcrierea în flux acceptă în prezent numai limba engleză, indiferent de limba selectată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Потоковая транскрипция в настоящее время поддерживает только английский язык, независимо от выбранного языка."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Strömmande transkription stöder för närvarande endast engelska, oavsett valt språk."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปัจจุบันการถอดเสียงแบบสตรีมมิ่งรองรับภาษาอังกฤษเท่านั้น โดยไม่คำนึงถึงภาษาที่เลือก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Akış transkripsiyonu şu anda seçilen dilden bağımsız olarak yalnızca İngilizceyi destekler."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Потокова транскрипція наразі підтримує лише англійську мову, незалежно від вибраної мови."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phiên âm trực tuyến hiện chỉ hỗ trợ tiếng Anh, bất kể ngôn ngữ đã chọn."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "流式轉錄當前僅支援英語，與所選語言無關。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "流式转录当前仅支持英语，与所选语言无关。"
          }
        }
      }
    },
    "streaming_transcription_is_disabled_while_ai_enh": {
