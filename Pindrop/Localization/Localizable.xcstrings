        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los modelos más pequeños son más rápidos pero menos precisos.\nEmpieza con Base para lograr el mejor equilibrio."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pienemmät mallit ovat nopeampia, mutta vähemmän tarkkoja.\nAloita Basesta parhaan tasapainon saavuttamiseksi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modèles plus petits sont plus rapides mais moins précis.\nCommencez avec Base pour le meilleur équilibre."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "דגמים קטנים יותר מהירים יותר אך פחות מדויקים.\nהתחל עם Base לקבלת האיזון הטוב ביותר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "छोटे मॉडल तेज़ लेकिन कम सटीक होते हैं।\nसर्वोत्तम संतुलन के लिए आधार से शुरुआत करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kisebb modellek gyorsabbak, de kevésbé pontosak.\nKezdje a Base-szal a legjobb egyensúly érdekében."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Model yang lebih kecil lebih cepat namun kurang akurat.\nMulailah dengan Base untuk keseimbangan terbaik."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I modelli più piccoli sono più veloci ma meno precisi.\nInizia con Base per il miglior equilibrio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルが小さいほど高速になりますが、精度は低くなります。\n最適なバランスを得るには、Base から始めてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작은 모델은 더 빠르지만 정확도는 떨어집니다.\n최고의 균형을 위해 Base로 시작하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Model yang lebih kecil lebih pantas tetapi kurang tepat.\nMulakan dengan Base untuk keseimbangan terbaik."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindre modeller er raskere, men mindre nøyaktige.\nStart med Base for best balanse."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleinere modellen zijn sneller maar minder nauwkeurig.\nBegin met Base voor de beste balans."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mniejsze modele są szybsze, ale mniej dokładne.\nZacznij od bazy, aby uzyskać najlepszą równowagę."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelos menores são mais rápidos, mas menos precisos.\nComece com Base para obter o melhor equilíbrio."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelele mai mici sunt mai rapide, dar mai puțin precise.\nÎncepeți cu Base pentru cel mai bun echilibru."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Меньшие модели работают быстрее, но менее точны.\nНачните с базы для лучшего баланса."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindre modeller är snabbare men mindre exakta.\nBörja med Base för bästa balans."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รุ่นเล็กจะเร็วกว่าแต่แม่นยำน้อยกว่า\nเริ่มต้นด้วยฐานเพื่อความสมดุลที่ดีที่สุด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha küçük modeller daha hızlıdır ancak daha az doğrudur.\nEn iyi denge için Base ile başlayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Менші моделі швидші, але менш точні.\nПочніть з Base для найкращого балансу."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các mô hình nhỏ hơn thì nhanh hơn nhưng kém chính xác hơn.\nBắt đầu với Base để có sự cân bằng tốt nhất."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "較小的模型更快但準確度較低。\n從 Base 開始以獲得最佳平衡。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较小的模型更快但准确度较低。\n从 Base 开始以获得最佳平衡。"
          }
        }
      }
    },
