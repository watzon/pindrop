    "LM Studio only needs a token if local server authentication is enabled.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio benötigt nur ein Token, wenn die lokale Serverauthentifizierung aktiviert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio only needs a token if local server authentication is enabled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio only needs a token if local server authentication is enabled."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio n'a besoin d'un jeton que si l'authentification du serveur local est activée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio necessita di un token solo se è abilitata l'autenticazione del server locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio は、ローカルサーバー認証が有効になっている場合にのみトークンを必要とします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio에는 로컬 서버 인증이 활성화된 경우에만 토큰이 필요합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio heeft alleen een token nodig als lokale serverauthenticatie is ingeschakeld."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O LM Studio só precisa de um token se a autenticação do servidor local estiver habilitada."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio 仅在启用本地服务器身份验证时才需要令牌。"
          }
        },
        "tr": {
