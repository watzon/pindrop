    "Pindrop needs microphone access to record and transcribe your voice.nnPlease grant permission in System Settings.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop benötigt Mikrofonzugriff, um Ihre Stimme aufzunehmen und zu transkribieren.nnBitte erteilen Sie die Berechtigung in den Systemeinstellungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to record and transcribe your voice.nnPlease grant permission in System Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs microphone access to record and transcribe your voice.nnPlease grant permission in System Settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop a besoin d'un accès au microphone pour enregistrer et transcrire votre voix.nnVeuillez accorder l'autorisation dans les Paramètres Système."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necessita dell'accesso al microfono per registrare e trascrivere la tua voce.nnConcedi l'autorizzazione nelle Impostazioni di sistema."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop では、あなたの声を録音して転写するにはマイクへのアクセスが必要です。システム設定で許可を与えてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 음성을 녹음하고 텍스트로 변환하려면 마이크 액세스 권한이 필요합니다.nn시스템 설정에서 권한을 부여하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop heeft microfoontoegang nodig om je stem op te nemen en te transcriberen.nnVerleen toestemming in Systeeminstellingen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop precisa de acesso ao microfone para gravar e transcrever sua voz.nnPor favor, conceda permissão nas configurações do sistema."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop 需要麦克风访问权限来录制和转录您的语音。nn请在系统设置中授予权限。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un sesinizi kaydedip yazıya dökebilmesi için mikrofon erişimine ihtiyacı var.nnLütfen Sistem Ayarları'ndan izin verin."
          }
        }
      }
    },
