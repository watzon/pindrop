    "Temporarily mute speaker output while dictation is recording.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalten Sie die Lautsprecherausgabe vorübergehend stumm, während die Diktierung aufgenommen wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Temporarily mute speaker output while dictation is recording."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencia temporalmente la salida del altavoz mientras se graba el dictado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Coupez temporairement la sortie des haut-parleurs pendant que la dictée est enregistrée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattiva temporaneamente l'uscita dell'altoparlante durante la registrazione della dettatura."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディクテーションの録音中にスピーカー出力を一時的にミュートします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "받아쓰기가 녹음되는 동안 일시적으로 스피커 출력을 음소거합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Demp tijdelijk de luidsprekeruitvoer terwijl het dictaat wordt opgenomen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencie temporariamente a saída do alto-falante durante a gravação do ditado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在听写录制期间暂时静音扬声器输出。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dikte kaydı sırasında hoparlör çıkışını geçici olarak sessize alın."
          }
        }
      }
    },
    "Temporarily pause active media playback while dictation is recording.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausieren Sie vorübergehend die aktive Medienwiedergabe, während die Diktierung aufgenommen wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Temporarily pause active media playback while dictation is recording."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
