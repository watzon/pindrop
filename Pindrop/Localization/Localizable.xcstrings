            "value": "সময়ের সাথে আপনার করা সংশোধনগুলি থেকে Pindrop কে শান্তভাবে শব্দভান্ডার শিখতে দিন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nechte Pindrop tiše se učit slovní zásobu z oprav, které v průběhu času uděláte."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lad Pindrop stille og roligt lære ordforråd fra de rettelser, du foretager over tid."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lassen Sie Pindrop im Hintergrund Vokabular aus den Korrekturen lernen, die Sie im Laufe der Zeit vornehmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let Pindrop quietly learn vocabulary from the corrections you make over time."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αφήστε τον Pindrop να μάθει αθόρυβα λεξιλόγιο από τις διορθώσεις που κάνετε με την πάροδο του χρόνου."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deja que Pindrop aprenda vocabulario silenciosamente de las correcciones que hagas con el tiempo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Anna Pindropin oppia hiljaa sanastoa ajan mittaan tekemistäsi korjauksista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laissez Pindrop apprendre tranquillement le vocabulaire à partir des corrections que vous faites au fil du temps."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "תן לפינדרופ ללמוד בשקט אוצר מילים מהתיקונים שאתה מבצע לאורך זמן."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिनड्रॉप को समय के साथ आपके द्वारा किए गए सुधारों से चुपचाप शब्दावली सीखने दें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hagyja, hogy Pindrop csendesen tanulja meg a szókincset az idők során elvégzett javításokból."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Biarkan Pindrop diam-diam mempelajari kosakata dari koreksi yang Anda lakukan seiring waktu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lascia che Pindrop impari tranquillamente il vocabolario dalle correzioni che apporti nel tempo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop は、時間をかけて修正した単語を静かに学習させてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 시간이 지남에 따라 수정한 내용을 통해 조용히 단어를 학습하게 하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Biarkan Pindrop mempelajari perbendaharaan kata secara senyap-senyap daripada pembetulan yang anda buat dari semasa ke semasa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "La Pindrop rolig lære ordforråd fra rettelsene du gjør over tid."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Laat Pindrop rustig de woordenschat leren van de correcties die u in de loop van de tijd aanbrengt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pozwól Pindropowi spokojnie uczyć się słownictwa na podstawie poprawek, które z czasem wprowadzasz."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixe o Pindrop aprender silenciosamente o vocabulário com as correções que você faz ao longo do tempo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Lăsați-l pe Pindrop să învețe în liniște vocabularul din corecțiile pe care le faceți în timp."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Позвольте Pindrop незаметно выучить словарный запас на основе исправлений, которые вы вносите с течением времени."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Låt Pindrop tyst lära sig ordförråd från de korrigeringar du gör med tiden."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ให้ Pindrop เรียนรู้คำศัพท์อย่างเงียบๆ จากการแก้ไขที่คุณทำเมื่อเวลาผ่านไป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un zaman içinde yaptığınız düzeltmelerden sessizce kelime öğrenmesine izin verin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Дозвольте Pindrop спокійно вивчати лексику на основі виправлень, які ви вносите з часом."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hãy để Pindrop lặng lẽ học từ vựng từ những chỉnh sửa mà bạn thực hiện theo thời gian."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讓 Pindrop 悄悄地從您隨時間做出的更正中學習詞彙。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让 Pindrop 悄悄地从您随时间做出的更正中学习词汇。"
          }
        }
      }
    },
