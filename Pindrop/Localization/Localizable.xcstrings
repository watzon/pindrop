    "choose_languages_for_the_interface_and_for_dicta": {
      "comment": "choose_languages_for_the_interface_and_for_dicta",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر اللغات للواجهة والإملاء. التلقائي يتبع النظام."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ইন্টারফেস এবং শ্রুতিমধুর জন্য ভাষা চয়ন করুন. স্বয়ংক্রিয়ভাবে সিস্টেম অনুসরণ করে."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte jazyky pro rozhraní a pro diktování. Automaticky následuje systém."
          }
        },
        "da": {
