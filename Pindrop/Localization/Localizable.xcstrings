        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen modeller tilgjengelig. Prøv Refresh eller skriv inn en modell-ID manuelt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen modellen beschikbaar. Probeer Vernieuwen of voer handmatig een model-ID in."
