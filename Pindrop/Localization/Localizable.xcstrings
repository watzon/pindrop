    "manage_local_speech_models_feature_models_and_th": {
      "comment": "manage_local_speech_models_feature_models_and_th",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إدارة نماذج الكلام المحلية ونماذج الميزات والمحرك الافتراضي الذي يستخدمه Pindrop للنسخ."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্থানীয় স্পিচ মডেল, ফিচার মডেল এবং ডিফল্ট ইঞ্জিন পিনড্রপ ট্রান্সক্রিপশনের জন্য ব্যবহার করে পরিচালনা করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Spravujte modely místní řeči, modely funkcí a výchozí modul, který Pindrop používá pro přepis."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Administrer lokale talemodeller, funktionsmodeller og den standardmaskine, Pindrop bruger til transskription."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwalten Sie lokale Sprachmodelle, Funktionsmodelle und die Standard-Engine, die Pindrop für die Transkription verwendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage local speech models, feature models, and the default engine Pindrop uses for transcription."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαχειριστείτε μοντέλα τοπικής ομιλίας, μοντέλα δυνατοτήτων και τον προεπιλεγμένο κινητήρα που χρησιμοποιεί το Pindrop για μεταγραφή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona los modelos de voz locales, los modelos de funciones y el motor predeterminado que Pindrop usa para la transcripción."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hallinnoi paikallisia puhemalleja, ominaisuusmalleja ja oletusmoottoria, jota Pindrop käyttää transkriptioon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez les modèles vocaux locaux, les modèles de fonctionnalités et le moteur par défaut que Pindrop utilise pour la transcription."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נהל מודלים מקומיים של דיבור, דגמי תכונה ומנוע ברירת המחדל ש-Pindrop משתמש בו לתמלול."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय भाषण मॉडल, फीचर मॉडल और ट्रांसक्रिप्शन के लिए पिनड्रॉप द्वारा उपयोग किए जाने वाले डिफ़ॉल्ट इंजन को प्रबंधित करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kezelheti a helyi beszédmodelleket, funkciómodelleket és az átíráshoz használt Pindrop alapértelmezett motort."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kelola model ucapan lokal, model fitur, dan mesin default yang digunakan Pindrop untuk transkripsi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestisci modelli vocali locali, modelli di funzionalità e il motore predefinito utilizzato da Pindrop per la trascrizione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカル音声モデル、特徴モデル、および Pindrop が文字起こしに使用するデフォルト エンジンを管理します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 음성 모델, 기능 모델 및 Pindrop이 전사에 사용하는 기본 엔진을 관리합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Urus model pertuturan tempatan, model ciri dan enjin lalai yang digunakan Pindrop untuk transkripsi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Administrer lokale talemodeller, funksjonsmodeller og standardmotoren Pindrop bruker for transkripsjon."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beheer lokale spraakmodellen, functiemodellen en de standaardengine die Pindrop gebruikt voor transcriptie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zarządzaj lokalnymi modelami mowy, modelami funkcji i domyślnym silnikiem używanym przez Pindrop do transkrypcji."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerencie modelos de fala locais, modelos de recursos e o mecanismo padrão que o Pindrop usa para transcrição."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestionați modelele locale de vorbire, modelele de caracteristici și motorul implicit pe care Pindrop îl folosește pentru transcriere."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Управляйте локальными речевыми моделями, моделями функций и механизмом по умолчанию, который Pindrop использует для транскрипции."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hantera lokala talmodeller, funktionsmodeller och standardmotorn Pindrop använder för transkription."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จัดการโมเดลคำพูดในท้องถิ่น โมเดลฟีเจอร์ และกลไกเริ่มต้นที่ Pindrop ใช้สำหรับการถอดเสียง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel konuşma modellerini, özellik modellerini ve Pindrop'un transkripsiyon için kullandığı varsayılan motoru yönetin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Керуйте локальними моделями мовлення, моделями функцій і механізмом за замовчуванням, який Pindrop використовує для транскрипції."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quản lý các mẫu giọng nói cục bộ, các mẫu tính năng và công cụ mặc định mà Pindrop sử dụng để phiên âm."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "管理本地語音模型、功能模型和 Pindrop 用於轉錄的預設引擎。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
