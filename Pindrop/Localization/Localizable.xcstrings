            "state": "translated",
            "value": "Pulsa una vez para empezar a grabar, luego otra vez para detener y transcribir."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Paina kerran aloittaaksesi nauhoituksen ja paina sitten uudelleen lopettaaksesi ja litteroiksesi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez une fois pour commencer l'enregistrement, puis appuyez à nouveau pour arrêter et transcrire."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לחץ פעם אחת כדי להתחיל בהקלטה, ולאחר מכן לחץ שוב כדי לעצור ולתמלל."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्डिंग शुरू करने के लिए एक बार दबाएँ, फिर रोकने और ट्रांसक्राइब करने के लिए दोबारा दबाएँ।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nyomja meg egyszer a felvétel elindításához, majd nyomja meg újra a leállításhoz és az átíráshoz."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan sekali untuk mulai merekam, lalu tekan lagi untuk berhenti dan menyalin."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi una volta per avviare la registrazione, quindi premi di nuovo per interrompere e trascrivere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1 回押すと録音が開始され、もう一度押すと停止して文字起こしされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 번 누르면 녹음이 시작되고 다시 누르면 중지 및 스크립트가 작성됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan sekali untuk memulakan rakaman, kemudian tekan sekali lagi untuk berhenti dan transkripsi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk én gang for å starte opptaket, og trykk deretter igjen for å stoppe og transkribere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Druk één keer om de opname te starten en druk vervolgens nogmaals om te stoppen en te transcriberen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij raz, aby rozpocząć nagrywanie, a następnie naciśnij ponownie, aby zatrzymać i dokonać transkrypcji."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione uma vez para iniciar a gravação e pressione novamente para parar e transcrever."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Apăsați o dată pentru a începe înregistrarea, apoi apăsați din nou pentru a opri și a transcrie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите один раз, чтобы начать запись, затем нажмите еще раз, чтобы остановить и расшифровать."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck en gång för att starta inspelningen, tryck sedan igen för att stoppa och transkribera."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กดหนึ่งครั้งเพื่อเริ่มการบันทึก จากนั้นกดอีกครั้งเพื่อหยุดและถอดเสียง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydı başlatmak için bir kez basın, ardından durdurmak ve yazıya dönüştürmek için tekrar basın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Натисніть один раз, щоб почати запис, потім натисніть ще раз, щоб зупинити та розшифрувати."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn một lần để bắt đầu ghi, sau đó nhấn lại để dừng và chép lại."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次開始錄製，然後再按一次停止並轉錄。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次开始录制，然后再按一次停止并转录。"
          }
        }
      }
    },
    "press_to_start_recording_press_again_to_open_not": {
      "comment": "press_to_start_recording_press_again_to_open_not",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط لبدء التسجيل، ثم اضغط مرة أخرى لفتح محرر الملاحظات"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রেকর্ডিং শুরু করতে টিপুন, নোট সম্পাদক খুলতে আবার টিপুন"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Stisknutím spustíte nahrávání, dalším stisknutím otevřete editor poznámek"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk for at starte optagelsen, tryk igen for at åbne noteeditor"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken Sie, um die Aufnahme zu starten, drücken Sie erneut, um den Notizeditor zu öffnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press to start recording, press again to open note editor"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πατήστε για να ξεκινήσει η εγγραφή, πατήστε ξανά για να ανοίξετε το πρόγραμμα επεξεργασίας σημειώσεων"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa para empezar a grabar y vuelve a pulsar para abrir el editor de notas"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Paina aloittaaksesi äänityksen, paina uudelleen avataksesi muistiinpanoeditorin"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez pour commencer l'enregistrement, appuyez à nouveau pour ouvrir l'éditeur de notes"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לחץ כדי להתחיל בהקלטה, לחץ שוב כדי לפתוח את עורך ההערות"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्डिंग शुरू करने के लिए दबाएँ, नोट संपादक खोलने के लिए फिर से दबाएँ"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nyomja meg a felvétel elindításához, nyomja meg újra a jegyzetszerkesztő megnyitásához"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan untuk mulai merekam, tekan lagi untuk membuka editor catatan"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi per avviare la registrazione, premi di nuovo per aprire l'editor delle note"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "押すと録音が開始され、もう一度押すとノートエディタが開きます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음을 시작하려면 누르세요. 메모 편집기를 열려면 다시 누르세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan untuk mula merakam, tekan sekali lagi untuk membuka editor nota"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk for å starte opptaket, trykk igjen for å åpne notatredigering"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Druk hierop om de opname te starten, druk nogmaals om de notitie-editor te openen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij, aby rozpocząć nagrywanie, naciśnij ponownie, aby otworzyć edytor notatek"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione para iniciar a gravação, pressione novamente para abrir o editor de notas"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Apăsați pentru a începe înregistrarea, apăsați din nou pentru a deschide editorul de note"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите, чтобы начать запись, нажмите еще раз, чтобы открыть редактор заметок."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck för att starta inspelningen, tryck igen för att öppna anteckningsredigeraren"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กดเพื่อเริ่มการบันทึก กดอีกครั้งเพื่อเปิดโปรแกรมแก้ไขบันทึก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydı başlatmak için basın, not düzenleyiciyi açmak için tekrar basın"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Натисніть, щоб почати запис, натисніть ще раз, щоб відкрити редактор нотаток"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn để bắt đầu ghi, nhấn lại để mở trình chỉnh sửa ghi chú"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按開始錄製，再按開啟筆記編輯器"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按开始录制，再按打开笔记编辑器"
          }
        }
      }
    },
