    "start_fresh_when_you_want_to_clear_preferences_o": {
      "comment": "start_fresh_when_you_want_to_clear_preferences_o",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابدأ من جديد عندما تريد مسح التفضيلات وحالة الإعداد وبيانات الاعتماد المحفوظة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি যখন পছন্দগুলি, অনবোর্ডিং অবস্থা এবং সংরক্ষিত শংসাপত্রগুলি সাফ করতে চান তখন নতুন করে শুরু করুন৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Začněte znovu, když chcete vymazat předvolby, stav registrace a uložené přihlašovací údaje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Start på en frisk, når du vil rydde præferencer, onboarding-tilstand og gemte legitimationsoplysninger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starten Sie neu, wenn Sie Einstellungen, Onboarding-Status und gespeicherte Anmeldedaten löschen möchten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start fresh when you want to clear preferences, onboarding state, and saved credentials."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ξεκινήστε από την αρχή όταν θέλετε να διαγράψετε τις προτιμήσεις, την κατάσταση ενσωμάτωσης και τα αποθηκευμένα διαπιστευτήρια."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Start fresh when you want to clear preferences, onboarding state, and saved credentials."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aloita alusta, kun haluat tyhjentää asetukset, aloitustilan ja tallennetut kirjautumistiedot."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recommencez à zéro lorsque vous voulez effacer les préférences, l'état d'intégration et les identifiants enregistrés."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התחל מחדש כאשר אתה רוצה לנקות העדפות, מצב הצטרפות ואישורים שמורים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप प्राथमिकताएं, ऑनबोर्डिंग स्थिति और सहेजे गए क्रेडेंशियल साफ़ करना चाहते हैं तो नए सिरे से शुरुआत करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kezdje újra, ha törölni szeretné a beállításokat, a belépési állapotot és a mentett hitelesítő adatokat."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mulai dari awal ketika Anda ingin menghapus preferensi, status orientasi, dan kredensial yang disimpan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricomincia da capo quando desideri cancellare le preferenze, lo stato di onboarding e le credenziali salvate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定、オンボーディング状態、保存された認証情報をクリアする場合は、最初からやり直してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 설정, 온보딩 상태 및 저장된 자격 증명을 지우려면 새로 시작하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mulakan baru apabila anda ingin mengosongkan pilihan, keadaan onboarding dan bukti kelayakan yang disimpan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Begynn på nytt når du vil slette preferanser, onboarding-status og lagret legitimasjon."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Begin opnieuw als u voorkeuren, onboardingstatus en opgeslagen inloggegevens wilt wissen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zacznij od nowa, jeśli chcesz wyczyścić preferencje, stan wdrożenia i zapisane dane uwierzytelniające."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece do zero quando quiser limpar preferências, estado de integração e credenciais salvas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Începeți din nou când doriți să ștergeți preferințele, starea de integrare și acreditările salvate."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните заново, если хотите очистить настройки, состояние подключения и сохраненные учетные данные."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Börja på nytt när du vill rensa inställningar, introduktionsstatus och sparade autentiseringsuppgifter."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เริ่มต้นใหม่เมื่อคุณต้องการล้างการตั้งค่า สถานะการเริ่มต้นใช้งาน และข้อมูลรับรองที่บันทึกไว้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tercihleri, katılım durumunu ve kayıtlı kimlik bilgilerini temizlemek istediğinizde yeni bir başlangıç ​​yapın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Почніть заново, коли захочете очистити налаштування, стан реєстрації та збережені облікові дані."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bắt đầu mới khi bạn muốn xóa tùy chọn, trạng thái giới thiệu và thông tin xác thực đã lưu."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當您想要清除首選項、引導狀態和儲存的憑證時重新開始。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当您想要清除首选项、引导状态和保存的凭证时重新开始。"
          }
        }
      }
    },
