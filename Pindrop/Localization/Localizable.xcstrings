    "microphone_permission_is_required_to_continue": {
      "comment": "microphone_permission_is_required_to_continue",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مطلوب إذن الميكروفون للمتابعة"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "চালিয়ে যাওয়ার জন্য মাইক্রোফোনের অনুমতি প্রয়োজন৷"
          }
        },
        "cs": {
