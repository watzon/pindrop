            "state": "translated",
            "value": "Apple thông minh"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence"
          }
        }
      }
    },
    "apple_intelligence_is_unavailable_on_this_system": {
      "comment": "apple_intelligence_is_unavailable_on_this_system",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence غير متوفر في هذا النظام. لن يتم حل هذه المهمة حتى يتم تمكين Apple Intelligence."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অ্যাপল ইন্টেলিজেন্স এই সিস্টেমে অনুপলব্ধ। অ্যাপল ইন্টেলিজেন্স সক্ষম না হওয়া পর্যন্ত এই অ্যাসাইনমেন্টটি সমাধান হবে না।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence není v tomto systému k dispozici. Toto přiřazení se nevyřeší, dokud nebude povolena Apple Intelligence."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence er ikke tilgængelig på dette system. Denne opgave løses ikke, før Apple Intelligence er aktiveret."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence ist auf diesem System nicht verfügbar. Diese Zuweisung wird erst gelöst, wenn Apple Intelligence aktiviert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence is unavailable on this system. This assignment will not resolve until Apple Intelligence is enabled."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Apple Intelligence δεν είναι διαθέσιμο σε αυτό το σύστημα. Αυτή η εκχώρηση δεν θα επιλυθεί έως ότου ενεργοποιηθεί το Apple Intelligence."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence no está disponible en este sistema. Esta asignación no se resolverá hasta que se habilite Apple Intelligence."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence ei ole käytettävissä tässä järjestelmässä. Tämä tehtävä ei ratkea ennen kuin Apple Intelligence on otettu käyttöön."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence n'est pas disponible sur ce système. Cette affectation ne sera pas résolue tant qu'Apple Intelligence n'est pas activé."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence אינו זמין במערכת זו. משימה זו לא תיפתר עד להפעלת Apple Intelligence."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस सिस्टम पर Apple इंटेलिजेंस उपलब्ध नहीं है. Apple इंटेलिजेंस सक्षम होने तक यह असाइनमेंट हल नहीं होगा।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Apple Intelligence nem érhető el ezen a rendszeren. Ez a hozzárendelés addig nem oldódik meg, amíg a Apple Intelligence nem engedélyezett."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence tidak tersedia di sistem ini. Tugas ini tidak akan terselesaikan sampai Apple Intelligence diaktifkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence non è disponibile su questo sistema. Questa assegnazione non verrà risolta finché Apple Intelligence non sarà abilitata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このシステムでは Apple Intelligence を利用できません。この割り当ては、Apple Intelligence が有効になるまで解決されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 시스템에서는 Apple Intelligence를 사용할 수 없습니다. 이 할당은 Apple Intelligence가 활성화될 때까지 해결되지 않습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence tidak tersedia pada sistem ini. Tugasan ini tidak akan diselesaikan sehingga Apple Intelligence didayakan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence er utilgjengelig på dette systemet. Denne oppgaven løses ikke før Apple Intelligence er aktivert."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence is niet beschikbaar op dit systeem. Deze toewijzing wordt pas opgelost als Apple Intelligence is ingeschakeld."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Funkcja Apple Intelligence jest niedostępna w tym systemie. To przypisanie nie zostanie rozwiązane, dopóki nie zostanie włączona funkcja Apple Intelligence."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Apple Intelligence não está disponível neste sistema. Esta atribuição não será resolvida até que o Apple Intelligence seja ativado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence nu este disponibilă pe acest sistem. Această atribuire nu se va rezolva până când Apple Intelligence nu este activată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence недоступна в этой системе. Это назначение не будет выполнено, пока Apple Intelligence не будет включена."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence är inte tillgängligt på det här systemet. Den här uppgiften kommer inte att lösas förrän Apple Intelligence har aktiverats."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence ไม่พร้อมใช้งานบนระบบนี้ การมอบหมายนี้จะไม่ได้รับการแก้ไขจนกว่าจะเปิดใช้งาน Apple Intelligence"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence bu sistemde kullanılamıyor. Bu atama, Apple Intelligence etkinleştirilene kadar çözülmeyecektir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence недоступна в цій системі. Це призначення не буде вирішено, доки не буде ввімкнено Apple Intelligence."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence không có sẵn trên hệ thống này. Nhiệm vụ này sẽ không được giải quyết cho đến khi Apple Intelligence được bật."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence 在此係統上不可用。在啟用 Apple Intelligence 之前，此分配不會得到解決。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence 在此系统上不可用。在启用 Apple Intelligence 之前，此分配不会得到解决。"
          }
        }
      }
    },
    "apple_intelligence_runs_on_device_and_requires_n": {
      "comment": "apple_intelligence_runs_on_device_and_requires_n",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعمل خدمة Apple Intelligence على الجهاز ولا تتطلب أي بيانات اعتماد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অ্যাপল ইন্টেলিজেন্স ডিভাইসে চলে এবং কোনো শংসাপত্রের প্রয়োজন হয় না।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence běží na zařízení a nevyžaduje žádné přihlašovací údaje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence kører på enheden og kræver ingen legitimationsoplysninger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence läuft auf dem Gerät und erfordert keine Anmeldeinformationen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence runs on-device and requires no credentials."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Apple Intelligence εκτελείται στη συσκευή και δεν απαιτεί διαπιστευτήρια."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence se ejecuta en el dispositivo y no requiere credenciales."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence toimii laitteella, eikä se vaadi kirjautumistietoja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence s'exécute sur l'appareil et ne nécessite aucune information d'identification."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence פועל במכשיר ואינו דורש אישורים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple इंटेलिजेंस डिवाइस पर चलता है और इसके लिए किसी क्रेडेंशियल की आवश्यकता नहीं होती है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az Apple Intelligence az eszközön fut, és nem igényel hitelesítő adatokat."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence berjalan di perangkat dan tidak memerlukan kredensial."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence viene eseguita sul dispositivo e non richiede credenziali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence はデバイス上で実行され、認証情報は必要ありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence는 기기 내에서 실행되며 자격 증명이 필요하지 않습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Perisikan Apple berjalan pada peranti dan tidak memerlukan bukti kelayakan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence kjører på enheten og krever ingen legitimasjon."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence draait op het apparaat en vereist geen inloggegevens."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence działa na urządzeniu i nie wymaga żadnych poświadczeń."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Apple Intelligence é executado no dispositivo e não requer credenciais."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence rulează pe dispozitiv și nu necesită acreditări."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence работает на устройстве и не требует учетных данных."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence körs på enheten och kräver inga inloggningsuppgifter."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence ทำงานบนอุปกรณ์และไม่ต้องใช้ข้อมูลประจำตัว"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence cihaz üzerinde çalışır ve herhangi bir kimlik bilgisi gerektirmez."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence працює на пристрої та не потребує облікових даних."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence chạy trên thiết bị và không yêu cầu thông tin xác thực."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence 在裝置上執行，無需憑據。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence 在设备上运行，无需凭据。"
          }
        }
      }
    },
