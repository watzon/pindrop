    "pindrop_needs_a_few_permissions_to_work_nyour_pr": {
      "comment": "pindrop_needs_a_few_permissions_to_work_nyour_pr",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج Pindrop إلى بعض الأذونات للعمل. خصوصيتك تُحترم دائمًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop-এর কাজ করার জন্য কিছু অনুমতির প্রয়োজন৷ আপনার গোপনীয়তা সর্বদা সম্মান করা হয়৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop npotřebuje několik oprávněníns, aby fungovalo.nVaše soukromí je vždy respektováno."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop har brug for et par tilladelser for at fungere.nDit privatliv respekteres altid."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop benötigt einige Berechtigungen, um zu funktionieren.nIhre Privatsphäre wird immer respektiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs a few permissions to work.nYour privacy is always respected."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Pindrop χρειάζεται μερικές άδειες για να λειτουργήσει. nΤο απόρρητό σας είναι πάντα σεβαστό."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop needs a few permissions to work.nYour privacy is always respected."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop tarvitsee muutaman käyttöoikeuden toimiakseen.nYksityisyyttäsi kunnioitetaan aina."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop a besoin de quelques autorisations pour fonctionner.nVotre vie privée est toujours respectée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop זקוק לכמה הרשאות כדי לעבוד. nהפרטיות שלך תמיד מכבדת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिनड्रॉप को काम करने के लिए कुछ अनुमतियों की आवश्यकता होती है। आपकी गोपनीयता का हमेशा सम्मान किया जाता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pindrop működéséhez néhány engedélyre van szüksége.nA magánéletét mindig tiszteletben tartják."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop memerlukan beberapa izin untuk bekerja.nPrivasi Anda selalu dihormati."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop necessita di alcune autorizzazioni per funzionare. La tua privacy è sempre rispettata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop が動作するには、いくつかの権限が必要です。nあなたのプライバシーは常に尊重されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 작동하려면 몇 가지 권한이 필요합니다.n귀하의 개인 정보는 항상 존중됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop memerlukan beberapa kebenaran untuk berfungsi.nPrivasi anda sentiasa dihormati."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop trenger noen få tillatelser for å fungere.nPersonvernet ditt blir alltid respektert."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop heeft een aantal machtigingen nodig om te kunnen werken.nUw privacy wordt altijd gerespecteerd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop potrzebuje kilku uprawnień do działania.nTwoja prywatność jest zawsze szanowana."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop precisa de algumas permissões para funcionar.nSua privacidade é sempre respeitada."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop are nevoie de câteva permisiuni pentru a funcționa.nConfidențialitatea dvs. este întotdeauna respectată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для работы Pindrop требуется несколько разрешений. nВаша конфиденциальность всегда соблюдается."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop behöver några behörigheter för att fungera.nDin integritet respekteras alltid."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop ต้องการการอนุญาตเล็กน้อยในการทำงาน ความเป็นส่วนตัวของคุณได้รับการเคารพเสมอ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un çalışması için birkaç izne ihtiyacı var.nGizliliğinize her zaman saygı gösterilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop потребує кількох дозволів для роботи.nВаша конфіденційність завжди поважається."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop cần một số quyền để hoạt động. Quyền riêng tư của bạn luôn được tôn trọng."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop 需要一些許可權才能工作。n您的隱私始終受到尊重。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop 需要一些权限才能工作。n您的隐私始终受到尊重。"
          }
        }
      }
    },
