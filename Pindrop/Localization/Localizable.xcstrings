            "state": "translated",
            "value": "Używa wbudowanego monitu dostosowanego do tego zadania."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa um prompt interno ajustado para esta tarefa."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizează un prompt încorporat reglat pentru această sarcină."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Использует встроенную подсказку, настроенную для этой задачи."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använder en inbyggd prompt som är inställd för denna uppgift."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้พร้อมต์ในตัวที่ปรับแต่งสำหรับงานนี้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu görev için ayarlanmış yerleşik bir istem kullanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовує вбудовану підказку, налаштовану для цього завдання."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sử dụng lời nhắc tích hợp được điều chỉnh cho tác vụ này."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用針對此任務調整的內建提示。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用针对此任务调整的内置提示。"
          }
        }
      }
    },
    "uses_the_160ms_parakeet_variant_for_snappier_par": {
      "comment": "uses_the_160ms_parakeet_variant_for_snappier_par",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم متغير Parakeet الذي تبلغ مدته 160 مللي ثانية للأجزاء الجزئية الأكثر سرعة على حساب زيادة في أخطاء الكلمات بنسبة 70% تقريبًا. الافتراضي هو البديل 320 مللي ثانية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "~70% বেশি শব্দ ত্রুটির খরচে স্ন্যাপিয়ার আংশিকগুলির জন্য 160ms প্যারাকিট ভেরিয়েন্ট ব্যবহার করে। ডিফল্ট হল 320ms ভেরিয়েন্ট।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Používá variantu 160 ms Parakeet pro rychlejší části za cenu ~70 % více slovních chyb. Výchozí je varianta 320 ms."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruger 160ms Parakeet-varianten til hurtigere partialer på bekostning af ~70 % flere ordfejl. Standard er 320ms varianten."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwendet die 160ms-Parakeet-Variante für flottere Teilergebnisse, auf Kosten von ~70 % mehr Worterkennungsfehlern. Standard ist die 320ms-Variante."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uses the 160ms Parakeet variant for snappier partials at the cost of ~70% more word errors. Default is the 320ms variant."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιεί την παραλλαγή Parakeet των 160 ms για πιο ευέλικτα τμήματα με κόστος ~ 70% περισσότερων σφαλμάτων λέξης. Η προεπιλογή είναι η παραλλαγή των 320 ms."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la variante Parakeet de 160 ms para resultados parciales más rápidos, a costa de ~70 % más errores de palabras. La variante predeterminada es la de 320 ms."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käyttää 160 ms:n Parakeet-varianttia näppärämpiin osioihin maksamalla ~70 % enemmän sanavirheitä. Oletus on 320 ms variantti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise la variante Parakeet 160 ms pour des résultats partiels plus rapides, au prix d'environ 70 % d'erreurs de mots supplémentaires. La variante par défaut est celle de 320 ms."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "משתמש בגרסה של 160ms Parakeet עבור חלקים חלקים יותר במחיר של ~70% יותר שגיאות מילים. ברירת המחדל היא גרסת 320ms."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "~70% अधिक शब्द त्रुटियों की कीमत पर अधिक तेज़ आंशिक भागों के लिए 160 एमएस पैराकीट संस्करण का उपयोग करता है। डिफ़ॉल्ट 320ms वैरिएंट है."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A 160 ms-os Parakeet változatot használja a frappánsabb részekre, ~70%-kal több szóhibával. Az alapértelmezett a 320 ms-os változat."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menggunakan varian Parakeet 160 md untuk bagian yang lebih cepat dengan kerugian ~70% lebih banyak kesalahan kata. Defaultnya adalah varian 320ms."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la variante Parakeet da 160 ms per parziali più reattivi, al costo di ~70 % di errori di parola in più. La variante predefinita è quella da 320 ms."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "160ms版Parakeetを使用して途中結果を高速化しますが、単語誤りが約70%増えます。既定は320ms版です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "160ms Parakeet 변형을 사용해 중간 결과가 더 빨라지지만, 단어 오류가 약 70% 증가합니다. 기본값은 320ms 변형입니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menggunakan varian Parakeet 160ms untuk bahagian yang lebih tajam dengan kos ~70% lagi ralat perkataan. Lalai ialah varian 320ms."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruker 160ms Parakeet-varianten for raskere partialer på bekostning av ~70 % flere ordfeil. Standard er 320ms-varianten."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruikt de 160 ms-variant van Parakeet voor snellere voorlopige resultaten, ten koste van ~70 % meer woordfouten. Standaard is de 320 ms-variant."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wykorzystuje wariant Parakeet o czasie trwania 160 ms w celu uzyskania szybszych fragmentów, kosztem ~70% więcej błędów słownych. Domyślnie jest to wariant 320 ms."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa a variante Parakeet de 160 ms para resultados parciais mais rápidos, ao custo de cerca de 70 % mais erros de palavra. O padrão é a variante de 320 ms."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizează varianta Parakeet de 160 ms pentru parțiale mai rapide, cu ~70% mai multe erori de cuvinte. Implicit este varianta de 320 ms."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Использует вариант Parakeet с длительностью 160 мс для более быстрых фрагментов за счет увеличения количества ошибок в словах примерно на 70%. По умолчанию используется вариант 320 мс."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använder 160ms Parakeet-varianten för snabbare partialer till priset av ~70 % fler ordfel. Standard är 320ms-varianten."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ตัวแปร Parakeet 160ms สำหรับปลากะพงบางส่วนโดยมีข้อผิดพลาดเพิ่มขึ้นประมาณ 70% ค่าเริ่มต้นคือตัวแปร 320ms"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha hızlı kısmi sonuçlar için 160 ms Parakeet varyantını kullanır, ancak ~%70 daha fazla sözcük hatasına yol açar. Varsayılan 320 ms varyantıdır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовує варіант Parakeet на 160 мс для швидшої часткової обробки за рахунок приблизно на 70% більшої кількості помилок у словах. За умовчанням встановлено варіант 320 мс."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sử dụng biến thể Parakeet 160ms cho các phần nhanh hơn với chi phí mắc lỗi từ nhiều hơn ~ 70%. Mặc định là biến thể 320ms."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 160 毫秒 Parakeet 變體以獲得更快的部分結果，但單詞錯誤會增加約 70%。預設使用 320 毫秒變體。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 160 毫秒 Parakeet 变体以获得更快的部分结果，但单词错误会增加约 70%。默认使用 320 毫秒变体。"
          }
        }
      }
    },
    "uses_the_transcription_enhancement_assignment_if": {
      "comment": "uses_the_transcription_enhancement_assignment_if",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم مهمة تحسين النسخ. إذا لم يتم تعيين أي شيء، فسيتم الاحتفاظ بمخرجات التنظيف الحتمية كما هي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ট্রান্সক্রিপশন এনহান্সমেন্ট অ্যাসাইনমেন্ট ব্যবহার করে। যদি কোনোটিই সেট করা না থাকে, তাহলে নির্ধারক ক্লিনার আউটপুট যেমন-ই রাখা হয়।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Používá přiřazení Vylepšení transkripce. Pokud není nastaveno žádné, deterministický čistší výstup se zachová tak, jak je."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruger tildelingen Transcription Enhancement. Hvis ingen er indstillet, bevares det deterministiske renseoutput som det er."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwendet die Zuordnung für Transkriptionsverbesserung. Ist keine festgelegt, bleibt die Ausgabe des deterministischen Reinigers unverändert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uses the Transcription Enhancement assignment. If none is set, the deterministic cleaner output is kept as-is."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιεί την εκχώρηση Transcription Enhancement. Εάν δεν έχει οριστεί κανένα, η ντετερμινιστική έξοδος καθαριστικού διατηρείται ως έχει."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la asignación de Mejora de transcripción. Si no hay ninguna definida, se conserva la salida del limpiador determinista tal cual."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käyttää Transkription parantaminen -tehtävää. Jos mitään ei ole asetettu, deterministisen puhdistajan lähtö pidetään sellaisenaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise l'affectation d'amélioration de transcription. En l'absence d'affectation, la sortie du nettoyeur déterministe est conservée telle quelle."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "משתמש במשימת שיפור תמלול. אם לא מוגדר, פלט מנקה דטרמיניסטי נשמר כפי שהוא."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ट्रांसक्रिप्शन एन्हांसमेंट असाइनमेंट का उपयोग करता है। यदि कोई भी सेट नहीं है, तो नियतात्मक क्लीनर आउटपुट को यथावत रखा जाता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Transzkripció javítása hozzárendelést használja. Ha egyik sincs beállítva, akkor a determinisztikus tisztító kimenet változatlan marad."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menggunakan tugas Peningkatan Transkripsi. Jika tidak ada yang disetel, keluaran pembersih deterministik akan dipertahankan apa adanya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa l'assegnazione Miglioramento trascrizione. Se non è impostata, l'output del pulitore deterministico viene mantenuto invariato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "文字起こし強化の割り当てを使用します。未設定の場合は決定論的クリーナーの出力がそのまま残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전사 향상 할당을 사용합니다. 설정되어 있지 않으면 결정론적 정리기의 출력이 그대로 유지됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Menggunakan tugasan Peningkatan Transkripsi. Jika tiada yang ditetapkan, keluaran pembersih deterministik dikekalkan seperti sedia ada."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruker oppdraget Transkripsjonsforbedring. Hvis ingen er angitt, beholdes den deterministiske renseeffekten som den er."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruikt de toewijzing voor Transcriptieverbetering. Als er geen is ingesteld, blijft de output van de deterministische opschoner ongewijzigd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Używa przypisania Wzmocnienie transkrypcji. Jeżeli żadna nie jest ustawiona, deterministyczne wyjście czyszczące pozostaje niezmienione."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa a atribuição de Aprimoramento de transcrição. Se nenhuma estiver definida, a saída do limpador determinístico é mantida."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizează atribuirea Îmbunătățirea transcripției. Dacă nu este setată niciuna, ieșirea deterministă de curățare este păstrată așa cum este."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Использует задание «Улучшение транскрипции». Если ничего не установлено, выход детерминированного очистителя сохраняется как есть."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använder uppdraget Transcription Enhancement. Om ingen är inställd, hålls den deterministiska renare utsignalen som den är."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้การมอบหมายการเพิ่มประสิทธิภาพการถอดเสียง หากไม่มีการตั้งค่าไว้ เอาต์พุตตัวล้างตามที่กำหนดจะถูกเก็บไว้เหมือนเดิม"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkript İyileştirme atamasını kullanır. Tanımlı değilse deterministik temizleyicinin çıktısı olduğu gibi bırakılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовує призначення покращення транскрипції. Якщо жодного не встановлено, вихід детермінованого очищення зберігається як є."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sử dụng bài tập Tăng cường phiên âm. Nếu không được đặt, đầu ra của trình dọn dẹp xác định sẽ được giữ nguyên."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用“轉錄增強”分配。如果未設定，則保留確定性清理器的輸出。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用“转录增强”分配。如果未设置，则保留确定性清理器的输出。"
          }
        }
      }
    },
