    "this_provider_will_be_available_in_a_future_upda": {
      "comment": "this_provider_will_be_available_in_a_future_upda",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيكون هذا الموفر متاحًا في التحديث المستقبلي.\nفي الوقت الحالي، جرب OpenAI أو استخدم نقطة نهاية مخصصة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই প্রদানকারী একটি ভবিষ্যতে আপডেট উপলব্ধ করা হবে.\n\nআপাতত, OpenAI চেষ্টা করুন বা একটি কাস্টম এন্ডপয়েন্ট ব্যবহার করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento poskytovatel bude k dispozici v budoucí aktualizaci.\nProzatím vyzkoušejte OpenAI nebo použijte vlastní koncový bod."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne udbyder vil være tilgængelig i en fremtidig opdatering.\nFor nu, prøv OpenAI eller brug et brugerdefineret slutpunkt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Anbieter wird in einem zukünftigen Update verfügbar sein.\nVersuchen Sie vorerst OpenAI oder verwenden Sie einen benutzerdefinierten Endpunkt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This provider will be available in a future update.\nFor now, try OpenAI or use a Custom endpoint."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτός ο πάροχος θα είναι διαθέσιμος σε μελλοντική ενημέρωση.\nΠρος το παρόν, δοκιμάστε το OpenAI ή χρησιμοποιήστε ένα προσαρμοσμένο τελικό σημείο."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este proveedor estará disponible en una futura actualización.\nPor ahora, prueba OpenAI o usa un endpoint personalizado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä palveluntarjoaja on saatavilla tulevassa päivityksessä.\nKokeile toistaiseksi OpenAI:ta tai käytä mukautettua päätepistettä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce fournisseur sera disponible dans une future mise à jour.\nPour l'instant, essayez OpenAI ou utilisez un point de terminaison personnalisé."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ספק זה יהיה זמין בעדכון עתידי.\nלעת עתה, נסה את OpenAI או השתמש בנקודת קצה מותאמת אישית."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रदाता भविष्य के अपडेट में उपलब्ध होगा।\nअभी के लिए, OpenAI आज़माएँ या कस्टम एंडपॉइंट का उपयोग करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a szolgáltató egy jövőbeli frissítésben lesz elérhető.\nEgyelőre próbálkozzon a OpenAI lehetőséggel, vagy használjon egyéni végpontot."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Penyedia ini akan tersedia dalam pembaruan mendatang.\nUntuk saat ini, coba OpenAI atau gunakan titik akhir Kustom."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo provider sarà disponibile in un aggiornamento futuro.\nPer ora, prova OpenAI o utilizza un endpoint personalizzato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このプロバイダーは将来のアップデートで利用可能になる予定です。\n現時点では、OpenAI を試すか、カスタム エンドポイントを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 공급자는 향후 업데이트에서 사용할 수 있습니다.\n지금은 OpenAI를 사용해 보거나 사용자 지정 엔드포인트를 사용하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembekal ini akan tersedia dalam kemas kini masa hadapan.\nBuat masa ini, cuba OpenAI atau gunakan titik akhir Tersuai."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne leverandøren vil være tilgjengelig i en fremtidig oppdatering.\nFor nå, prøv OpenAI eller bruk et tilpasset endepunkt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze provider zal beschikbaar zijn in een toekomstige update.\nProbeer voorlopig OpenAI of gebruik een aangepast eindpunt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten dostawca będzie dostępny w przyszłej aktualizacji.\nNa razie wypróbuj OpenAI lub użyj niestandardowego punktu końcowego."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este provedor estará disponível em uma atualização futura.\nPor enquanto, experimente o OpenAI ou use um endpoint personalizado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Acest furnizor va fi disponibil într-o actualizare viitoare.\nPentru moment, încercați OpenAI sau utilizați un punct final personalizat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот поставщик будет доступен в будущем обновлении.\nА пока попробуйте OpenAI или используйте пользовательскую конечную точку."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Denna leverantör kommer att finnas tillgänglig i en framtida uppdatering.\nFör nu, prova OpenAI eller använd en anpassad slutpunkt."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ผู้ให้บริการรายนี้จะพร้อมใช้งานในการอัปเดตในอนาคต\nในตอนนี้ ให้ลองใช้ OpenAI หรือใช้ปลายทางแบบกำหนดเอง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu sağlayıcı gelecekteki bir güncellemede mevcut olacaktır.\nŞimdilik OpenAI'yi deneyin veya Özel bir uç nokta kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей постачальник буде доступний у майбутньому оновленні.\nНаразі спробуйте OpenAI або використовуйте спеціальну кінцеву точку."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhà cung cấp này sẽ có sẵn trong bản cập nhật trong tương lai.\nHiện tại, hãy thử OpenAI hoặc sử dụng điểm cuối tùy chỉnh."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此提供商將在未來的更新中可用。\n目前，請嘗試 OpenAI 或使用自定義端點。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此提供商将在未来的更新中可用。\n目前，请尝试 OpenAI 或使用自定义端点。"
          }
        }
      }
    },
