    "try_searching_for_terms_like_hotkeys_microphone": {
      "comment": "try_searching_for_terms_like_hotkeys_microphone",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حاول البحث عن مصطلحات مثل مفاتيح التشغيل السريع أو الميكروفون أو التحديثات أو الوضع الحيوي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "হটকি, মাইক্রোফোন, আপডেট বা ভাইব মোডের মতো শব্দগুলি অনুসন্ধান করার চেষ্টা করুন৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zkuste vyhledat výrazy jako klávesové zkratky, mikrofon, aktualizace nebo vibrační režim."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Prøv at søge efter termer som genvejstaster, mikrofon, opdateringer eller vibetilstand."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuchen Sie, nach Begriffen wie Tastenkürzel, Mikrofon, Updates oder Vibe-Modus zu suchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try searching for terms like hotkeys, microphone, updates, or vibe mode."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δοκιμάστε να αναζητήσετε όρους όπως πλήκτρα πρόσβασης, μικρόφωνο, ενημερώσεις ή λειτουργία vibe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prueba buscando términos como atajos, micrófono, actualizaciones o modo vibe."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kokeile hakea termeillä, kuten pikanäppäimet, mikrofoni, päivitykset tai tunnelmatila."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayez de rechercher des termes comme raccourcis, microphone, mises à jour ou mode vibe."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נסה לחפש מונחים כמו מקשי קיצור, מיקרופון, עדכונים או מצב אווירה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हॉटकी, माइक्रोफ़ोन, अपडेट या वाइब मोड जैसे शब्दों को खोजने का प्रयास करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Próbáljon olyan kifejezésekre keresni, mint a gyorsbillentyűk, mikrofon, frissítések vagy hangulatmód."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Coba telusuri istilah seperti tombol pintas, mikrofon, pembaruan, atau mode getar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prova a cercare termini come tasti di scelta rapida, microfono, aggiornamenti o modalità vibrazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホットキー、マイク、アップデート、バイブ モードなどの用語を検索してみてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축키, 마이크, 업데이트, 진동 모드 등의 용어를 검색해 보세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuba cari istilah seperti kekunci pintas, mikrofon, kemas kini atau mod getaran."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Prøv å søke etter termer som hurtigtaster, mikrofon, oppdateringer eller vibe-modus."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Probeer te zoeken naar termen als sneltoetsen, microfoon, updates of sfeermodus."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spróbuj wyszukać terminy takie jak klawisze skrótu, mikrofon, aktualizacje lub tryb wibracji."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tente pesquisar termos como teclas de atalho, microfone, atualizações ou modo vibe."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Încercați să căutați termeni precum taste rapide, microfon, actualizări sau modul vibrație."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Попробуйте выполнить поиск по таким словам, как «горячие клавиши», «микрофон», «обновления» или «режим Vibe»."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Testa att söka efter termer som snabbtangenter, mikrofon, uppdateringar eller vibbläge."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลองค้นหาคำต่างๆ เช่น ปุ่มลัด ไมโครโฟน การอัปเดต หรือโหมดความรู้สึก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısayol tuşları, mikrofon, güncellemeler veya titreşim modu gibi terimleri aramayı deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Спробуйте шукати такі терміни, як гарячі клавіші, мікрофон, оновлення або режим Vibe."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hãy thử tìm kiếm các thuật ngữ như phím nóng, micrô, cập nhật hoặc chế độ rung."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "嘗試搜尋快捷鍵、麥克風、更新或 vibe 模式等術語。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尝试搜索快捷键、麦克风、更新或 vibe 模式等术语。"
          }
        }
      }
    },
