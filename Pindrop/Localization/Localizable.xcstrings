    "add_word_replacements_to_automatically_correct_c": {
      "comment": "add_word_replacements_to_automatically_correct_c",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف بدائل الكلمات لتصحيح أخطاء النسخ الشائعة تلقائيًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্বয়ংক্রিয়ভাবে সাধারণ ট্রান্সক্রিপশন ত্রুটি সংশোধন করতে শব্দ প্রতিস্থাপন যোগ করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidáním náhrad slov automaticky opravíte běžné chyby v přepisu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilføj orderstatninger for automatisk at rette almindelige transskriptionsfejl."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie Wortersatz hinzu, um häufige Transkriptionsfehler automatisch zu korrigieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add word replacements to automatically correct common transcription errors."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε αντικαταστάσεις λέξεων για αυτόματη διόρθωση συνηθισμένων σφαλμάτων μεταγραφής."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade reemplazos de palabras para corregir automáticamente errores comunes de transcripción."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Korjaa yleiset transkriptiovirheet automaattisesti lisäämällä sanankorvauksia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des remplacements de mots pour corriger automatiquement les erreurs de transcription courantes."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הוסף החלפות מילים כדי לתקן אוטומטית שגיאות תעתיק נפוצות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सामान्य प्रतिलेखन त्रुटियों को स्वचालित रूप से ठीक करने के लिए शब्द प्रतिस्थापन जोड़ें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Szóhelyettesítések hozzáadása a gyakori átírási hibák automatikus kijavításához."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan pengganti kata untuk memperbaiki kesalahan transkripsi umum secara otomatis."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi sostituzioni di parole per correggere automaticamente gli errori di trascrizione più comuni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "単語の置換を追加して、一般的な転写エラーを自動的に修正します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일반적인 전사 오류를 자동으로 수정하려면 단어 대체를 추가하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
