    "add_words_you_manually_correct_into_your_vocabul": {
      "comment": "add_words_you_manually_correct_into_your_vocabul",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف الكلمات التي تقوم بتصحيحها يدويًا إلى مفرداتك لعمليات النسخ المستقبلية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ভবিষ্যত ট্রান্সক্রিপশনের জন্য আপনার শব্দভান্ডারে ম্যানুয়ালি ঠিক করা শব্দ যোগ করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidejte slova, která ručně opravíte, do své slovní zásoby pro budoucí přepisy."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilføj ord, du manuelt retter, til dit ordforråd til fremtidige transskriptioner."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie manuell korrigierte Wörter zu Ihrem Vokabular für zukünftige Transkriptionen hinzu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add words you manually correct into your vocabulary for future transcriptions."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε λέξεις που διορθώνετε χειροκίνητα στο λεξιλόγιό σας για μελλοντικές μεταγραφές."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade palabras que corrijas manualmente a tu vocabulario para futuras transcripciones."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisää manuaalisesti korjaamasi sanat sanastoon tulevia transkriptioita varten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez les mots que vous corrigez manuellement à votre vocabulaire pour les transcriptions futures."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הוסף מילים שאתה מתקן באופן ידני לאוצר המילים שלך לתמלולים עתידיים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "भविष्य के प्रतिलेखन के लिए अपनी शब्दावली में उन शब्दों को जोड़ें जिन्हें आप मैन्युअल रूप से सही करते हैं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjon hozzá kézzel javított szavakat szókincséhez a későbbi átírásokhoz."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan kata-kata yang Anda koreksi secara manual ke dalam kosakata Anda untuk transkripsi di masa mendatang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi le parole che correggi manualmente al tuo vocabolario per le trascrizioni future."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今後の文字起こしのために、手動で修正した単語を語彙に追加します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "향후 전사를 위해 수동으로 수정하는 단어를 어휘에 추가하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan perkataan yang anda betulkan secara manual ke dalam perbendaharaan kata anda untuk transkripsi masa hadapan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til ord du manuelt korrigerer i vokabularet ditt for fremtidige transkripsjoner."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg woorden die u handmatig corrigeert toe aan uw vocabulaire voor toekomstige transcripties."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj słowa, które ręcznie poprawiłeś, do swojego słownictwa na potrzeby przyszłych transkrypcji."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione palavras que você corrige manualmente em seu vocabulário para transcrições futuras."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Adăugați cuvinte pe care le corectați manual în vocabularul dvs. pentru transcrieri viitoare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляйте слова, которые вы исправляете вручную, в свой словарный запас для будущих транскрипций."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till ord som du manuellt korrigerar i ditt ordförråd för framtida transkriptioner."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่มคำที่คุณแก้ไขลงในคำศัพท์ด้วยตนเองเพื่อการถอดเสียงในอนาคต"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelecekteki transkripsiyonlar için manuel olarak düzelttiğiniz kelimeleri kelime dağarcığınıza ekleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додайте слова, які ви виправили вручну, у свій словник для майбутніх транскрипцій."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm các từ bạn sửa theo cách thủ công vào từ vựng của mình để phiên âm trong tương lai."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將您手動更正的詞彙新增到詞彙表中，以供將來的轉錄使用。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将您手动更正的词汇添加到词汇表中，以供将来的转录使用。"
          }
        }
      }
    },
