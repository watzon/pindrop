    "display_pindrop_in_the_dock_instead_of_running_o": {
      "comment": "display_pindrop_in_the_dock_instead_of_running_o",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بعرض Pindrop في Dock بدلاً من تشغيله كتطبيق شريط قوائم فقط."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "শুধুমাত্র একটি মেনু বার অ্যাপ হিসাবে চালানোর পরিবর্তে ডকে পিনড্রপ প্রদর্শন করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zobrazte Pindrop v doku místo toho, aby běžel pouze jako aplikace na liště nabídek."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vis Pindrop i Dock i stedet for kun at køre som en menulinjeapp."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigen Sie Pindrop im Dock an, anstatt es nur als Menüleisten-App auszuführen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Display Pindrop in the Dock instead of running only as a menu bar app."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εμφανίστε το Pindrop στο Dock αντί να εκτελείται μόνο ως εφαρμογή γραμμής μενού."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra Pindrop en el Dock en lugar de ejecutarlo solo como app de barra de menús."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Näytä Pindrop Dockissa sen sijaan, että se toimisi vain valikkorivisovelluksena."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affichez Pindrop dans le Dock au lieu de l'exécuter uniquement comme une app de barre de menus."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הצג Pindrop ב-Dock במקום לפעול רק כאפליקציה של שורת תפריטים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिनड्रॉप को केवल मेनू बार ऐप के रूप में चलाने के बजाय डॉक में प्रदर्शित करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Pindrop megjelenítése a Dockban, ahelyett, hogy csak menüsor-alkalmazásként futna."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tampilkan Pindrop di Dock alih-alih menggunakannn hanya sebagai aplikasi bilah menu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualizza Pindrop nel Dock invece di essere eseguito solo come app della barra dei menu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メニュー バー アプリとしてのみ実行するのではなく、Dock に Pindrop を表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메뉴 막대 앱으로만 실행하는 대신 Dock에 Pindrop을 표시합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Paparkan Pindrop dalam Dok dan bukannya berjalan hanya sebagai apl bar menu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vis Pindrop i Dock i stedet for å kjøre bare som en menylinjeapp."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geef Pindrop weer in het Dock in plaats van alleen als menubalk-app te draaien."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyświetlaj Pindrop w Docku zamiast running tylko jako aplikację na pasku menu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Exiba o Pindrop no Dock em vez de executá-lo apenas como um aplicativo da barra de menus."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Afișați Pindrop în Dock în loc să rulați doar ca aplicație pentru bara de meniu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отображайте Pindrop в Dock вместо того, чтобы запускать его только как приложение в строке меню."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Visa Pindrop i Dock istället för att endast köras som en menyradsapp."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แสดง Pindrop ใน Dock แทนที่จะทำงานเป็นแอปแถบเมนูเท่านั้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'u yalnızca bir menü çubuğu uygulaması olarak çalıştırmak yerine Dock'ta görüntüleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відображати Pindrop у Dock замість running лише як програму на панелі меню."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiển thị Pindrop trong Dock thay vì chỉ chạy dưới dạng ứng dụng trên thanh menu."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Dock 中顯示 Pindrop，而不是僅作為選單欄應用執行。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Dock 中显示 Pindrop，而不是仅作为菜单栏应用运行。"
          }
        }
      }
    },
    "dock_the_sidebar_to_the_left_or_right_edge_of_th": {
      "comment": "dock_the_sidebar_to_the_left_or_right_edge_of_th",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بإرساء الشريط الجانبي على الحافة اليسرى أو اليمنى من النافذة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "উইন্ডোর বাম বা ডান প্রান্তে সাইডবার ডক করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukotvete postranní panel k levému nebo pravému okraji okna."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dok sidebjælken til venstre eller højre kant af vinduet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Docken Sie die Seitenleiste an den linken oder rechten Rand des Fensters."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dock the sidebar to the left or right edge of the window."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Στερεώστε την πλαϊνή γραμμή στην αριστερή ή τη δεξιά άκρη του παραθύρου."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancla la barra lateral al borde izquierdo o derecho de la ventana."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiinnitä sivupalkki ikkunan vasempaan tai oikeaan reunaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancrez la barre latérale sur le bord gauche ou droit de la fenêtre."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "עגן את סרגל הצד לקצה השמאלי או הימני של החלון."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साइडबार को विंडो के बाएँ या दाएँ किनारे पर डॉक करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Rögzítse az oldalsávot az ablak bal vagy jobb széléhez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tempatkan sidebar di tepi kiri atau kanan jendela."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora la barra laterale al bordo sinistro o destro della finestra."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイドバーをウィンドウの左端または右端にドッキングします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사이드바를 창의 왼쪽 또는 오른쪽 가장자리에 고정합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dok bar sisi ke tepi kiri atau kanan tetingkap."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fest sidefeltet til venstre eller høyre kant av vinduet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dock de zijbalk aan de linker- of rechterrand van het venster."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadokuj pasek boczny do lewej lub prawej krawędzi okna."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Encaixe a barra lateral na borda esquerda ou direita da janela."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fixați bara laterală la marginea stângă sau dreaptă a ferestrei."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прикрепите боковую панель к левому или правому краю окна."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Docka sidofältet till vänster eller höger kant av fönstret."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "วางแถบด้านข้างไว้ที่ขอบซ้ายหรือขวาของหน้าต่าง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kenar çubuğunu pencerenin sol veya sağ kenarına sabitleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Прикріпіть бічну панель до лівого або правого краю вікна."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gắn thanh bên vào cạnh trái hoặc phải của cửa sổ."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將側邊欄固定到視窗的左側或右側邊緣。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将侧边栏固定到窗口的左侧或右侧边缘。"
          }
        }
      }
    },
