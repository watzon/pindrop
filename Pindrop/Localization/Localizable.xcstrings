    "use_a_tap_to_start_tap_to_finish_shortcut_for_no": {
      "comment": "use_a_tap_to_start_tap_to_finish_shortcut_for_no",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم اختصار النقر للبدء والنقر للإنهاء لالتقاط الملاحظات."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নোট ক্যাপচারের জন্য একটি ট্যাপ-টু-স্টার্ট, ট্যাপ-টু-ফিনিশ শর্টকাট ব্যবহার করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "K zachycení poznámky použijte zkratku klepnutím spustíte a ukončíte klepnutím."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Brug en tryk-for-at-start, tryk-for-afslut-genvej til noteoptagelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie eine Tippe-zum-Starten, Tippe-zum-Beenden-Verknüpfung für die Notizerfassung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a tap-to-start, tap-to-finish shortcut for note capture."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιήστε μια συντόμευση πάτημα για έναρξη, πάτημα για ολοκλήρωση για τη λήψη σημειώσεων."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa un atajo de pulsar para iniciar, pulsar para finalizar para captura de notas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käytä napauttamalla aloita ja lopeta napauttamalla pikakuvaketta muistiinpanojen tallentamiseen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez un raccourci tap-to-start, tap-to-finish pour la capture de notes."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השתמש בקיצור דרך הקש כדי להתחיל, הקש לסיום ללכידת הערות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नोट कैप्चर के लिए टैप-टू-स्टार्ट, टैप-टू-फिनिश शॉर्टकट का उपयोग करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A jegyzetek rögzítéséhez használjon koppintással indítható, érintéssel befejezhető parancsikont."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan pintasan ketuk untuk memulai, ketuk untuk menyelesaikan untuk pengambilan catatan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza una scorciatoia tocca per iniziare e tocca per finire per l'acquisizione delle note."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タップして開始、タップして終了するショートカットを使用してメモをキャプチャします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "탭하여 시작, 탭하여 종료 단축키를 사용하여 메모를 캡처하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan pintasan ketik-untuk-mula, ketik-untuk-selesai untuk menangkap nota."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruk en trykk-for-å-start, trykk-for-avslutt-snarvei for å fange notater."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik een sneltoets om te beginnen en te eindigen om notities vast te leggen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby przechwytywać notatki, użyj skrótu typu „dotknij, aby rozpocząć” i „dokończ, aby zakończyć”."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use um atalho toque para iniciar e toque para terminar para capturar notas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Folosiți o comandă rapidă apăsare pentru a începe, apăsare pentru a termina pentru a captura note."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте ярлык «Нажмите, чтобы начать» и «Нажмите, чтобы закончить» для записи заметок."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd en genväg med tryck för att starta, tryck för att avsluta för att fånga anteckningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ทางลัดแตะเพื่อเริ่มต้น แตะเพื่อเสร็จสิ้นสำหรับการบันทึกโน้ต"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Not yakalamak için dokunarak başlat ve dokunarak bitir kısayolunu kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовуйте ярлик для створення нотаток."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sử dụng phím tắt nhấn để bắt đầu, nhấn để kết thúc để ghi chú."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用點選開始、點選完成的快捷鍵進行筆記捕獲。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用点击开始、点击完成的快捷键进行笔记捕获。"
          }
        }
      }
    },
