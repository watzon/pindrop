    "failed_to_initialize_the_database_nnthe_app_will": {
      "comment": "failed_to_initialize_the_database_nnthe_app_will",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل في تهيئة قاعدة البيانات: %@nnسيتم إنهاء التطبيق الآن. يرجى محاولة إعادة التشغيل أو الاتصال بالدعم إذا استمرت المشكلة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ডাটাবেস আরম্ভ করতে ব্যর্থ হয়েছে: %@nn অ্যাপটি এখন প্রস্থান করবে। অনুগ্রহ করে পুনরায় চালু করার চেষ্টা করুন বা সমস্যা থেকে গেলে সহায়তার সাথে যোগাযোগ করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicializace databáze se nezdařila: %@nnAplikace se nyní ukončí. Zkuste restartovat nebo kontaktujte podporu, pokud problém přetrvává."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke initialisere databasen: %@nnAppen vil nu afslutte. Prøv at genstarte, eller kontakt support, hvis problemet fortsætter."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Datenbank konnte nicht initialisiert werden: %@nnDie App wird jetzt beendet. Bitte versuchen Sie einen Neustart oder kontaktieren Sie den Support, wenn das Problem weiterhin besteht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to initialize the database: %@nnThe app will now quit. Please try restarting or contact support if the problem persists."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απέτυχε η προετοιμασία της βάσης δεδομένων: %@nnΗ εφαρμογή θα τερματιστεί τώρα. Δοκιμάστε να κάνετε επανεκκίνηση ή επικοινωνήστε με την υποστήριξη εάν το πρόβλημα παραμένει."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to initialize the database: %@nnThe app will now quit. Please try restarting or contact support if the problem persists."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tietokannan alustaminen epäonnistui: %@nnSovellus sulkeutuu nyt. Yritä käynnistää uudelleen tai ota yhteyttä tukeen, jos ongelma jatkuu."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'initialisation de la base de données : %@nnL'app va maintenant se fermer. Veuillez essayer de redémarrer ou contacter le support si le problème persiste."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אתחול מסד הנתונים נכשל: %@nnהאפליקציה תיסגר כעת. אנא נסה להפעיל מחדש או צור קשר עם התמיכה אם הבעיה נמשכת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डेटाबेस प्रारंभ करने में विफल: %@nn ऐप अब बंद हो जाएगा। यदि समस्या बनी रहती है तो कृपया पुनः आरंभ करने का प्रयास करें या सहायता से संपर्क करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem sikerült inicializálni az adatbázist: %@nnAz alkalmazás most kilép. Kérjük, próbálja meg újraindítani, vagy forduljon az ügyfélszolgálathoz, ha a probléma továbbra is fennáll."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gagal menginisialisasi database: %@nnAplikasi sekarang akan ditutup. Silakan coba memulai ulang atau hubungi dukungan jika masalah terus berlanjut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile inizializzare il database: %@nnL'app verrà chiusa. Prova a riavviare o contatta l'assistenza se il problema persiste."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データベースの初期化に失敗しました: %@nnアプリは終了します。問題が解決しない場合は、再起動するか、サポートにお問い合わせください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터베이스 초기화 실패: %@nn이제 앱이 종료됩니다. 문제가 지속되면 다시 시작하거나 지원팀에 문의하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gagal untuk memulakan pangkalan data: %@nnApl kini akan berhenti. Sila cuba mulakan semula atau hubungi sokongan jika masalah berterusan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke initialisere databasen: %@nnAppen vil nå avsluttes. Prøv å starte på nytt eller kontakt brukerstøtte hvis problemet vedvarer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan de database niet initialiseren: %@nnDe app wordt nu afgesloten. Probeer opnieuw op te starten of neem contact op met de ondersteuning als het probleem zich blijft voordoen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się zainicjować bazy danych: %@nnAplikacja zostanie teraz zamknięta. Spróbuj uruchomić ponownie lub skontaktuj się z pomocą techniczną, jeśli problem będzie się powtarzał."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao inicializar o banco de dados: %@nnO aplicativo será encerrado agora. Tente reiniciar ou entre em contato com o suporte se o problema persistir."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Eșuarea inițializării bazei de date: %@nnAplicația se va închide acum. Vă rugăm să încercați să reporniți sau să contactați asistența dacă problema persistă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось инициализировать базу данных: %@nnПриложение закроется. Попробуйте перезагрузить компьютер или обратитесь в службу поддержки, если проблема не устранена."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det gick inte att initiera databasen: %@nnAppen avslutas nu. Försök att starta om eller kontakta supporten om problemet kvarstår."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่สามารถเริ่มต้นฐานข้อมูล: %@nnแอปจะปิดในขณะนี้ โปรดลองรีสตาร์ทหรือติดต่อฝ่ายสนับสนุนหากปัญหายังคงมีอยู่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veritabanı başlatılamadı: %@nnUygulamadan şimdi çıkılacak. Lütfen yeniden başlatmayı deneyin veya sorun devam ederse destek ekibiyle iletişime geçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося ініціалізувати базу даних: %@nnПрограма закриється. Спробуйте перезапустити або зверніться до служби підтримки, якщо проблема не зникне."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không thể khởi tạo cơ sở dữ liệu: %@nnỨng dụng bây giờ sẽ thoát. Vui lòng thử khởi động lại hoặc liên hệ với bộ phận hỗ trợ nếu sự cố vẫn tiếp diễn."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "初始化資料庫失敗：%@nn應用現在將退出。如果問題仍然存在，請嘗試重新啟動或聯絡支援。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "初始化数据库失败：%@nn应用现在将退出。如果问题仍然存在，请尝试重新启动或联系支持。"
          }
        }
      }
    },
