          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Control how Pindrop appears in macOS and whether it starts with your desktop session."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Contrôlez comment Pindrop apparaît dans macOS et s'il démarre avec votre session."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controlla come appare Pindrop in macOS e se si avvia con la sessione desktop."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop が macOS でどのように表示されるか、およびデスクトップ セッションで開始されるかどうかを制御します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS에서 Pindrop이 나타나는 방식과 데스크탑 세션에서 Pindrop이 시작되는지 여부를 제어합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bepaal hoe Pindrop verschijnt in macOS en of het begint met uw desktopsessie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Controle como o Pindrop aparece no macOS e se ele inicia na sua sessão de desktop."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制 Pindrop 在 macOS 中的显示方式以及是否随桌面会话启动。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un macOS'ta nasıl görüneceğini ve masaüstü oturumunuzla başlayıp başlamayacağını kontrol edin."
