    "supports_local_media_files_and_web_links_resolve": {
      "comment": "supports_local_media_files_and_web_links_resolve",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يدعم ملفات الوسائط المحلية وروابط الويب التي تم حلها باستخدام yt-dlp."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "yt-dlp দিয়ে সমাধান করা স্থানীয় মিডিয়া ফাইল এবং ওয়েব লিঙ্কগুলিকে সমর্থন করে।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Podporuje místní mediální soubory a webové odkazy vyřešené pomocí yt-dlp."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Understøtter lokale mediefiler og weblinks løst med yt-dlp."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unterstützt lokale Mediendateien und Web-Links, die mit yt-dlp aufgelöst werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Supports local media files and web links resolved with yt-dlp."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Υποστηρίζει αρχεία τοπικών πολυμέσων και συνδέσμους ιστού που επιλύονται με yt-dlp."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Admite archivos multimedia locales y enlaces web resueltos con yt-dlp."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tukee paikallisia mediatiedostoja ja verkkolinkkejä, jotka on ratkaistu yt-dlp:llä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prend en charge les fichiers médias locaux et les liens web résolus avec yt-dlp."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "תומך בקבצי מדיה מקומיים וקישורי אינטרנט שנפתרו באמצעות yt-dlp."
