    "use_transcription_as_a_placeholder_for_the_trans": {
      "comment": "use_transcription_as_a_placeholder_for_the_trans",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم ${transcription} كعنصر نائب للنص المكتوب."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতিলিপিকৃত পাঠ্যের জন্য একটি স্থানধারক হিসাবে ${transcription} ব্যবহার করুন।"
          }
