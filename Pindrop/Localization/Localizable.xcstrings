    "are_you_sure_you_want_to_delete_this_action_cann": {
      "comment": "are_you_sure_you_want_to_delete_this_action_cann",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد أنك تريد حذف '%@'؟ لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি কি '%@' মুছতে চান? এই ক্রিয়াটি পূর্বাবস্থায় ফেরানো যাবে না৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Opravdu chcete smazat „%@“? Tuto akci nelze vrátit zpět."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på, at du vil slette '%@'? Denne handling kan ikke fortrydes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie '%@' löschen möchten? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete '%@'? This action cannot be undone."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Είστε βέβαιοι ότι θέλετε να διαγράψετε το '%@'; Αυτή η ενέργεια δεν μπορεί να αναιρεθεί."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres eliminar '%@'? Esta acción no se puede deshacer."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Haluatko varmasti poistaa kohteen '%@'? Tätä toimintoa ei voi kumota."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir supprimer '%@' ? Cette action ne peut pas être annulée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "האם אתה בטוח שברצונך למחוק את '%@'? לא ניתן לבטל פעולה זו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या आप वाकई '%@' को हटाना चाहते हैं? इस एक्शन को वापस नहीं किया जा सकता।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Biztosan törli a következőt: '%@'? Ez a művelet nem vonható vissza."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apakah Anda yakin ingin menghapus '%@'? Tindakan ini tidak dapat diurungkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler eliminare '%@'? Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」を削除してもよろしいですか?この操作は元に戻すことができません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정말로 '%@'을(를) 삭제하시겠습니까? 이 작업은 취소할 수 없습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Adakah anda pasti mahu memadamkan '%@'? Tindakan ini tidak boleh dibuat asal."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på at du vil slette '%@'? Denne handlingen kan ikke angres."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet u zeker dat u '%@' wilt verwijderen? Deze actie kan niet ongedaan worden gemaakt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć „%@”? Tej akcji nie można cofnąć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir '%@'? Esta ação não pode ser desfeita."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigur doriți să ștergeți „%@”? Această acțiune nu poate fi anulată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить «%@»? Это действие невозможно отменить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Är du säker på att du vill ta bort '%@'? Denna åtgärd kan inte ångras."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณแน่ใจหรือไม่ว่าต้องการลบ '%@' การดำเนินการนี้ไม่สามารถยกเลิกได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' dosyasını silmek istediğinizden emin misiniz? Bu eylem geri alınamaz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви впевнені, що хочете видалити \"%@\"? Цю діюnnне можна скасувати."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc chắn muốn xóa '%@' không? Không thể hoàn tác hành động này."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您確定要刪除'%@'嗎？此操作無法撤銷。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要删除'%@'吗？此操作无法撤销。"
          }
        }
      }
    },
