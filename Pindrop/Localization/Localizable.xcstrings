    "ollama_usually_does_not_require_authentication_f": {
      "comment": "ollama_usually_does_not_require_authentication_f",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يتطلب Olma عادةً المصادقة للطلبات المحلية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ওল্লামার সাধারণত স্থানীয় অনুরোধের জন্য প্রমাণীকরণের প্রয়োজন হয় না।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama obvykle nevyžaduje ověření pro místní požadavky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama kræver normalt ikke godkendelse for lokale anmodninger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama erfordert normalerweise keine Authentifizierung für lokale Anfragen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama usually does not require authentication for local requests."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Ollama συνήθως δεν απαιτεί έλεγχο ταυτότητας για τοπικά αιτήματα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama usually does not require authentication for local requests."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama ei yleensä vaadi todennusta paikallisiin pyyntöihin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama ne nécessite généralement pas d'authentification pour les requêtes locales."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אולמה בדרך כלל אינה דורשת אימות עבור בקשות מקומיות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ओलामा को आमतौर पर स्थानीय अनुरोधों के लिए प्रमाणीकरण की आवश्यकता नहीं होती है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az Ollama általában nem igényel hitelesítést a helyi kérésekhez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama biasanya tidak memerlukan otentikasi untuk permintaan lokal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama solitamente non richiede l'autenticazione per le richieste locali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama は通常、ローカル要求に対して認証を必要としません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama는 일반적으로 로컬 요청에 대한 인증을 요구하지 않습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama biasanya tidak memerlukan pengesahan untuk permintaan tempatan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama krever vanligvis ikke autentisering for lokale forespørsler."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama vereist meestal geen authenticatie voor lokale verzoeken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama zwykle nie wymaga uwierzytelniania w przypadku żądań lokalnych."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama geralmente não requer autenticação para solicitações locais."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama de obicei nu necesită autentificare pentru solicitările locale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оллама обычно не требует аутентификации для локальных запросов."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama kräver vanligtvis inte autentisering för lokala förfrågningar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โดยทั่วไป Ollama ไม่ต้องการการรับรองความถูกต้องสำหรับคำขอในเครื่อง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama genellikle yerel istekler için kimlik doğrulama gerektirmez."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama зазвичай не вимагає автентифікації для локальних запитів."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama thường không yêu cầu xác thực đối với các yêu cầu cục bộ."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama 通常不需要本地請求的身份驗證。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Ollama 通常不需要本地请求的身份验证。"
          }
        }
      }
