    "hold_the_shortcut_to_record_then_release_to_tran": {
      "comment": "hold_the_shortcut_to_record_then_release_to_tran",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط مع الاستمرار على الاختصار للتسجيل، ثم حرره للنسخ."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রেকর্ড করতে শর্টকাট ধরে রাখুন, তারপর ট্রান্সক্রাইব করতে ছেড়ে দিন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Chcete-li nahrávat, podržte klávesovou zkratku a poté ji uvolněte pro přepis."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold genvejen for at optage, og slip derefter for at transskribere."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halten Sie die Tastenkombination zum Aufnehmen gedrückt, lassen Sie sie los, um zu transkribieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold the shortcut to record, then release to transcribe."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κρατήστε πατημένο τη συντόμευση για εγγραφή και, στη συνέχεια, αφήστε το για μεταγραφή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén el atajo para grabar, luego suelta para transcribir."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidä pikanäppäintä painettuna tallentaaksesi ja vapauta sitten litteroimaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez le raccourci pour enregistrer, puis relâchez pour transcrire."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החזק את קיצור הדרך להקלטה ולאחר מכן שחרר כדי לתמלל."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्ड करने के लिए शॉर्टकट को दबाए रखें, फिर ट्रांसक्राइब करने के लिए छोड़ दें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tartsa lenyomva a parancsikont a rögzítéshez, majd engedje fel az átíráshoz."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan pintasan untuk merekam, lalu lepaskan untuk menyalin."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuta la scorciatoia per registrare, quindi rilasciala per trascrivere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットを長押しして録音し、放して文字起こしします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음하려면 단축키를 길게 누른 다음 스크립트를 작성하려면 손을 떼세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan pintasan untuk merakam, kemudian lepaskan untuk menyalin."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold snarveien for å ta opp, og slipp deretter for å transkribere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd de sneltoets ingedrukt om op te nemen en laat vervolgens los om te transcriberen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj skrót, aby nagrać, a następnie zwolnij, aby dokonać transkrypcji."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure o atalho para gravar e solte para transcrever."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Țineți apăsată comanda rapidă pentru a înregistra, apoi eliberați pentru a transcrie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удерживайте ярлык для записи, затем отпустите для расшифровки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll ned genvägen för att spela in och släpp sedan för att transkribera."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กดคีย์ลัดค้างไว้เพื่อบันทึก จากนั้นปล่อยเพื่อถอดเสียง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydetmek için kısayolu basılı tutun, ardından metne dönüştürmek için bırakın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Утримуйте ярлик, щоб записати, а потім відпустіть, щоб транскрибувати."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ phím tắt để ghi, sau đó thả ra để chép lời."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按住快捷鍵錄製，然後釋放以轉錄。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住快捷键录制，然后释放以转录。"
          }
        }
      }
    },
    "hold_to_record_release_to_open_note_editor_with": {
      "comment": "hold_to_record_release_to_open_note_editor_with",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط مع الاستمرار للتسجيل، ثم حرره لفتح محرر الملاحظات مع النسخ"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রেকর্ড করতে ধরে রাখুন, ট্রান্সক্রিপশন সহ নোট সম্পাদক খুলতে ছেড়ে দিন"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Podržením nahrajete, uvolněním otevřete editor poznámek s přepisem"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold nede for at optage, slip for at åbne noteeditor med transskription"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halten Sie zum Aufnehmen gedrückt, lassen Sie los, um den Notizeditor mit Transkription zu öffnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold to record, release to open note editor with transcription"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κρατήστε πατημένο για εγγραφή, αφήστε το για να ανοίξει το πρόγραμμα επεξεργασίας σημειώσεων με μεταγραφή"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén pulsado para grabar; al soltar se abrirá el editor de notas con la transcripción"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidä painettuna tallentaaksesi, vapauta avataksesi muistiinpanoeditorin ja transkription"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez pour enregistrer, relâchez pour ouvrir l'éditeur de notes avec transcription"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החזק כדי להקליט, שחרר כדי לפתוח את עורך הערות עם תמלול"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्ड करने के लिए दबाए रखें, प्रतिलेखन के साथ नोट संपादक खोलने के लिए छोड़ें"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tartsa lenyomva a rögzítéshez, engedje fel a jegyzetszerkesztő megnyitásához az átírással"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan untuk merekam, lepaskan untuk membuka editor catatan dengan transkripsi"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto per registrare, rilascia per aprire l'editor di note con trascrizione"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "長押しして録音、離すと文字起こし付きのノートエディターが開きます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "길게 누르면 녹음되고, 떼면 스크립트가 포함된 메모 편집기가 열립니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan untuk merakam, lepaskan untuk membuka editor nota dengan transkripsi"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold for å ta opp, slipp for å åpne notatredigering med transkripsjon"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd ingedrukt om op te nemen, laat los om de notitie-editor met transcriptie te openen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj, aby nagrać, zwolnij, aby otworzyć edytor notatek z transkrypcją"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure para gravar, solte para abrir o editor de notas com transcrição"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Țineți apăsat pentru a înregistra, eliberați pentru a deschide editorul de note cu transcriere"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удерживайте, чтобы записать, отпустите, чтобы открыть редактор заметок с транскрипцией."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll ned för att spela in, släpp för att öppna anteckningsredigeraren med transkription"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กดค้างไว้เพื่อบันทึก ปล่อยเพื่อเปิดเครื่องมือแก้ไขบันทึกพร้อมการถอดเสียง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydetmek için basılı tutun, transkripsiyonlu not düzenleyiciyi açmak için bırakın"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Утримуйте, щоб записати, відпустіть, щоб відкрити редактор нотаток із транскрипцією"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ để ghi, nhả để mở trình chỉnh sửa ghi chú có phiên âm"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按住錄製，釋放以開啟帶轉錄的筆記編輯器"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住录制，释放以打开带转录的笔记编辑器"
          }
        }
      }
    },
    "hold_to_record_release_to_stop_and_transcribe": {
      "comment": "hold_to_record_release_to_stop_and_transcribe",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط باستمرار للتسجيل، ثم حرر للإيقاف والنسخ"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রেকর্ড করতে ধরে রাখুন, থামাতে ছেড়ে দিন এবং প্রতিলিপি করুন"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Podržením záznam nahrajete, uvolněním zastavíte a přepíšete"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold nede for at optage, slip for at stoppe og transskribere"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halten Sie zum Aufnehmen gedrückt, lassen Sie los, um zu stoppen und zu transkribieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold to record, release to stop and transcribe"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κρατήστε πατημένο για εγγραφή, αφήστε το για διακοπή και μεταγραφή"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén pulsado para grabar; al soltar se detendrá y transcribirá"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidä painettuna tallentaaksesi, vapauta pysäyttääksesi ja litteroiksesi"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez pour enregistrer, relâchez pour arrêter et transcrire"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החזק כדי להקליט, שחרר כדי לעצור ולתמלל"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्ड करने के लिए दबाएँ, रोकने और प्रतिलेखन करने के लिए छोड़ें"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tartsa lenyomva a rögzítéshez, engedje fel a leállításhoz és átíráshoz"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan untuk merekam, lepaskan untuk berhenti dan menyalin"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto per registrare, rilascia per interrompere e trascrivere"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "押し続けると録音、放すと停止および転写"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음하려면 길게 누르고, 중지하고 스크립트를 작성하려면 떼세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan untuk merakam, lepaskan untuk berhenti dan transkripsi"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold for å ta opp, slipp for å stoppe og transkribere"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd ingedrukt om op te nemen, laat los om te stoppen en te transcriberen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj, aby nagrać, zwolnij, aby zatrzymać i dokonać transkrypcji"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure para gravar, solte para parar e transcrever"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Țineți apăsat pentru a înregistra, eliberați pentru a opri și a transcrie"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удерживайте, чтобы записать, отпустите, чтобы остановить и расшифровать"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll ned för att spela in, släpp för att stoppa och transkribera"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กดค้างไว้เพื่อบันทึก ปล่อยเพื่อหยุดและถอดเสียง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydetmek için basılı tutun, durdurmak ve metne dönüştürmek için bırakın"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Утримуйте, щоб записати, відпустіть, щоб зупинити та транскрибувати"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ để ghi, thả ra để dừng và chép lại"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按住錄製，釋放以停止並轉錄"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住录制，释放以停止并转录"
          }
        }
      }
    },
