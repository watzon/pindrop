    "press_once_to_start_recording_press_again_to_sto": {
      "comment": "press_once_to_start_recording_press_again_to_sto",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط مرة واحدة لبدء التسجيل، واضغط مرة أخرى للإيقاف والنسخ"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রেকর্ডিং শুরু করতে একবার টিপুন, থামাতে আবার টিপুন এবং প্রতিলিপি করুন৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jedním stisknutím spustíte nahrávání, dalším stisknutím zastavíte a přepíšete"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk én gang for at starte optagelsen, tryk igen for at stoppe og transskribere"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einmal drücken, um die Aufnahme zu starten, erneut drücken, um zu stoppen und zu transkribieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press once to start recording, press again to stop and transcribe"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πατήστε μία φορά για να ξεκινήσει η εγγραφή, πατήστε ξανά για διακοπή και μεταγραφή"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa una vez para empezar a grabar y otra vez para detener y transcribir"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Paina kerran aloittaaksesi nauhoituksen, paina uudelleen lopettaaksesi ja litteroiksesi"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez une fois pour commencer l'enregistrement, appuyez à nouveau pour arrêter et transcrire"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לחץ פעם אחת כדי להתחיל בהקלטה, לחץ שוב כדי לעצור ולתמלל"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्डिंग शुरू करने के लिए एक बार दबाएँ, रोकने और ट्रांसक्राइब करने के लिए दोबारा दबाएँ"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nyomja meg egyszer a felvétel elindításához, nyomja meg újra a leállításhoz és az átíráshoz"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan sekali untuk mulai merekam, tekan lagi untuk berhenti dan menyalin"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi una volta per avviare la registrazione, premi di nuovo per interrompere e trascrivere"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1 回押すと録音が開始され、もう一度押すと停止して文字起こしされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 번 누르면 녹음이 시작되고, 다시 누르면 중지되고 스크립트가 작성됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan sekali untuk mula merakam, tekan sekali lagi untuk berhenti dan transkripsi"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk én gang for å starte opptaket, trykk igjen for å stoppe og transkribere"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Druk één keer om de opname te starten, druk nogmaals om te stoppen en te transcriberen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij raz, aby rozpocząć nagrywanie, naciśnij ponownie, aby zatrzymać i dokonać transkrypcji"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione uma vez para iniciar a gravação, pressione novamente para parar e transcrever"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Apăsați o dată pentru a începe înregistrarea, apăsați din nou pentru a opri și a transcrie"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите один раз, чтобы начать запись, нажмите еще раз, чтобы остановить и расшифровать"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck en gång för att starta inspelningen, tryck igen för att stoppa och transkribera"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กดหนึ่งครั้งเพื่อเริ่มการบันทึก กดอีกครั้งเพื่อหยุดและถอดเสียง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydı başlatmak için bir kez basın, durdurmak ve metne dönüştürmek için tekrar basın"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Натисніть один раз, щоб почати запис, натисніть ще раз, щоб зупинити та розшифрувати"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn một lần để bắt đầu ghi, nhấn lần nữa để dừng và chép lại"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次開始錄製，再按一次停止並轉錄"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次开始录制，再按一次停止并转录"
          }
        }
      }
    },
