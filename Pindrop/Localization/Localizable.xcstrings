            "value": "Streaming-Transkription ist deaktiviert, während die KI-Verbesserung aktiviert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Streaming transcription is disabled while AI Enhancement is enabled."
          }
