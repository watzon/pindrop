    "choose_how_dictated_text_lands_then_tune_the_fin": {
      "comment": "choose_how_dictated_text_lands_then_tune_the_fin",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر كيفية وصول النص الذي تم إملاؤه، ثم قم بضبط سلوك الإدراج النهائي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "টেক্সট ল্যান্ড কিভাবে নির্দেশিত চয়ন করুন, তারপর চূড়ান্ত সন্নিবেশ আচরণ টিউন."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte, jak bude diktovaný text přistávat, a poté vylaďte konečné chování vkládání."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg, hvordan dikteret tekst lander, og juster derefter den endelige indsættelsesadfærd."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie, wie diktierter Text eingefügt wird, und passen Sie dann das endgültige Einfügeverhalten an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose how dictated text lands, then tune the final insertion behavior."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε τον τρόπο προσγείωσης του υπαγορευμένου κειμένου και, στη συνέχεια, συντονίστε την τελική συμπεριφορά εισαγωγής."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose how dictated text lands, then tune the final insertion behavior."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse sanelun tekstin saapumistapa ja säädä lopullinen lisäyskäyttäytyminen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez comment le texte dicté est inséré, puis réglez le comportement d'insertion final."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר כיצד נוחת הטקסט המוכתב ולאחר מכן כוונן את התנהגות ההוספה הסופית."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि निर्देशित पाठ किस प्रकार उतरेगा, फिर अंतिम प्रविष्टि व्यवहार को समायोजित करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válassza ki a diktált szöveg érkezési módját, majd hangolja be a végső beillesztési viselkedést."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih cara teks yang didiktekan mendarat, lalu sesuaikan perilaku penyisipan terakhir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli la modalità di destinazione del testo dettato, quindi ottimizza il comportamento di inserimento finale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "口述テキストの挿入方法を選択し、最終的な挿入動作を調整します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "받아쓰기 텍스트가 어떻게 전달되는지 선택한 다음 최종 삽입 동작을 조정하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih cara teks yang ditentukan tiba, kemudian sesuaikan gelagat sisipan akhir."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg hvordan diktert tekst lander, og juster deretter den endelige innsettingsatferden."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies hoe gedicteerde tekst terechtkomt en stem vervolgens het uiteindelijke invoeggedrag af."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz sposób wylądowania podyktowanego tekstu, a następnie dostosuj końcowe zachowanie podczas wstawiania."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha como o texto ditado será exibido e ajuste o comportamento de inserção final."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alegeți cum aterizează textul dictat, apoi reglați comportamentul final de inserare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, как будет располагаться продиктованный текст, а затем настройте окончательное поведение вставки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj hur dikterad text landar och ställ sedan in det slutliga infogningsbeteendet."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกวิธีการป้อนข้อความตามคำบอก จากนั้นปรับแต่งลักษณะการแทรกขั้นสุดท้าย"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dikte edilen metnin nasıl yerleştirileceğini seçin, ardından son ekleme davranışını ayarlayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть спосіб розміщення продиктованого тексту, а потім налаштуйте остаточну поведінку вставки."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn cách hiển thị văn bản chính tả, sau đó điều chỉnh hành vi chèn cuối cùng."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇聽寫文字的插入方式，然後調整最終插入行為。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择听写文本的插入方式，然后调整最终插入行为。"
          }
        }
      }
    },
    "choose_how_pindrop_follows_system_appearance_the": {
      "comment": "choose_how_pindrop_follows_system_appearance_the",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر كيفية اتباع Pindrop لمظهر النظام، ثم قم بمزج اللوحات الفاتحة والداكنة المنسقة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পিনড্রপ কীভাবে সিস্টেমের চেহারা অনুসরণ করে তা চয়ন করুন, তারপরে কিউরেটেড আলো এবং অন্ধকার প্যালেটগুলি মিশ্রিত করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte, jak Pindrop sleduje vzhled systému, a poté smíchejte upravené světlé a tmavé palety."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg, hvordan Pindrop følger systemets udseende, og bland derefter udvalgte lyse og mørke paletter."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie, wie Pindrop dem System-Erscheinungsbild folgt, und mischen Sie dann kuratierte helle und dunkle Paletten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose how Pindrop follows system appearance, then mix curated light and dark palettes."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε πώς το Pindrop ακολουθεί την εμφάνιση του συστήματος και, στη συνέχεια, συνδυάστε επιλεγμένες ανοιχτές και σκούρες παλέτες."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige cómo Pindrop sigue la apariencia del sistema, luego mezcla paletas claras y oscuras curadas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse, miten Pindrop seuraa järjestelmän ulkonäköä, ja sekoita sitten kuratoituja vaaleita ja tummia paletteja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez comment Pindrop suit l'apparence du système, puis mélangez les palettes claires et sombres sélectionnées."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר כיצד Pindrop עוקב אחר מראה המערכת, ולאחר מכן ערבב פלטות בהירות וכהות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि पिनड्रॉप सिस्टम स्वरूप का अनुसरण कैसे करता है, फिर क्यूरेटेड लाइट और डार्क पैलेट्स को मिलाएं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válassza ki, hogy a Pindrop hogyan kövesse a rendszer megjelenését, majd keverje össze a világos és sötét palettákat."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih bagaimana Pindrop mengikuti tampilan sistem, lalu gabungkan palet terang dan gelap yang dikurasi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli in che modo Pindrop segue l'aspetto del sistema, quindi mescola tavolozze chiare e scure selezionate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop がシステムの外観に従う方法を選択し、厳選された明るいパレットと暗いパレットを組み合わせます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 시스템 모양을 따르는 방식을 선택한 다음 엄선된 밝은 팔레트와 어두운 팔레트를 혼합합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih cara Pindrop mengikuti penampilan sistem, kemudian campurkan palet terang dan gelap yang dipilih susun."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg hvordan Pindrop følger systemets utseende, og bland deretter kurerte lyse og mørke paletter."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies hoe Pindrop het uiterlijk van het systeem volgt en meng vervolgens samengestelde lichte en donkere paletten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz sposób, w jaki Pindrop będzie podążał za wyglądem systemu, a następnie połącz wybrane jasne i ciemne palety."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha como o Pindrop segue a aparência do sistema e, em seguida, misture paletas claras e escuras selecionadas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alegeți modul în care Pindrop urmărește aspectul sistemului, apoi amestecați paletele luminoase și întunecate."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, как Pindrop соответствует внешнему виду системы, а затем смешайте выбранные светлые и темные палитры."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj hur Pindrop följer systemets utseende och blanda sedan utvalda ljusa och mörka paletter."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกวิธีที่ Pindrop ติดตามลักษณะที่ปรากฏของระบบ จากนั้นผสมพาเล็ตแสงและสีเข้มที่คัดสรรแล้ว"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'un sistem görünümünü nasıl takip edeceğini seçin, ardından seçilmiş açık ve koyu paletleri karıştırın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть, як Pindrop слідує зовнішньому вигляду системи, а потім змішайте підібрані світлі та темні палітри."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn cách Pindrop theo dõi giao diện của hệ thống, sau đó trộn các bảng màu sáng và tối được tuyển chọn."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇 Pindrop 如何跟隨系統外觀，然後混合精選的淺色和深色調色盤。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 Pindrop 如何跟随系统外观，然后混合精选的浅色和深色调色板。"
          }
        }
      }
    },
