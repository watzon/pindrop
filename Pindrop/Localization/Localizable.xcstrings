    "accessibility_permission_is_enabled_full_ui_cont": {
      "comment": "accessibility_permission_is_enabled_full_ui_cont",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تمكين إذن الوصول. سياق واجهة المستخدم الكامل متاح."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অ্যাক্সেসিবিলিটি অনুমতি সক্ষম করা হয়েছে। সম্পূর্ণ UI প্রসঙ্গ উপলব্ধ।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Je povoleno oprávnění k usnadnění. K dispozici je úplný kontext uživatelského rozhraní."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilgængelighedstilladelse er aktiveret. Fuld UI-kontekst er tilgængelig."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Bedienungshilfen-Berechtigung ist aktiviert. Vollständiger UI-Kontext verfügbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission is enabled. Full UI context is available."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η άδεια προσβασιμότητας είναι ενεργοποιημένη. Διατίθεται πλήρες περιβάλλον διεπαφής χρήστη."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El permiso de Accesibilidad está activado. El contexto completo de la interfaz está disponible."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Esteettömyysoikeus on käytössä. Koko käyttöliittymäkonteksti on saatavilla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'autorisation d'accessibilité est activée. Le contexte complet de l'interface est disponible."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הרשאת נגישות מופעלת. ההקשר המלא של ממשק המשתמש זמין."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभिगम्यता अनुमति सक्षम है. पूर्ण यूआई संदर्भ उपलब्ध है."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kisegítő lehetőségek engedélyezve vannak. A teljes felhasználói felület kontextus elérhető."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Izin aksesibilitas diaktifkan. Konteks UI lengkap tersedia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'autorizzazione di accessibilità è abilitata. È disponibile il contesto completo dell'interfaccia utente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティ権限が有効になっています。完全な UI コンテキストが利用可能です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "접근성 권한이 활성화되었습니다. 전체 UI 컨텍스트를 사용할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kebenaran kebolehaksesan didayakan. Konteks UI penuh tersedia."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilgjengelighetstillatelse er aktivert. Full UI-kontekst er tilgjengelig."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toegankelijkheidsrechten zijn ingeschakeld. Volledige UI-context is beschikbaar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uprawnienia dostępu są włączone. Dostępny jest pełny kontekst interfejsu użytkownika."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A permissão de acessibilidade está habilitada. O contexto completo da UI está disponível."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Permisiunea de accesibilitate este activată. Contextul UI complet este disponibil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешение на доступ включено. Доступен полный контекст пользовательского интерфейса."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillgänglighetsbehörighet är aktiverad. Fullständig UI-kontext är tillgänglig."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดใช้งานการอนุญาตการเข้าถึงแล้ว มีบริบท UI แบบเต็ม"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Erişilebilirlik izni etkin. Tam kullanıcı arayüzü bağlamı mevcuttur."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Дозвіл доступності ввімкнено. Доступний повний контекст інтерфейсу користувача."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quyền truy cập được bật. Bối cảnh giao diện người dùng đầy đủ có sẵn."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輔助功能許可權已啟用。完整的 UI 上下文可用。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能权限已启用。完整的 UI 上下文可用。"
          }
        }
      }
    },
    "accessibility_permission_is_not_granted_vibe_mod": {
      "comment": "accessibility_permission_is_not_granted_vibe_mod",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم منح إذن الوصول. يظل وضع Vibe غير محظور مع سياق محدود."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অ্যাক্সেসযোগ্যতার অনুমতি দেওয়া হয় না। Vibe মোড সীমিত প্রসঙ্গের সাথে অ-ব্লকিং রয়ে গেছে।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Oprávnění k usnadnění není uděleno. Vibe režim zůstává neblokující s omezeným kontextem."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilgængelighedstilladelse gives ikke. Vibe-tilstand forbliver ikke-blokerende med begrænset kontekst."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Bedienungshilfen-Berechtigung wurde nicht erteilt. Der Vibe-Modus bleibt nicht blockierend mit begrenztem Kontext."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission is not granted. Vibe mode remains non-blocking with limited context."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν χορηγείται άδεια προσβασιμότητας. Η λειτουργία Vibe παραμένει μη μπλοκαρισμένη με περιορισμένο περιβάλλον."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El permiso de Accesibilidad no está concedido. El modo vibe sigue siendo no bloqueante con contexto limitado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Esteettömyyslupaa ei myönnetä. Vibe-tila pysyy estävänä rajoitetussa kontekstissa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'autorisation d'accessibilité n'est pas accordée. Le mode vibe reste non bloquant avec un contexte limité."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הרשאת נגישות אינה ניתנת. מצב אווירה נשאר לא חוסם עם הקשר מוגבל."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभिगम्यता अनुमति नहीं दी गई है. वाइब मोड सीमित संदर्भ के साथ गैर-अवरुद्ध रहता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kisegítő lehetőségek nem engedélyezettek. A Vibe mód továbbra is nem blokkol, korlátozott környezettel."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Izin aksesibilitas tidak diberikan. Mode getar tetap non-pemblokiran dengan konteks terbatas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il permesso di accessibilità non è concesso. La modalità Vibe rimane non bloccante con un contesto limitato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティ権限が付与されていません。 Vibe モードは、制限されたコンテキストでノンブロッキングのままです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "접근성 권한이 부여되지 않았습니다. Vibe 모드는 제한된 상황에서 비차단 상태로 유지됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kebenaran kebolehaksesan tidak diberikan. Mod vibe kekal tidak menyekat dengan konteks terhad."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilgjengelighetstillatelse er ikke gitt. Vibe-modus forblir ikke-blokkerende med begrenset kontekst."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toegankelijkheidstoestemming wordt niet verleend. De Vibe-modus blijft niet-blokkerend met beperkte context."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pozwolenie na dostępność nie zostało przyznane. Tryb Vibe pozostaje nieblokujący w ograniczonym kontekście."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A permissão de acessibilidade não é concedida. O modo Vibe permanece sem bloqueio com contexto limitado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Permisiunea de accesibilitate nu este acordată. Modul Vibe rămâne neblocant cu context limitat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешение на доступ не предоставлено. Режим Vibe остается неблокирующим с ограниченным контекстом."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tillgänglighetstillstånd beviljas inte. Vibeläget förblir icke-blockerande med begränsad kontext."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่ได้รับอนุญาตการเข้าถึง โหมด Vibe ยังคงไม่ปิดกั้นโดยมีบริบทที่จำกัด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Erişilebilirlik izni verilmedi. Vibe modu, sınırlı bağlamla engellemesiz kalır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Дозвіл на доступність не надано. Режим Vibe залишається неблокуючим із обмеженим контекстом."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quyền truy cập không được cấp. Chế độ Vibe vẫn không bị chặn với bối cảnh hạn chế."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未授予輔助功能許可權。Vibe 模式保持非阻塞狀態，但上下文有限。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未授予辅助功能权限。Vibe 模式保持非阻塞状态，但上下文有限。"
          }
        }
      }
    },
