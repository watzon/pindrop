    "please_check_your_internet_connection_and_try_ag": {
      "comment": "please_check_your_internet_connection_and_try_ag",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى التحقق من اتصالك بالإنترنت والمحاولة مرة أخرى."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার ইন্টারনেট সংযোগ পরীক্ষা করুন এবং আবার চেষ্টা করুন."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zkontrolujte prosím připojení k internetu a zkuste to znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tjek venligst din internetforbindelse og prøv igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte überprüfen Sie Ihre Internetverbindung und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please check your internet connection and try again."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ελέγξτε τη σύνδεσή σας στο Διαδίκτυο και δοκιμάστε ξανά."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, comprueba tu conexión a internet e inténtalo de nuevo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarkista internetyhteytesi ja yritä uudelleen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez vérifier votre connexion internet et réessayer."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אנא בדוק את חיבור האינטרנט שלך ונסה שוב."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने इंटरनेट कनेक्शन की जाँच करें और पुन: प्रयास करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kérjük, ellenőrizze internetkapcsolatát, és próbálja újra."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Silakan periksa koneksi internet Anda dan coba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controlla la connessione Internet e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インターネット接続を確認して、もう一度試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인터넷 연결을 확인하고 다시 시도해 주세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sila semak sambungan internet anda dan cuba lagi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontroller Internett-tilkoblingen din og prøv igjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Controleer uw internetverbinding en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprawdź połączenie internetowe i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifique sua conexão com a Internet e tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Vă rugăm să vă verificați conexiunea la internet și să încercați din nou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пожалуйста, проверьте подключение к Интернету и повторите попытку."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrollera din internetanslutning och försök igen."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โปรดตรวจสอบการเชื่อมต่ออินเทอร์เน็ตของคุณแล้วลองอีกครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lütfen internet bağlantınızı kontrol edip tekrar deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перевірте підключення до Інтернетуnnі спробуйте ще раз."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vui lòng kiểm tra kết nối internet của bạn và thử lại."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請檢查您的網際網路連線，然後重試。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请检查您的互联网连接，然后重试。"
          }
        }
      }
    },
    "please_download_a_whisper_model_in_settings_befo": {
      "comment": "please_download_a_whisper_model_in_settings_befo",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى تنزيل نموذج Whisper في الإعدادات قبل التسجيل.\n\nانتقل إلى الإعدادات → النماذج لتنزيل نموذج."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রেকর্ড করার আগে সেটিংস থেকে একটি হুইস্পার মডেল ডাউনলোড করুন।\n\n\nএকটি মডেল ডাউনলোড করতে সেটিংস → মডেলগুলিতে যান৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Před nahráváním si prosím stáhněte model Whisper v Nastavení.\n\nPřejděte do Nastavení → Modely a stáhněte si model."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Download venligst en Whisper-model i Indstillinger før optagelse.\n\nGå til Indstillinger → Modeller for at downloade en model."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte laden Sie ein Whisper-Modell in den Einstellungen herunter, bevor Sie aufnehmen.\n\nGehen Sie zu Einstellungen → Modelle, um ein Modell herunterzuladen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please download a Whisper model in Settings before recording.\n\nGo to Settings → Models to download a model."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κάντε λήψη ενός μοντέλου Whisper στις Ρυθμίσεις πριν την εγγραφή.\n\nΜεταβείτε στις Ρυθμίσεις → Μοντέλα για λήψη ενός μοντέλου."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descarga un modelo de Whisper en Ajustes antes de grabar.\n\nVe a Ajustes → Modelos para descargar un modelo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lataa Whisper-malli asetuksista ennen tallennusta.\n\nLataa malli siirtymällä kohtaan Asetukset → Mallit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez télécharger un modèle Whisper dans les Paramètres avant d'enregistrer.\n\nAllez dans Paramètres → Modèles pour télécharger un modèle."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אנא הורד דגם Whisper בהגדרות לפני ההקלטה.\n\nעבור אל הגדרות ← דגמים כדי להוריד דגם."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कृपया रिकॉर्डिंग से पहले सेटिंग्स में व्हिस्पर मॉडल डाउनलोड करें।\n\nमॉडल डाउनलोड करने के लिए सेटिंग्स → मॉडल पर जाएं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Felvétel előtt töltsön le egy Whisper modellt a Beállításokban.\n\nA modell letöltéséhez lépjen a Beállítások → Modellek menüpontba."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Silakan unduh model Whisper di Pengaturan sebelum merekam.\n\nBuka Pengaturan → Model untuk mengunduh model."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scarica un modello Whisper in Impostazioni prima di registrare.\n\nVai su Impostazioni → Modelli per scaricare un modello."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音する前に、設定で Whisper モデルをダウンロードしてください。\n\n[設定] → [モデル] に移動してモデルをダウンロードします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
