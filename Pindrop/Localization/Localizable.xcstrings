    "keep_pindrop_current_automatically_or_trigger_a": {
      "comment": "keep_pindrop_current_automatically_or_trigger_a",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حافظ على تحديث Pindrop تلقائيًا، أو قم بإجراء فحص يدوي وقتما تشاء."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop কে স্বয়ংক্রিয়ভাবে বর্তমান রাখুন, অথবা আপনি যখনই চান একটি ম্যানুয়াল চেক ট্রিগার করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Udržujte Pindrop aktuální automaticky nebo spusťte ruční kontrolu, kdykoli budete chtít."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold Pindrop aktuel automatisk, eller udløs en manuel kontrol, når du vil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halten Sie Pindrop automatisch aktuell oder lösen Sie eine manuelle Prüfung aus, wann immer Sie möchten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep Pindrop current automatically, or trigger a manual check whenever you want."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διατηρήστε το Pindrop τρέχον αυτόματα ή ενεργοποιήστε έναν μη αυτόματο έλεγχο όποτε θέλετε."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén Pindrop actualizado automáticamente, o activa una búsqueda manual cuando quieras."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidä Pindrop ajan tasalla automaattisesti tai käynnistä manuaalinen tarkistus milloin haluat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez Pindrop à jour automatiquement, ou déclenchez une vérification manuelle quand vous voulez."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שמור על עדכניות של Pindrop באופן אוטומטי, או הפעל בדיקה ידנית מתי שתרצה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिनड्रॉप को स्वचालित रूप से चालू रखें, या जब चाहें मैन्युअल जांच चालू करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tartsa Pindrop automatikusan aktuális, vagy indítson el egy kézi ellenőrzést, amikor csak akarja."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pertahankan Pindrop terkini secara otomatis, atau picu pemeriksaan manual kapan pun Anda mau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantieni Pindrop aggiornato automaticamente o attiva un controllo manuale quando vuoi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop を自動的に最新の状態に保つことも、必要に応じていつでも手動チェックをトリガーすることもできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop을 자동으로 최신 상태로 유지하거나 원할 때마다 수동 검사를 실행하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pastikan Pindrop semasa secara automatik, atau cetuskan semakan manual pada bila-bila masa anda mahu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold Pindrop oppdatert automatisk, eller utløs en manuell sjekk når du vil."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd Pindrop automatisch actueel of activeer een handmatige controle wanneer u maar wilt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatycznie aktualizuj Pindrop lub uruchamiaj ręczne sprawdzanie, kiedy tylko chcesz."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha o Pindrop atualizado automaticamente ou acione uma verificação manual sempre que desejar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Păstrați curentul Pindrop în mod automat sau declanșați o verificare manuală oricând doriți."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поддерживайте актуальность Pindrop автоматически или запускайте ручную проверку, когда захотите."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll Pindrop aktuell automatiskt eller utlös en manuell kontroll när du vill."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รักษา Pindrop ให้เป็นปัจจุบันโดยอัตโนมัติ หรือเรียกใช้การตรวจสอบด้วยตนเองทุกครั้งที่คุณต้องการ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop'u otomatik olarak güncel tutun veya istediğiniz zaman manuel kontrolü tetikleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматично підтримуйте Pindrop актуальним або запустіть перевірку вручну, коли забажаєте."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tự động cập nhật Pindrop hoặc kích hoạt kiểm tra thủ công bất cứ khi nào bạn muốn."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動保持 Pindrop 最新，或隨時觸發手動檢查。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动保持 Pindrop 最新，或随时触发手动检查。"
          }
        }
      }
    },
