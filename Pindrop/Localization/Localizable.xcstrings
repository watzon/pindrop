    "sent_to_the_ai_model_when_processing_dictation_f": {
      "comment": "sent_to_the_ai_model_when_processing_dictation_f",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم إرساله إلى نموذج الذكاء الاصطناعي عند معالجة الإملاء لإدراج النص المباشر."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সরাসরি টেক্সট সন্নিবেশের জন্য শ্রুতিলিপি প্রক্রিয়া করার সময় AI মডেলে পাঠানো হয়।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odesláno do modelu AI při zpracování diktátu pro přímé vložení textu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendes til AI-modellen ved behandling af diktat til direkte tekstindsættelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird an das KI-Modell gesendet, wenn die Diktierung für die direkte Texteingabe verarbeitet wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sent to the AI model when processing dictation for direct text insertion."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αποστέλλεται στο μοντέλο AI κατά την επεξεργασία υπαγόρευσης για άμεση εισαγωγή κειμένου."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se envía al modelo de IA al procesar el dictado para inserción directa de texto."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lähetetään tekoälymalliin, kun käsitellään sanelua suoraa tekstin lisäystä varten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyé au modèle IA lors du traitement de la dictée pour l'insertion directe de texte."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נשלח למודל AI בעת עיבוד הכתבה להכנסת טקסט ישירה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रत्यक्ष पाठ प्रविष्टि के लिए श्रुतलेख संसाधित करते समय एआई मॉडल पर भेजा गया।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Elküldve az AI-modellnek a diktálás feldolgozása során a közvetlen szövegbeillesztéshez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dikirim ke model AI saat memproses dikte untuk penyisipan teks langsung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inviato al modello AI durante l'elaborazione della dettatura per l'inserimento diretto del testo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テキストを直接挿入するためのディクテーションを処理するときに AI モデルに送信されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "직접 텍스트 삽입을 위한 받아쓰기 처리 시 AI 모델로 전송됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dihantar kepada model AI semasa memproses imlak untuk sisipan teks langsung."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendes til AI-modellen ved behandling av diktat for direkte tekstinnsetting."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verzonden naar het AI-model bij het verwerken van dictaat voor directe tekstinvoeging."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyłane do modelu AI podczas przetwarzania dyktowania w celu bezpośredniego wstawienia tekstu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviado ao modelo de IA ao processar o ditado para inserção direta de texto."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Trimis la modelul AI atunci când procesează dictarea pentru inserarea directă a textului."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляется в модель ИИ при обработке диктовки для прямой вставки текста."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
