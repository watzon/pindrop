    "%@ is assigned to both %@ and %@. Only the first action will be active. Update your hotkeys in Settings to resolve this conflict.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ist sowohl %@ als auch %@ zugewiesen. Nur die erste Aktion wird aktiv sein. Aktualisieren Sie Ihre Tastenkürzel in den Einstellungen, um diesen Konflikt zu lösen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is assigned to both %@ and %@. Only the first action will be active. Update your hotkeys in Settings to resolve this conflict."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ está asignado tanto a %@ como a %@. Solo la primera acción estará activa. Actualiza tus atajos en Ajustes para resolver este conflicto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ est assigné à la fois à %@ et %@. Seule la première action sera active. Mettez à jour vos raccourcis dans les Paramètres pour résoudre ce conflit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ è assegnato sia a %@ che a %@. Sarà attiva solo la prima azione. Aggiorna i tasti di scelta rapida in Impostazioni per risolvere questo conflitto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ は %@ と %@ の両方に割り当てられます。最初のアクションのみがアクティブになります。この競合を解決するには、設定でホットキーを更新してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@는 %@ 및 %@ 모두에 할당됩니다. 첫 번째 작업만 활성화됩니다. 이 충돌을 해결하려면 설정에서 단축키를 업데이트하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is toegewezen aan zowel %@ als %@. Alleen de eerste actie is actief. Update uw sneltoetsen in Instellingen om dit conflict op te lossen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ é atribuído a %@ e %@. Apenas a primeira ação estará ativa. Atualize suas teclas de atalho em Configurações para resolver este conflito."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 同时分配给 %@ 和 %@。只有第一个操作将处于活动状态。在设置中更新您的快捷键以解决此冲突。"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@, hem %@ hem de %@'ye atanır. Yalnızca ilk eylem etkin olacaktır. Bu çakışmayı çözmek için Ayarlar'da kısayol tuşlarınızı güncelleyin."
          }
        }
      }
    },
