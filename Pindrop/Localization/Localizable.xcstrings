    "lm_studio_only_needs_a_token_if_local_server_aut": {
      "comment": "lm_studio_only_needs_a_token_if_local_server_aut",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج LM Studio إلى رمز مميز فقط إذا تم تمكين مصادقة الخادم المحلي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "LM স্টুডিও শুধুমাত্র একটি টোকেন প্রয়োজন যদি স্থানীয় সার্ভার প্রমাণীকরণ সক্ষম করা থাকে।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio potřebuje token pouze v případě, že je povoleno ověřování místního serveru."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio behøver kun et token, hvis lokal servergodkendelse er aktiveret."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio benötigt nur ein Token, wenn die lokale Serverauthentifizierung aktiviert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio only needs a token if local server authentication is enabled."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το LM Studio χρειάζεται ένα διακριτικό μόνο εάν είναι ενεργοποιημένος ο έλεγχος ταυτότητας τοπικού διακομιστή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio only needs a token if local server authentication is enabled."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio tarvitsee tunnuksen vain, jos paikallisen palvelimen todennus on käytössä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio n'a besoin d'un jeton que si l'authentification du serveur local est activée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio צריך אסימון רק אם אימות שרת מקומי מופעל."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय सर्वर प्रमाणीकरण सक्षम होने पर एलएम स्टूडियो को केवल टोकन की आवश्यकता होती है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az LM Studionak csak akkor van szüksége tokenre, ha a helyi szerver hitelesítés engedélyezve van."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio hanya memerlukan token jika otentikasi server lokal diaktifkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio necessita di un token solo se è abilitata l'autenticazione del server locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio は、ローカルサーバー認証が有効になっている場合にのみトークンを必要とします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio에는 로컬 서버 인증이 활성화된 경우에만 토큰이 필요합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio hanya memerlukan token jika pengesahan pelayan setempat didayakan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio trenger bare et token hvis lokal serverautentisering er aktivert."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio heeft alleen een token nodig als lokale serverauthenticatie is ingeschakeld."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio potrzebuje tokena tylko wtedy, gdy włączone jest uwierzytelnianie serwera lokalnego."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O LM Studio só precisa de um token se a autenticação do servidor local estiver habilitada."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio are nevoie de un token doar dacă autentificarea locală a serverului este activată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio нужен токен только в том случае, если включена аутентификация локального сервера."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio behöver bara en token om lokal serverautentisering är aktiverad."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio ต้องการโทเค็นเท่านั้นหากเปิดใช้งานการรับรองความถูกต้องของเซิร์ฟเวอร์ภายในเครื่อง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio'nun yalnızca yerel sunucu kimlik doğrulaması etkinse bir belirtece ihtiyacı vardır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio потрібен лише маркер, якщо ввімкнено автентифікацію локального сервера."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio chỉ cần mã thông báo nếu xác thực máy chủ cục bộ được bật."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio 僅在啟用本地伺服器身份驗證時才需要令牌。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "LM Studio 仅在启用本地服务器身份验证时才需要令牌。"
          }
        }
      }
    },
