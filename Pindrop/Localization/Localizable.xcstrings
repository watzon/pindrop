          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parakeet (birden fazla sürümle uyumlu, indirilen model) ile Apple SpeechTranscriber (macOS 26+, işletim sistemiyle birlikte gelir) arasında seçim yapın."
          }
        },
        "uk": {
          "stringUnit": {
