    "temporarily_copy_text_paste_it_then_restore_your": {
      "comment": "temporarily_copy_text_paste_it_then_restore_your",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انسخ النص مؤقتًا، والصقه، ثم قم باستعادة الحافظة الخاصة بك"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সাময়িকভাবে টেক্সট কপি করুন, পেস্ট করুন, তারপর আপনার ক্লিপবোর্ড পুনরুদ্ধার করুন"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dočasně zkopírujte text, vložte jej a poté obnovte schránku"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopier tekst midlertidigt, indsæt den, og gendan derefter dit udklipsholder"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopieren Sie vorübergehend Text, fügen Sie ihn ein, dann stellen Sie Ihre Zwischenablage wieder her"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Temporarily copy text, paste it, then restore your clipboard"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αντιγράψτε προσωρινά το κείμενο, επικολλήστε το και, στη συνέχεια, επαναφέρετε το πρόχειρό σας"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Temporalmente copia el texto, pégalo, luego restaura tu portapapeles"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopioi teksti väliaikaisesti, liitä se ja palauta sitten leikepöytä"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiez temporairement du texte, collez-le, puis restaurez votre presse-papiers"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "העתק טקסט באופן זמני, הדבק אותו ואז שחזר את הלוח שלך"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टेक्स्ट को अस्थायी रूप से कॉपी करें, पेस्ट करें, फिर अपना क्लिपबोर्ड पुनर्स्थापित करें"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ideiglenesen másolja ki a szöveget, illessze be, majd állítsa vissza a vágólapot"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Salin teks untuk sementara, tempel, lalu pulihkan clipboard Anda"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Copia temporaneamente il testo, incollalo, quindi ripristina gli appunti"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テキストを一時的にコピーして貼り付け、クリップボードを復元します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "임시로 텍스트를 복사하여 붙여넣은 다음 클립보드를 복원하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Salin teks buat sementara waktu, tampalkannya, kemudian pulihkan papan keratan anda"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopier tekst midlertidig, lim den inn, og gjenopprett deretter utklippstavlen"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopieer tijdelijk tekst, plak deze en herstel vervolgens uw klembord"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tymczasowo skopiuj tekst, wklej go, a następnie przywróć schowek"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copie o texto temporariamente, cole-o e restaure a área de transferência"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiați temporar textul, lipiți-l, apoi restaurați-vă clipboardul"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Временно скопируйте текст, вставьте его, а затем восстановите буфер обмена."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kopiera text tillfälligt, klistra in den och återställ sedan ditt urklipp"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คัดลอกข้อความชั่วคราว วาง จากนั้นกู้คืนคลิปบอร์ดของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Metni geçici olarak kopyalayın, yapıştırın ve ardından panonuzu geri yükleyin"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тимчасово скопіюйте текст, вставте його, а потім відновіть буфер обміну"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tạm thời sao chép văn bản, dán nó, sau đó khôi phục bảng nhớ tạm của bạn"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "臨時複製文字，貼上它，然後恢復您的剪貼簿"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "临时复制文本，粘贴它，然后恢复您的剪贴板"
          }
        }
      }
    },
    "temporarily_mute_speaker_output_while_dictation": {
      "comment": "temporarily_mute_speaker_output_while_dictation",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كتم صوت مكبر الصوت مؤقتًا أثناء تسجيل الإملاء."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "শ্রুতিমধুর রেকর্ড করার সময় অস্থায়ীভাবে স্পীকার আউটপুট নিঃশব্দ করুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Během nahrávání diktátu dočasně ztlumte výstup reproduktoru."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Slå højttalerudgangen midlertidigt fra, mens diktering optages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalten Sie die Lautsprecherausgabe vorübergehend stumm, während die Diktierung aufgenommen wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Temporarily mute speaker output while dictation is recording."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσωρινή σίγαση της εξόδου των ηχείων κατά την εγγραφή της υπαγόρευσης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencia temporalmente la salida del altavoz mientras se graba el dictado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mykistä tilapäisesti kaiuttimen lähtö sanelun tallennuksen aikana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Coupez temporairement la sortie des haut-parleurs pendant que la dictée est enregistrée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השתקה זמנית של פלט הרמקול בזמן ההקלטה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "श्रुतलेख रिकॉर्ड करते समय स्पीकर आउटपुट को अस्थायी रूप से म्यूट करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hangszórókimenet ideiglenes némítása diktálás közben."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menonaktifkan sementara output speaker saat dikte sedang direkam."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattiva temporaneamente l'uscita dell'altoparlante durante la registrazione della dettatura."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディクテーションの録音中にスピーカー出力を一時的にミュートします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "받아쓰기가 녹음되는 동안 일시적으로 스피커 출력을 음소거합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Redamkan output pembesar suara buat sementara waktu semasa imlak sedang dirakam."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Demp høyttalerutgangen midlertidig mens diktering pågår."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Demp tijdelijk de luidsprekeruitvoer terwijl het dictaat wordt opgenomen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tymczasowo wycisz dźwięk głośnika podczas nagrywania dyktowania."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencie temporariamente a saída do alto-falante durante a gravação do ditado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dezactivați temporar ieșirea difuzorului în timp ce se înregistrează dictarea."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Временно отключите звук динамика во время записи диктовки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Stäng av högtalarutgången tillfälligt medan diktering pågår."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปิดเสียงเอาต์พุตของลำโพงชั่วคราวในขณะที่กำลังบันทึกการเขียนตามคำบอก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dikte kaydı sırasında hoparlör çıkışını geçici olarak sessize alın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тимчасово вимкнути звук динаміка під час запису диктування."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tạm thời tắt tiếng đầu ra của loa trong khi đang ghi chính tả."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在聽寫錄製期間暫時靜音揚聲器輸出。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在听写录制期间暂时静音扬声器输出。"
          }
        }
      }
    },
    "temporarily_pause_active_media_playback_while_di": {
      "comment": "temporarily_pause_active_media_playback_while_di",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بإيقاف تشغيل الوسائط النشطة مؤقتًا أثناء تسجيل الإملاء."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ডিক্টেশন রেকর্ডিং করার সময় সক্রিয় মিডিয়া প্লেব্যাক সাময়িকভাবে বিরাম দিন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dočasně pozastavit aktivní přehrávání médií během nahrávání diktátu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sæt aktiv medieafspilning midlertidigt på pause, mens diktering optages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausieren Sie vorübergehend die aktive Medienwiedergabe, während die Diktierung aufgenommen wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Temporarily pause active media playback while dictation is recording."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διακόψτε προσωρινά την ενεργή αναπαραγωγή πολυμέσων κατά την εγγραφή της υπαγόρευσης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausa temporalmente la reproducción de medios mientras se graba el dictado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Keskeytä aktiivisen median toisto väliaikaisesti sanelun tallennuksen aikana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettez temporairement en pause la lecture de médias active pendant que la dictée est enregistrée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השהה זמנית את השמעת מדיה פעילה בזמן ההקלטה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "श्रुतलेख रिकॉर्ड करते समय सक्रिय मीडिया प्लेबैक को अस्थायी रूप से रोकें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Átmenetileg szünetelteti az aktív médialejátszást diktálás közben."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeda sementara pemutaran media aktif saat dikte sedang direkam."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettere temporaneamente in pausa la riproduzione multimediale attiva durante la registrazione della dettatura."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディクテーションの録音中にアクティブなメディアの再生を一時停止します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "받아쓰기가 녹음되는 동안 활성 미디어 재생을 일시적으로 일시 중지합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeda main balik media aktif buat sementara waktu semasa imlak sedang dirakam."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sett aktiv medieavspilling midlertidig på pause mens diktering pågår."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pauzeer tijdelijk het actieve afspelen van media terwijl het dictaat wordt opgenomen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tymczasowo wstrzymuj aktywne odtwarzanie multimediów podczas nagrywania dyktowania."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pause temporariamente a reprodução de mídia ativa enquanto o ditado está sendo gravado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Întrerupeți temporar redarea media activă în timp ce se înregistrează dictarea."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Временно приостановите воспроизведение активного мультимедиа во время записи диктовки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausa aktiv mediauppspelning tillfälligt medan diktering spelas in."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หยุดการเล่นสื่อที่ใช้งานชั่วคราวชั่วคราวในขณะที่กำลังบันทึกการเขียนตามคำบอก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dikte kaydı sırasında aktif medya oynatmayı geçici olarak duraklatın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тимчасово призупинити активне відтворення медіа під час запису диктування."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tạm dừng phát lại phương tiện đang hoạt động trong khi đang ghi chính tả."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在聽寫錄製期間暫時暫停活動的媒體播放。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在听写录制期间暂时暂停活动的媒体播放。"
          }
        }
      }
    },
