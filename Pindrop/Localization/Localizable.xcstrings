          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til orderstatninger for å automatisk korrigere vanlige transkripsjonsfeil."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg woordvervangingen toe om veelvoorkomende transcriptiefouten automatisch te corrigeren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj zamienniki słów, aby automatycznie poprawiać typowe błędy w transkrypcji."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione substituições de palavras para corrigir automaticamente erros comuns de transcrição."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Adăugați înlocuiri de cuvinte pentru a corecta automat erorile comune de transcriere."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляйте замены слов, чтобы автоматически исправлять распространенные ошибки транскрипции."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till ordersättningar för att automatiskt korrigera vanliga transkriptionsfel."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่มการแทนที่คำเพื่อแก้ไขข้อผิดพลาดในการถอดเสียงทั่วไปโดยอัตโนมัติ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sık karşılaşılan transkripsiyon hatalarını otomatik olarak düzeltmek için sözcük değiştirmeleri ekleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додайте заміни слів для автоматичного виправлення типових помилок транскрипції."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm từ thay thế để tự động sửa các lỗi phiên âm phổ biến."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增詞彙替換以自動糾正常見的轉錄錯誤。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加词汇替换以自动纠正常见的转录错误。"
          }
        }
      }
    },
    "add_words_to_help_pindrop_recognize_them_properl": {
      "comment": "add_words_to_help_pindrop_recognize_them_properl",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف كلمات لمساعدة Pindrop في التعرف عليها بشكل صحيح"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop তাদের সঠিকভাবে চিনতে সাহায্য করার জন্য শব্দ যোগ করুন"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidejte slova, abyste je Pindrop mohli správně rozpoznat"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilføj ord for at hjælpe Pindrop med at genkende dem korrekt"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie Wörter hinzu, um Pindrop zu helfen, sie korrekt zu erkennen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add words to help Pindrop recognize them properly"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε λέξεις για να βοηθήσετε τον Pindrop να τις αναγνωρίσει σωστά"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Add words to help Pindrop recognize them properly"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisää sanoja auttaaksesi Pindropia tunnistamaan ne oikein"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des mots pour aider Pindrop à les reconnaître correctement"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הוסף מילים כדי לעזור לפינדרופ לזהות אותן כראוי"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिनड्रॉप को उन्हें ठीक से पहचानने में मदद करने के लिए शब्द जोड़ें"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjon hozzá szavakat, hogy segítsen Pindrop helyesen felismerni őket"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan kata-kata untuk membantu Pindrop mengenalinya dengan benar"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi parole per aiutare Pindrop a riconoscerle correttamente"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop が正しく認識できるように単語を追加します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindrop이 올바르게 인식할 수 있도록 단어를 추가하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan perkataan untuk membantu Pindrop mengenalinya dengan betul"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til ord for å hjelpe Pindrop å gjenkjenne dem riktig"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg woorden toe zodat Pindrop ze goed kan herkennen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj słowa, aby Pindrop mógł je poprawnie rozpoznać"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione palavras para ajudar o Pindrop a reconhecê-las corretamente"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Adăugați cuvinte pentru a ajuta Pindrop să le recunoască corect"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляйте слова, чтобы Pindrop правильно их распознавал."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till ord för att hjälpa Pindrop att känna igen dem ordentligt"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่มคำเพื่อช่วยให้ Pindrop จดจำได้อย่างถูกต้อง"
          }
        },
        "tr": {
          "stringUnit": {
