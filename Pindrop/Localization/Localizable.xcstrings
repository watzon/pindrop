    "local_speech_to_text_right_from_your_menu_bar_fa": {
      "comment": "local_speech_to_text_right_from_your_menu_bar_fa",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحويل الكلام المحلي إلى نص، مباشرة من شريط القائمة.\nسريع وخاص ومتاح دائمًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার মেনু বার থেকে স্থানীয় স্পিচ-টু-টেক্সট।\n\nদ্রুত, ব্যক্তিগত, এবং সর্বদা উপলব্ধ।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Místní převod řeči na text přímo z panelu nabídek.\nRychlé, soukromé a vždy dostupné."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokal tale-til-tekst, direkte fra din menulinje.\nHurtig, privat og altid tilgængelig."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokale Spracherkennung direkt aus Ihrer Menüleiste.\nSchnell, privat und immer verfügbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local speech-to-text, right from your menu bar.\nFast, private, and always available."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τοπική ομιλία σε κείμενο, απευθείας από τη γραμμή μενού σας.\nΓρήγορη, ιδιωτική και πάντα διαθέσιμη."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Voz a texto local, directamente desde tu barra de menús.\nRápido, privado y siempre disponible."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Paikallinen puhe tekstiksi, suoraan valikkopalkistasi.\nNopea, yksityinen ja aina saatavilla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reconnaissance vocale locale, directement depuis votre barre de menus.\nRapide, privé et toujours disponible."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "דיבור מקומי לטקסט, ישירות משורת התפריטים שלך.\nמהיר, פרטי וזמין תמיד."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय वाक्-से-पाठ, सीधे आपके मेनू बार से।\nतेज़, निजी और हमेशा उपलब्ध।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Helyi beszéd-szöveg, közvetlenül a menüsorból.\nGyors, privát és mindig elérhető."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ucapan lokal-ke-teks, langsung dari bilah menu Anda.\nCepat, pribadi, dan selalu tersedia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sintesi vocale locale, direttamente dalla barra dei menu.\nVeloce, riservato e sempre disponibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルの音声テキスト変換をメニュー バーから直接実行できます。\n高速、プライベート、いつでも利用可能。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메뉴 표시줄에서 바로 로컬 음성을 텍스트로 변환하세요.\n빠르고, 비공개이며, 항상 사용 가능합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pertuturan ke teks setempat, terus dari bar menu anda.\nCepat, peribadi dan sentiasa tersedia."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokal tale-til-tekst, rett fra menylinjen.\nRask, privat og alltid tilgjengelig."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokale spraak-naar-tekst, rechtstreeks vanuit uw menubalk.\nSnel, privé en altijd beschikbaar."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokalna zamiana mowy na tekst bezpośrednio z paska menu.\nSzybki, prywatny i zawsze dostępny."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conversão local de fala para texto, diretamente na barra de menu.\nRápido, privado e sempre disponível."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Conversie vocală locală în text, direct din bara de meniu.\nRapid, privat și întotdeauna disponibil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локальное преобразование речи в текст прямо из строки меню.\nБыстро, конфиденциально и всегда доступно."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokalt tal-till-text, direkt från din menyrad.\nSnabbt, privat och alltid tillgängligt."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เสียงพูดเป็นข้อความท้องถิ่นจากแถบเมนูของคุณ\nรวดเร็ว เป็นส่วนตัว และพร้อมให้บริการตลอดเวลา"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğrudan menü çubuğunuzdan yerel konuşmayı metne dönüştürme.\nHızlı, özel ve her zaman ulaşılabilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Місцеве перетворення мовлення в текст прямо з панелі меню.\nШвидко, приватно та завжди доступно."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chuyển lời nói thành văn bản cục bộ, ngay từ thanh menu của bạn.\nNhanh chóng, riêng tư và luôn có sẵn."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "直接從選單欄進行本地語音轉文字。\n快速、私密且始終可用。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直接从菜单栏进行本地语音转文本。\n快速、私密且始终可用。"
          }
        }
      }
    },
