    "configure_ai_providers_and_credentials_apple_int": {
      "comment": "configure_ai_providers_and_credentials_apple_int",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتكوين موفري الذكاء الاصطناعي وبيانات الاعتماد. تعمل خدمة Apple Intelligence على الجهاز؛ ويتطلب مقدمو الخدمة الآخرون مفاتيح واجهة برمجة التطبيقات (API)."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "AI প্রদানকারী এবং শংসাপত্র কনফিগার করুন। অ্যাপল ইন্টেলিজেন্স ডিভাইসে চলে; অন্যান্য প্রদানকারীদের API কী প্রয়োজন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nakonfigurujte poskytovatele AI a přihlašovací údaje. Apple Intelligence běží na zařízení; ostatní poskytovatelé vyžadují klíče API."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurer AI-udbydere og legitimationsoplysninger. Apple Intelligence kører på enheden; andre udbydere kræver API-nøgler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurieren Sie KI-Anbieter und Anmeldeinformationen. Apple Intelligence läuft auf dem Gerät; andere Anbieter benötigen API-Schlüssel."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure AI providers and credentials. Apple Intelligence runs on-device; other providers require API keys."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαμόρφωση παρόχων και διαπιστευτηρίων τεχνητής νοημοσύνης. Το Apple Intelligence εκτελείται στη συσκευή. άλλοι πάροχοι απαιτούν κλειδιά API."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure proveedores y credenciales de IA. Apple Intelligence se ejecuta en el dispositivo; otros proveedores requieren claves API."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Määritä AI-palveluntarjoajat ja tunnistetiedot. Apple Intelligence toimii laitteessa; muut palveluntarjoajat vaativat API-avaimia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurez les fournisseurs d’IA et les informations d’identification. Apple Intelligence s'exécute sur l'appareil ; d'autres fournisseurs exigent des clés API."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הגדר ספקי AI ואישורים. Apple Intelligence פועל במכשיר; ספקים אחרים דורשים מפתחות API."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एआई प्रदाताओं और क्रेडेंशियल्स को कॉन्फ़िगर करें। Apple इंटेलिजेंस डिवाइस पर चलता है; अन्य प्रदाताओं को एपीआई कुंजियों की आवश्यकता होती है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurálja az AI-szolgáltatókat és a hitelesítési adatokat. Az Apple Intelligence az eszközön fut; más szolgáltatók API-kulcsokat igényelnek."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurasikan penyedia dan kredensial AI. Apple Intelligence berjalan di perangkat; penyedia lain memerlukan kunci API."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura i provider e le credenziali di intelligenza artificiale. Apple Intelligence viene eseguita sul dispositivo; altri fornitori richiedono chiavi API."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AI プロバイダーと資格情報を構成します。 Apple Intelligence はデバイス上で実行されます。他のプロバイダーには API キーが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 공급자 및 자격 증명을 구성합니다. Apple Intelligence는 기기 내에서 실행됩니다. 다른 제공업체에는 API 키가 필요합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurasikan pembekal dan kelayakan AI. Perisikan Apple berjalan pada peranti; pembekal lain memerlukan kunci API."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurer AI-leverandører og legitimasjon. Apple Intelligence kjører på enheten; andre leverandører krever API-nøkler."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Configureer AI-providers en inloggegevens. Apple Intelligence draait op het apparaat; andere providers hebben API-sleutels nodig."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skonfiguruj dostawców AI i poświadczenia. Apple Intelligence działa na urządzeniu; inni dostawcy wymagają kluczy API."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure provedores e credenciais de IA. O Apple Intelligence é executado no dispositivo; outros provedores exigem chaves de API."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurați furnizorii și acreditările AI. Apple Intelligence rulează pe dispozitiv; alți furnizori necesită chei API."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте поставщиков ИИ и учетные данные. Apple Intelligence работает на устройстве; другим поставщикам требуются ключи API."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurera AI-leverantörer och autentiseringsuppgifter. Apple Intelligence körs på enheten; andra leverantörer kräver API-nycklar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กำหนดค่าผู้ให้บริการ AI และข้อมูลประจำตัว Apple Intelligence ทำงานบนอุปกรณ์ ผู้ให้บริการรายอื่นต้องการคีย์ API"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapay zeka sağlayıcılarını ve kimlik bilgilerini yapılandırın. Apple Intelligence cihazda çalışır; diğer sağlayıcılar API anahtarlarına ihtiyaç duyar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштуйте постачальників AI та облікові дані. Apple Intelligence працює на пристрої; іншим постачальникам потрібні ключі API."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Định cấu hình nhà cung cấp và thông tin xác thực AI. Apple Intelligence chạy trên thiết bị; các nhà cung cấp khác yêu cầu khóa API."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "配置 AI 提供商和憑據。Apple Intelligence 在裝置上執行；其他提供商需要 API 金鑰。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配置 AI 提供商和凭据。Apple Intelligence 在设备上运行；其他提供商需要 API 密钥。"
          }
        }
      }
    },
