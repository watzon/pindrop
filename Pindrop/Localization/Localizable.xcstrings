    "this_will_clear_all_your_settings_including_api": {
      "comment": "this_will_clear_all_your_settings_including_api",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى مسح جميع إعداداتك، بما في ذلك مفاتيح API ومفاتيح التشغيل السريع وتفضيلات الطراز. سيتم إنهاء التطبيق وسيظهر الإعداد مرة أخرى عند الإطلاق التالي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি API কী, হটকি এবং মডেল পছন্দগুলি সহ আপনার সমস্ত সেটিংস সাফ করবে৷ অ্যাপটি প্রস্থান করবে এবং পরবর্তী লঞ্চে আবার অনবোর্ডিং দেখাবে।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tím vymažete všechna vaše nastavení, včetně klíčů API, klávesových zkratek a předvoleb modelu. Aplikace se ukončí a při příštím spuštění se znovu zobrazí."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil rydde alle dine indstillinger, inklusive API-nøgler, genvejstaster og modelpræferencer. Appen afsluttes og viser onboarding igen ved næste lancering."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht alle Ihre Einstellungen, einschließlich API-Schlüssel, Tastenkürzel und Modellpräferenzen. Die App wird beendet und beim nächsten Start erneut das Onboarding anzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will clear all your settings, including API keys, hotkeys, and model preferences. The app will quit and show onboarding again on next launch."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό θα διαγράψει όλες τις ρυθμίσεις σας, συμπεριλαμβανομένων των κλειδιών API, των πλήκτρων πρόσβασης και των προτιμήσεων μοντέλου. Η εφαρμογή θα τερματιστεί και θα εμφανιστεί ξανά η ενσωμάτωση στην επόμενη κυκλοφορία."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borrará todos tus ajustes, incluyendo claves API, atajos y preferencias de modelo. La app se cerrará y mostrará el onboarding al siguiente inicio."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä tyhjentää kaikki asetuksesi, mukaan lukien API-avaimet, pikanäppäimet ja malliasetukset. Sovellus sulkeutuu ja näyttää uudelleen käyttöönoton seuraavan käynnistyksen yhteydessä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela effacera tous vos paramètres, y compris les clés API, les raccourcis et les préférences de modèle. L'app se fermera et affichera à nouveau l'intégration au prochain lancement."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "פעולה זו תנקה את כל ההגדרות שלך, כולל מפתחות API, מקשי קיצור והעדפות דגם. האפליקציה תסגר ותציג את ההטמעה שוב בהשקה הבאה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे एपीआई कुंजी, हॉटकी और मॉडल प्राथमिकताओं सहित आपकी सभी सेटिंग्स साफ़ हो जाएंगी। ऐप बंद हो जाएगा और अगले लॉन्च पर फिर से ऑनबोर्डिंग दिखाएगा।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezzel törli az összes beállítást, beleértve az API-kulcsokat, gyorsbillentyűket és a modellbeállításokat. Az alkalmazás kilép, és a következő indításkor ismét megjelenik a bekapcsolódás."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan menghapus semua pengaturan Anda, termasuk kunci API, tombol pintas, dan preferensi model. Aplikasi akan berhenti dan menampilkan orientasi lagi pada peluncuran berikutnya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciò cancellerà tutte le tue impostazioni, comprese le chiavi API, i tasti di scelta rapida e le preferenze del modello. L'app si chiuderà e mostrerà nuovamente l'onboarding al prossimo avvio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、API キー、ホットキー、モデル設定を含むすべての設定がクリアされます。アプリは終了し、次回起動時に再びオンボーディングが表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "API 키, 단축키, 모델 기본 설정을 포함한 모든 설정이 삭제됩니다. 다음 실행 시 앱이 종료되고 온보딩이 다시 표시됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan mengosongkan semua tetapan anda, termasuk kunci API, kekunci pintas dan pilihan model. Apl akan berhenti dan menunjukkan orientasi semula pada pelancaran seterusnya."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil slette alle innstillingene dine, inkludert API-nøkler, hurtigtaster og modellpreferanser. Appen avsluttes og viser onboarding igjen ved neste lansering."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermee worden al uw instellingen gewist, inclusief API-sleutels, sneltoetsen en modelvoorkeuren. De app wordt afgesloten en wordt bij de volgende lancering opnieuw onboarding weergegeven."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to wyczyszczenie wszystkich ustawień, w tym kluczy API, skrótów klawiszowych i preferencji modelu. Aplikacja zostanie zamknięta i ponownie wyświetli informacje o wejściu na pokład przy następnym uruchomieniu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso limpará todas as suas configurações, incluindo chaves de API, teclas de atalho e preferências de modelo. O aplicativo será encerrado e mostrará a integração novamente na próxima inicialização."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceasta vă va șterge toate setările, inclusiv cheile API, tastele rapide și preferințele de model. Aplicația se va închide și va afișa din nou integrarea la următoarea lansare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это приведет к очистке всех ваших настроек, включая ключи API, горячие клавиши и настройки модели. Приложение закроется и снова отобразит регистрацию при следующем запуске."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta kommer att rensa alla dina inställningar, inklusive API-nycklar, snabbtangenter och modellinställningar. Appen avslutas och visar onboarding igen vid nästa lansering."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะล้างการตั้งค่าทั้งหมดของคุณ รวมถึงคีย์ API, ปุ่มลัด และการกำหนดลักษณะโมเดล แอปจะปิดและแสดงการเริ่มต้นใช้งานอีกครั้งในการเปิดตัวครั้งถัดไป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, API anahtarları, kısayol tuşları ve model tercihleri ​​dahil tüm ayarlarınızı temizleyecektir. Uygulama sonlandırılacak ve bir sonraki başlatmada yeniden katılım gösterilecektir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це очистить усі ваші налаштування, включно з ключами API, гарячими клавішами та параметрами моделі. Під час наступного запуску програма закриється та знову відобразить інформацію про адаптацію."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa tất cả cài đặt của bạn, bao gồm khóa API, phím nóng và tùy chọn kiểu máy. Ứng dụng sẽ thoát và hiển thị lại phần giới thiệu trong lần khởi chạy tiếp theo."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將清除您的所有設定，包括 API 金鑰、快捷鍵和模型首選項。應用將退出並在下次啟動時再次顯示引導。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将清除您的所有设置，包括 API 密钥、快捷键和模型首选项。应用将退出并在下次启动时再次显示引导。"
          }
        }
      }
    },
    "this_will_permanently_remove_the_transcript_and": {
      "comment": "this_will_permanently_remove_the_transcript_and",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى إزالة النص وملف الوسائط المُدار الخاص به نهائيًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি স্থায়ীভাবে ট্রান্সক্রিপ্ট এবং এর পরিচালিত মিডিয়া ফাইল সরিয়ে দেবে।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tím trvale odstraníte přepis a jeho spravovaný mediální soubor."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil permanent fjerne transskriptionen og dens administrerede mediefil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies entfernt die Transkription und ihre verwaltete Mediendatei dauerhaft."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will permanently remove the transcript and its managed media file."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό θα καταργήσει οριστικά τη μεταγραφή και το διαχειριζόμενο αρχείο πολυμέσων."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente la transcripción y su archivo multimedia gestionado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä poistaa pysyvästi transkription ja sen hallitun mediatiedoston."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera définitivement la transcription et son fichier média géré."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "פעולה זו תסיר לצמיתות את התמליל ואת קובץ המדיה המנוהל שלו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रतिलेख और उसकी प्रबंधित मीडिया फ़ाइल को स्थायी रूप से हटा देगा।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezzel véglegesen eltávolítja az átiratot és a kezelt médiafájlt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tindakan ini akan menghapus transkrip dan file media yang dikelolanya secara permanen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciò rimuoverà definitivamente la trascrizione e il relativo file multimediale gestito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、トランスクリプトとその管理対象メディア ファイルが完全に削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이렇게 하면 스크립트와 관리되는 미디어 파일이 영구적으로 제거됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan mengalih keluar transkrip dan fail media terurusnya secara kekal."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil permanent fjerne transkripsjonen og dens administrerte mediefil."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdoor worden het transcript en het beheerde mediabestand permanent verwijderd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to trwałe usunięcie transkrypcji i zarządzanego pliku multimedialnego."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso removerá permanentemente a transcrição e seu arquivo de mídia gerenciado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceasta va elimina definitiv transcrierea și fișierul media gestionat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это приведет к безвозвратному удалению расшифровки и ее управляемого медиафайла."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta tar permanent bort transkriptionen och dess hanterade mediefil."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบข้อความถอดเสียงและไฟล์สื่อที่มีการจัดการออกอย่างถาวร"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, transkripti ve yönetilen medya dosyasını kalıcı olarak kaldıracaktır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це назавжди видалить стенограму та її керований медіафайл."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa vĩnh viễn bản ghi và tệp phương tiện được quản lý của nó."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將永久刪除轉錄及其託管的媒體檔案。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除转录及其托管的媒体文件。"
          }
