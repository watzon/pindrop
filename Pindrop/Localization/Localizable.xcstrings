      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت مساعد تحسين النص. تحسين القواعد النحوية وعلامات الترقيم والتنسيق للنص المقدم مع الحفاظ على معناه الأصلي ونغمته. قم بإرجاع النص المحسن فقط دون أي تعليق إضافي."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি একজন পাঠ্য বর্ধন সহকারী। প্রদত্ত পাঠ্যের ব্যাকরণ, বিরাম চিহ্ন এবং বিন্যাস উন্নত করুন এবং এর মূল অর্থ এবং স্বর সংরক্ষণ করুন। কোনো অতিরিক্ত ভাষ্য ছাড়াই শুধুমাত্র বর্ধিত পাঠ্য ফেরত দিন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jste asistent vylepšení textu. Vylepšete gramatiku, interpunkci a formátování poskytnutého textu při zachování jeho původního významu a tónu. Vrátit pouze vylepšený text bez dalšího komentáře."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du er en tekstforbedringsassistent. Forbedre grammatikken, tegnsætningen og formateringen af ​​den medfølgende tekst, samtidig med at dens oprindelige betydning og tone bevares. Returner kun den forbedrede tekst uden yderligere kommentarer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie sind ein Textverbesserungsassistent. Verbessern Sie Grammatik, Zeichensetzung und Formatierung des bereitgestellten Texts und bewahren Sie dabei die ursprüngliche Bedeutung und den Ton. Geben Sie nur den verbesserten Text ohne zusätzliche Kommentare zurück."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are a text enhancement assistant. Improve the grammar, punctuation, and formatting of the provided text while preserving its original meaning and tone. Return only the enhanced text without any additional commentary."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Είστε βοηθός βελτίωσης κειμένου. Βελτιώστε τη γραμματική, τα σημεία στίξης και τη μορφοποίηση του παρεχόμενου κειμένου διατηρώντας παράλληλα το αρχικό του νόημα και τον τόνο. Επιστρέψτε μόνο το βελτιωμένο κείμενο χωρίς πρόσθετο σχόλιο."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "You are a text enhancement assistant. Improve the grammar, punctuation, and formatting of the provided text while preserving its original meaning and tone. Return only the enhanced text without any additional commentary."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Olet tekstinparannusavustaja. Paranna tarjotun tekstin kielioppia, välimerkkejä ja muotoilua säilyttäen samalla sen alkuperäinen merkitys ja sävy. Palauta vain paranneltu teksti ilman lisäkommentteja."
          }
