    "press_and_hold_to_dictate_in_any_app_pindrop_wil": {
      "comment": "press_and_hold_to_dictate_in_any_app_pindrop_wil",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط مع الاستمرار للإملاء في أي تطبيق. سوف يقوم Pindrop بنسخ كلامك وإدراج النص حيث يوجد المؤشر."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "যেকোন অ্যাপে নির্দেশ দিতে টিপুন এবং ধরে রাখুন। Pindrop আপনার বক্তৃতা প্রতিলিপি এবং আপনার কার্সার যেখানে পাঠ্য সন্নিবেশ করা হবে."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Stisknutím a podržením můžete diktovat v libovolné aplikaci. Pindrop přepíše vaši řeč a vloží text tam, kde je váš kurzor."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk og hold for at diktere i enhver app. Pindrop transskriberer din tale og indsætter teksten, hvor markøren er."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken und halten Sie, um in jeder App zu diktieren. Pindrop transkribiert Ihre Sprache und fügt den Text an Ihrer Cursorposition ein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press and hold to dictate in any app. Pindrop will transcribe your speech and insert the text where your cursor is."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πατήστε παρατεταμένα για υπαγόρευση σε οποιαδήποτε εφαρμογή. Το Pindrop θα μεταγράψει την ομιλία σας και θα εισαγάγει το κείμενο όπου βρίσκεται ο κέρσορας σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén pulsado para dictar en cualquier app. Pindrop transcribirá tu voz e insertará el texto donde esté el cursor."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Paina ja pidä painettuna sanellaksesi missä tahansa sovelluksessa. Pindrop litteroi puheesi ja lisää tekstin kohdistimen kohdalle."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez et maintenez pour dicter dans n'importe quelle app. Pindrop transcrira votre discours et insérera le texte où se trouve votre curseur."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לחץ והחזק כדי להכתיב בכל אפליקציה. Pindrop תעתיק את הנאום שלך ותוסיף את הטקסט במקום שבו הסמן שלך נמצא."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी भी ऐप में निर्देश देने के लिए दबाकर रखें। पिनड्रॉप आपके भाषण को ट्रांसक्रिप्ट करेगा और टेक्स्ट को वहां डाल देगा जहां आपका कर्सर है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nyomja meg és tartsa lenyomva a diktáláshoz bármely alkalmazásban. A Pindrop átírja a beszédet, és beszúrja a szöveget oda, ahol a kurzor van."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan dan tahan untuk mendikte di aplikasi apa pun. Pindrop akan menyalin ucapan Anda dan menyisipkan teks di tempat kursor Anda berada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto per dettare in qualsiasi app. Pindrop trascriverà il tuo discorso e inserirà il testo nel punto in cui si trova il cursore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どのアプリでも押し続けると口述入力できます。 Pindrop はあなたのスピーチを文字に起こし、カーソルがある場所にテキストを挿入します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어떤 앱에서든 길게 누르면 받아쓰게 됩니다. Pindrop은 귀하의 음성을 기록하고 커서가 있는 곳에 텍스트를 삽입합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekan dan tahan untuk menentukan dalam mana-mana apl. Pindrop akan menyalin pertuturan anda dan memasukkan teks di mana kursor anda berada."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk og hold for å diktere i en hvilken som helst app. Pindrop vil transkribere talen din og sette inn teksten der markøren er."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd ingedrukt om in elke app te dicteren. Pindrop zal uw toespraak transcriberen en de tekst invoegen waar uw cursor zich bevindt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij i przytrzymaj, aby dyktować w dowolnej aplikacji. Pindrop dokona transkrypcji Twojej wypowiedzi i wstawi tekst w miejscu, w którym znajduje się kursor."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione e segure para ditar em qualquer aplicativo. Pindrop transcreverá sua fala e inserirá o texto onde estiver o cursor."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Apăsați lung pentru a dicta în orice aplicație. Pindrop vă va transcrie discursul și va insera textul acolo unde se află cursorul."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите и удерживайте, чтобы диктовать в любом приложении. Pindrop расшифрует вашу речь и вставит текст в место, где находится курсор."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck och håll ned för att diktera i valfri app. Pindrop kommer att transkribera ditt tal och infoga texten där markören är."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กดค้างไว้เพื่อเขียนตามคำบอกในแอปใดก็ได้ Pindrop จะถอดเสียงคำพูดของคุณและแทรกข้อความในตำแหน่งที่เคอร์เซอร์ของคุณอยู่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Herhangi bir uygulamada dikte etmek için basılı tutun. Pindrop konuşmanızı yazıya dökecek ve metni imlecinizin bulunduğu yere ekleyecektir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Натисніть і утримуйте, щоб продиктувати в будь-якій програмі. Pindrop транскрибує вашу промову та вставляє текст у місце курсора."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn và giữ để đọc chính tả trong bất kỳ ứng dụng nào. Pindrop sẽ phiên âm lời nói của bạn và chèn văn bản vào vị trí con trỏ của bạn."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按住以在任何應用中聽寫。Pindrop 將轉錄您的語音並在游標位置插入文字。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住以在任何应用中听写。Pindrop 将转录您的语音并在光标位置插入文本。"
          }
        }
      }
    },
