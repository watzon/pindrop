    "on_device_no_credentials_required": {
      "comment": "on_device_no_credentials_required",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "على الجهاز، لا توجد بيانات اعتماد مطلوبة"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ডিভাইসে, কোনো শংসাপত্রের প্রয়োজন নেই"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V zařízení nejsou vyžadovány žádné přihlašovací údaje"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "På enheden, ingen legitimationsoplysninger påkrævet"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf dem Gerät, keine Anmeldeinformationen erforderlich"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On-device, no credentials required"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Στη συσκευή, δεν απαιτούνται διαπιστευτήρια"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En el dispositivo, no se requieren credenciales"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Laitteessa, kirjautumistietoja ei vaadita"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sur l'appareil, aucune information d'identification requise"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "במכשיר, אין צורך באישורים"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऑन-डिवाइस, किसी क्रेडेंशियल की आवश्यकता नहीं है"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az eszközön, nincs szükség hitelesítő adatokra"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Di perangkat, tidak diperlukan kredensial"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sul dispositivo, non sono richieste credenziali"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス上で認証情報は不要"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기 내에서는 자격 증명이 필요하지 않습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pada peranti, tiada bukti kelayakan diperlukan"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "På enheten, ingen legitimasjon kreves"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Op het apparaat, geen inloggegevens vereist"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na urządzeniu, nie są wymagane żadne dane uwierzytelniające"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "No dispositivo, sem necessidade de credenciais"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pe dispozitiv, nu sunt necesare acreditări"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На устройстве, учетные данные не требуются"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "På enheten, inga inloggningsuppgifter krävs"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บนอุปกรณ์ไม่ต้องใช้ข้อมูลรับรอง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cihazda kimlik bilgisi gerekmez"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "На пристрої, облікові дані не потрібні"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trên thiết bị, không cần thông tin xác thực"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在裝置上，無需憑據"
          }
        },
        "zh-Hans": {
