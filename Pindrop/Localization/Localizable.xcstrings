        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η μεταγραφή ροής είναι απενεργοποιημένη ενώ η Βελτίωση AI είναι ενεργοποιημένη."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La transcripción en streaming está desactivada mientras la mejora con IA esté activada."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Suoratoiston transkriptio on poistettu käytöstä, kun AI Enhancement on käytössä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La transcription en streaming est désactivée lorsque l'amélioration IA est activée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "תמלול סטרימינג מושבת בזמן ששיפור בינה מלאכותית מופעל."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एआई एन्हांसमेंट सक्षम होने पर स्ट्रीमिंग ट्रांसक्रिप्शन अक्षम है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A streamelési átírás le van tiltva, amíg az AI Enhancement engedélyezve van."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkripsi streaming dinonaktifkan saat Peningkatan AI diaktifkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La trascrizione dello streaming è disabilitata mentre il miglioramento AI è abilitato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AI Enhancement が有効になっている間、ストリーミング文字起こしは無効になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI Enhancement가 활성화된 동안 스트리밍 전사는 비활성화됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkripsi penstriman dilumpuhkan manakala Peningkatan AI didayakan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Streaming-transkripsjon er deaktivert mens AI Enhancement er aktivert."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Streamingtranscriptie is uitgeschakeld terwijl AI Enhancement is ingeschakeld."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkrypcja strumieniowa jest wyłączona, gdy włączone jest ulepszenie AI."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A transcrição de streaming está desativada enquanto o AI Enhancement está ativado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcrierea în flux este dezactivată în timp ce Îmbunătățirea AI este activată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Потоковая транскрипция отключена, пока включена функция AI Enhancement."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Strömmande transkription är inaktiverad medan AI Enhancement är aktiverat."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การถอดเสียงแบบสตรีมมิ่งถูกปิดใช้งานในขณะที่เปิดใช้งานการเพิ่มประสิทธิภาพ AI"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "AI Geliştirme etkinken akış transkripsiyonu devre dışı bırakılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Потокова транскрипція вимкнена, коли ввімкнено AI Enhancement."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tính năng chép lời trực tuyến bị vô hiệu hóa khi tính năng Cải tiến AI được bật."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用 AI 增強時，流式轉錄被禁用。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用 AI 增强时，流式转录被禁用。"
          }
        }
      }
    },
    "streaming_transcription_model_parakeet_realtime": {
      "comment": "streaming_transcription_model_parakeet_realtime",
