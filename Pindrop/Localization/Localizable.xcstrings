    "import_or_transcribe_media_while_this_folder_is": {
      "comment": "import_or_transcribe_media_while_this_folder_is",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم باستيراد الوسائط أو نسخها أثناء تحديد هذا المجلد لحفظ العناصر هنا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এখানে আইটেমগুলি সংরক্ষণ করতে এই ফোল্ডারটি নির্বাচন করার সময় মিডিয়া আমদানি বা প্রতিলিপি করুন৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Importujte nebo přepisujte média, když je vybrána tato složka, aby se sem ukládaly položky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Importer eller transskriber medier, mens denne mappe er valgt for at gemme elementer her."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importieren oder transkribieren Sie Medien, während dieser Ordner ausgewählt ist, um Elemente hier zu speichern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import or transcribe media while this folder is selected to save items here."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εισαγωγή ή μεταγραφή πολυμέσων ενώ αυτός ο φάκελος είναι επιλεγμένος για αποθήκευση στοιχείων εδώ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa o transcribe medios mientras esta carpeta esté seleccionada para guardar elementos aquí."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuo tai litteröi mediaa, kun tämä kansio on valittuna, jotta kohteet tallennetaan tähän."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importez ou transcrivez des médias lorsque ce dossier est sélectionné pour y enregistrer les éléments."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ייבא או תמלול מדיה בזמן שהתיקיה הזו נבחרת כדי לשמור פריטים כאן."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यहां आइटम सहेजने के लिए इस फ़ोल्डर का चयन करते समय मीडिया को आयात या ट्रांसक्राइब करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Amíg ez a mappa ki van választva, importáljon vagy írjon át médiát az elemek ide mentéséhez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Impor atau transkripsikan media saat folder ini dipilih untuk menyimpan item di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa o trascrivi contenuti multimediali mentre questa cartella è selezionata per salvare qui gli elementi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
