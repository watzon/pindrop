    "speaker_diarization_and_timestamps_are_attached": {
      "comment": "speaker_diarization_and_timestamps_are_attached",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم إرفاق مذكرات المتحدث والطوابع الزمنية بالتشغيل."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "স্পীকার ডায়েরাইজেশন এবং টাইমস্ট্যাম্প প্লেব্যাকের সাথে সংযুক্ত।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "K přehrávání jsou připojeny diarizace a časová razítka reproduktoru."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Højttalerdiarisering og tidsstempler er knyttet til afspilning."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprecherdiarisierung und Zeitstempel sind an die Wiedergabe angehängt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Speaker diarization and timestamps are attached to playback."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η ένδειξη ηχείων και οι χρονικές σημάνσεις επισυνάπτονται στην αναπαραγωγή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La diarización de hablantes y las marcas de tiempo se adjuntan a la reproducción."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaiutinpäiväkirja ja aikaleimat on liitetty toistoon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La diarisation des locuteurs et les horodatages sont attachés à la lecture."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "יומן רמקול וחותמות זמן מצורפות להשמעה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्पीकर डायराइज़ेशन और टाइमस्टैम्प प्लेबैक से जुड़े हुए हैं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hangszóró naplózása és az időbélyegek a lejátszáshoz vannak csatolva."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Diarisasi speaker dan stempel waktu dilampirkan pada pemutaran."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La diarizzazione degli altoparlanti e i timestamp sono allegati alla riproduzione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再生にはスピーカーのダイアライゼーションとタイムスタンプが付加されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화자 분할 및 타임스탬프가 재생에 첨부됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Diarisasi pembesar suara dan cap masa dilampirkan pada main semula."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Høyttalerdiarisering og tidsstempler er festet til avspilling."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprekersdialoog en tijdstempels zijn aan het afspelen gekoppeld."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Diaryzacja głośników i znaczniki czasu są dołączane do odtwarzania."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A diarização do alto-falante e os carimbos de data/hora são anexados à reprodução."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Diarizarea difuzorului și marcajele de timp sunt atașate la redare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "К воспроизведению прикрепляются дневники докладчиков и временные метки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Högtalardiarisering och tidsstämplar är fästa vid uppspelning."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "มีการแนบไดอะแกรมของลำโพงและการประทับเวลาไว้กับการเล่น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konuşmacı günlüğü ve zaman damgaları oynatmaya eklenir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щоденник доповідача та часові мітки додаються до відтворення."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhật ký loa và dấu thời gian được đính kèm để phát lại."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "說話人分離和時間戳附加到播放。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "说话人分离和时间戳附加到播放。"
          }
        }
      }
    },
