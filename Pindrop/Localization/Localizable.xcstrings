            "value": "Kies tussen Parakeet (meerdere versies, gedownload model) en Apple SpeechTranscriber (macOS 26+, meegeleverd met het besturingssysteem)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz pomiędzy Parakeet (wersja krzyżowa, model pobrany) i Apple SpeechTranscriber (macOS 26+, dostarczany z systemem operacyjnym)."
          }
        },
        "pt-BR": {
          "stringUnit": {
