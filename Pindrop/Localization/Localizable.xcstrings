    "is_assigned_to_both_and_only_the_first_action_wi": {
      "comment": "is_assigned_to_both_and_only_the_first_action_wi",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تعيين %@ لكل من %@ و%@. سيكون الإجراء الأول فقط نشطًا. قم بتحديث مفاتيح التشغيل السريع في الإعدادات لحل هذا التعارض."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %@ এবং %@ উভয়কেই বরাদ্দ করা হয়েছে৷ শুধুমাত্র প্রথম কর্ম সক্রিয় হবে. এই বিরোধের সমাধান করতে সেটিংসে আপনার হটকিগুলি আপডেট করুন৷"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ je přiřazeno k %@ i %@. Aktivní bude pouze první akce. Tento konflikt vyřešíte aktualizací klávesových zkratek v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ er tildelt både %@ og %@. Kun den første handling vil være aktiv. Opdater dine genvejstaster i Indstillinger for at løse denne konflikt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ist sowohl %@ als auch %@ zugewiesen. Nur die erste Aktion wird aktiv sein. Aktualisieren Sie Ihre Tastenkürzel in den Einstellungen, um diesen Konflikt zu lösen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is assigned to both %@ and %@. Only the first action will be active. Update your hotkeys in Settings to resolve this conflict."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το %@ έχει εκχωρηθεί τόσο στο %@ όσο και στο %@. Μόνο η πρώτη ενέργεια θα είναι ενεργή. Ενημερώστε τα πλήκτρα πρόσβασης στις Ρυθμίσεις για να επιλύσετε αυτήν τη διένεξη."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ está asignado tanto a %@ como a %@. Solo la primera acción estará activa. Actualiza tus atajos en Ajustes para resolver este conflicto."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ on määritetty sekä %@:lle että %@:lle. Vain ensimmäinen toiminto on aktiivinen. Ratkaise tämä ristiriita päivittämällä pikanäppäimet asetuksissa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ est assigné à la fois à %@ et %@. Seule la première action sera active. Mettez à jour vos raccourcis dans les Paramètres pour résoudre ce conflit."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ מוקצה גם ל-%@ וגם ל-%@. רק הפעולה הראשונה תהיה פעילה. עדכן את מקשי הקיצור שלך בהגדרות כדי לפתור את ההתנגשות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ को %@ और %@ दोनों को सौंपा गया है। केवल पहली कार्रवाई ही सक्रिय होगी. इस विरोध को हल करने के लिए सेटिंग्स में अपनी हॉटकी अपडेट करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A %@ a %@ és a %@ számára is hozzá van rendelve. Csak az első művelet lesz aktív. Az ütközés feloldásához frissítse a gyorsbillentyűket a Beállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ditugaskan ke %@ dan %@. Hanya tindakan pertama yang akan aktif. Perbarui tombol pintas Anda di Pengaturan untuk mengatasi konflik ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ è assegnato sia a %@ che a %@. Sarà attiva solo la prima azione. Aggiorna i tasti di scelta rapida in Impostazioni per risolvere questo conflitto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ は %@ と %@ の両方に割り当てられます。最初のアクションのみがアクティブになります。この競合を解決するには、設定でホットキーを更新してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@는 %@ 및 %@ 모두에 할당됩니다. 첫 번째 작업만 활성화됩니다. 이 충돌을 해결하려면 설정에서 단축키를 업데이트하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ diberikan kepada %@ dan %@. Hanya tindakan pertama akan aktif. Kemas kini kekunci pintas anda dalam Tetapan untuk menyelesaikan konflik ini."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ er tilordnet både %@ og %@. Bare den første handlingen vil være aktiv. Oppdater hurtigtastene dine i Innstillinger for å løse denne konflikten."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is toegewezen aan zowel %@ als %@. Alleen de eerste actie is actief. Update uw sneltoetsen in Instellingen om dit conflict op te lossen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ jest przypisany zarówno do %@, jak i %@. Aktywna będzie tylko pierwsza akcja. Zaktualizuj skróty klawiszowe w Ustawieniach, aby rozwiązać ten konflikt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ é atribuído a %@ e %@. Apenas a primeira ação estará ativa. Atualize suas teclas de atalho em Configurações para resolver este conflito."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ este atribuit atât la %@, cât și la %@. Doar prima acțiune va fi activă. Actualizați tastele rapide din Setări pentru a rezolva acest conflict."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ назначен как %@, так и %@. Активным будет только первое действие. Обновите горячие клавиши в настройках, чтобы разрешить этот конфликт."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ är tilldelad både %@ och %@. Endast den första åtgärden kommer att vara aktiv. Uppdatera dina snabbtangenter i Inställningar för att lösa denna konflikt."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ถูกกำหนดให้กับทั้ง %@ และ %@ เฉพาะการดำเนินการแรกเท่านั้นที่จะใช้งานได้ อัปเดตปุ่มลัดของคุณในการตั้งค่าเพื่อแก้ไขข้อขัดแย้งนี้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@, hem %@ hem de %@'ye atanır. Yalnızca ilk eylem etkin olacaktır. Bu çakışmayı çözmek için Ayarlar'da kısayol tuşlarınızı güncelleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ призначено як %@, так і %@. Активною буде лише перша дія. Оновіть гарячі клавіші в налаштуваннях, щоб вирішити цей конфлікт."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ được gán cho cả %@ và %@. Chỉ hành động đầu tiên sẽ được kích hoạt. Cập nhật các phím nóng của bạn trong Cài đặt để giải quyết xung đột này."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 同時分配給 %@ 和 %@。只有第一個操作將處於活動狀態。在設定中更新您的快捷鍵以解決此衝突。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 同时分配给 %@ 和 %@。只有第一个操作将处于活动状态。在设置中更新您的快捷键以解决此冲突。"
          }
        }
      }
    },
