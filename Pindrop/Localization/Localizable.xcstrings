    "pick_which_provider_and_model_handles_each_ai_ta": {
      "comment": "pick_which_provider_and_model_handles_each_ai_ta",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر الموفر والنموذج الذي يتعامل مع كل مهمة من مهام الذكاء الاصطناعي. اتركه كـ \"غير معين\" لتخطي أحد الأغراض."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কোন প্রদানকারী এবং মডেল প্রতিটি AI টাস্ক পরিচালনা করে তা বেছে নিন। একটি উদ্দেশ্য এড়ানোর জন্য \"অ্যাসাইন করা হয়নি\" হিসাবে ছেড়ে দিন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte poskytovatele a model, který zpracuje jednotlivé úkoly AI. Chcete-li přeskočit účel, ponechte jako „Nepřiřazeno“."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg, hvilken udbyder og model, der håndterer hver AI-opgave. Lad være som \\\"Ikke tildelt\\\" for at springe et formål over."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie aus, welcher Anbieter und welches Modell die jeweilige KI-Aufgabe übernimmt. Belassen Sie es auf „Nicht zugewiesen“, um einen Zweck zu überspringen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick which provider and model handles each AI task. Leave as \"Not assigned\" to skip a purpose."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε ποιος πάροχος και μοντέλο χειρίζεται κάθε εργασία AI. Αποχωρήστε ως \"Δεν έχει ανατεθεί\" για να παραλείψετε έναν σκοπό."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija qué proveedor y modelo se encarga de cada tarea de IA. Déjelo como \"No asignado\" para omitir un propósito."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse, mikä toimittaja ja malli hoitaa jokaisen tekoälytehtävän. Jätä \"Ei määritetty\" -asetukseksi ohittaaksesi tarkoituksen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez quel fournisseur et quel modèle gère chaque tâche d'IA. Laissez comme « Non attribué » pour ignorer un objectif."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר איזה ספק ודגם מטפלים בכל משימת AI. השאר בתור \"לא מוקצה\" כדי לדלג על מטרה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि कौन सा प्रदाता और मॉडल प्रत्येक एआई कार्य को संभालता है। किसी उद्देश्य को छोड़ने के लिए \"असाइन नहीं किया गया\" के रूप में छोड़ दें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válassza ki, hogy melyik szolgáltató és modell kezeli az egyes AI-feladatokat. Hagyja \"Nincs hozzárendelve\"ként, hogy kihagyjon egy célt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih penyedia dan model mana yang menangani setiap tugas AI. Biarkan sebagai \"Tidak ditugaskan\" untuk melewatkan suatu tujuan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick which provider and model handles each AI task. Lascia come \"Non assegnato\" per saltare uno scopo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各 AI タスクを処理するプロバイダーとモデルを選択します。目的をスキップするには、「未割り当て」のままにします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 AI 작업을 처리하는 공급자와 모델을 선택하세요. 목적을 건너뛰려면 '할당되지 않음'으로 두세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih penyedia dan model yang mengendalikan setiap tugas AI. Biarkan sebagai \"Tidak ditetapkan\" untuk melangkau tujuan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg hvilken leverandør og modell som håndterer hver AI-oppgave. La stå som «Ikke tildelt» for å hoppe over et formål."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies welke provider en welk model elke AI-taak afhandelt. Laat het staan ​​op 'Niet toegewezen' om een ​​doel over te slaan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz dostawcę i model obsługujący każde zadanie AI. Pozostaw jako „Nieprzypisane”, aby pominąć cel."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha qual provedor e modelo lida com cada tarefa de IA. Deixe como \"Não atribuído\" para pular uma finalidade."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alegeți ce furnizor și model se ocupă de fiecare sarcină AI. Lăsați „Nealocat” pentru a omite un scop."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, какой поставщик и модель будет выполнять каждую задачу ИИ. Оставьте значение «Не назначено», чтобы пропустить цель."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj vilken leverantör och modell som hanterar varje AI-uppgift. Lämna som \"Inte tilldelad\" för att hoppa över ett syfte."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกผู้ให้บริการและโมเดลที่จะจัดการงาน AI แต่ละรายการ ปล่อยให้เป็น \"ไม่ได้มอบหมาย\" เพื่อข้ามวัตถุประสงค์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her bir AI görevini hangi sağlayıcının ve modelin gerçekleştireceğini seçin. Bir amacı atlamak için \"Atanmadı\" olarak bırakın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть, який постачальник і модель обробляє кожне завдання ШІ. Залиште як «Не призначено», щоб пропустити мету."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn nhà cung cấp và mô hình nào xử lý từng nhiệm vụ AI. Để lại là \"Chưa được chỉ định\" để bỏ qua mục đích."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇哪個提供商和模型來處理每個人工智慧任務。保留為“未分配”以跳過目的。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择哪个提供商和模型来处理每个人工智能任务。保留为“未分配”以跳过目的。"
          }
        }
      }
    },
