    "Press and hold to dictate in any app. Pindrop will transcribe your speech and insert the text where your cursor is.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken und halten Sie, um in jeder App zu diktieren. Pindrop transkribiert Ihre Sprache und fügt den Text an Ihrer Cursorposition ein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press and hold to dictate in any app. Pindrop will transcribe your speech and insert the text where your cursor is."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén pulsado para dictar en cualquier app. Pindrop transcribirá tu voz e insertará el texto donde esté el cursor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez et maintenez pour dicter dans n'importe quelle app. Pindrop transcrira votre discours et insérera le texte où se trouve votre curseur."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どのアプリでも押し続けると口述入力できます。 Pindrop はあなたのスピーチを文字に起こし、カーソルがある場所にテキストを挿入します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住以在任何应用中听写。Pindrop 将转录您的语音并在光标位置插入文本。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione e segure para ditar em qualquer aplicativo. Pindrop transcreverá sua fala e inserirá o texto onde estiver o cursor."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto per dettare in qualsiasi app. Pindrop trascriverà il tuo discorso e inserirà il testo nel punto in cui si trova il cursore."
          }
        }
      }
    },
