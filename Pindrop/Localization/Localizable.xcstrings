    "search_settings_or_jump_between_sections_without": {
      "comment": "search_settings_or_jump_between_sections_without",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابحث في الإعدادات أو انتقل بين الأقسام دون مغادرة مساحة العمل الرئيسية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সেটিংস অনুসন্ধান করুন বা প্রধান ওয়ার্কস্পেস না রেখে বিভাগগুলির মধ্যে ঝাঁপ দিন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Prohledávejte nastavení nebo přeskakujte mezi sekcemi, aniž byste opustili hlavní pracovní plochu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Søg i indstillinger eller spring mellem sektioner uden at forlade hovedarbejdsområdet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchsuchen Sie Einstellungen oder springen Sie zwischen Abschnitten, ohne den Hauptarbeitsbereich zu verlassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search settings or jump between sections without leaving the main workspace."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αναζητήστε ρυθμίσεις ή μεταβείτε μεταξύ των ενοτήτων χωρίς να βγείτε από τον κύριο χώρο εργασίας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca ajustes o cambia entre secciones sin dejar el espacio de trabajo principal."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hae asetuksia tai siirry osioiden välillä poistumatta päätyötilasta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recherchez dans les paramètres ou sautez entre les sections sans quitter l'espace de travail principal."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "חפש בהגדרות או דלג בין מקטעים מבלי לצאת מסביבת העבודה הראשית."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेटिंग्स खोजें या मुख्य कार्यक्षेत्र छोड़े बिना अनुभागों के बीच कूदें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Keresés a beállításokban vagy ugrás a szakaszok között anélkül, hogy elhagyná a fő munkaterületet."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cari pengaturan atau lompat antar bagian tanpa meninggalkan ruang kerja utama."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerca le impostazioni o passa da una sezione all'altra senza lasciare l'area di lavoro principale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メイン ワークスペースを離れることなく、設定を検索したり、セクション間を移動したりできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 작업 공간을 떠나지 않고도 설정을 검색하거나 섹션 사이를 이동할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Cari tetapan atau lompat antara bahagian tanpa meninggalkan ruang kerja utama."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Søk i innstillinger eller hopp mellom seksjoner uten å forlate hovedarbeidsområdet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zoek naar instellingen of spring tussen secties zonder de hoofdwerkruimte te verlaten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyszukaj ustawienia lub przeskakuj między sekcjami bez opuszczania głównego obszaru roboczego."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pesquise configurações ou salte entre seções sem sair da área de trabalho principal."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Căutați setări sau săriți între secțiuni fără a părăsi spațiul de lucru principal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ищите настройки или переключайтесь между разделами, не выходя из основного рабочего пространства."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sök i inställningar eller hoppa mellan avsnitt utan att lämna huvudarbetsytan."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ค้นหาการตั้งค่าหรือข้ามระหว่างส่วนต่างๆ โดยไม่ต้องออกจากพื้นที่ทำงานหลัก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana çalışma alanından ayrılmadan ayarları arayın veya bölümler arasında geçiş yapın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Шукайте налаштування або переходьте між розділами, не виходячи з основної робочої області."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tìm kiếm cài đặt hoặc chuyển giữa các phần mà không cần rời khỏi không gian làm việc chính."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "搜尋設定或在各部分之間跳轉，無需離開主工作區。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "搜索设置或在各部分之间跳转，无需离开主工作区。"
          }
        }
      }
    },
