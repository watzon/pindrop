    "no_models_available_try_refresh_or_enter_a_model": {
      "comment": "no_models_available_try_refresh_or_enter_a_model",
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد نماذج متاحة. حاول التحديث أو أدخل معرف النموذج يدويًا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কোন মডেল উপলব্ধ. রিফ্রেশ করার চেষ্টা করুন বা ম্যানুয়ালি একটি মডেল আইডি লিখুন।"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nejsou dostupné žádné modely. Zkuste Obnovit nebo zadejte ID modelu ručně."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen tilgængelige modeller. Prøv Opdater eller indtast et model-id manuelt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Modelle verfügbar. Versuchen Sie Aktualisieren oder geben Sie eine Modell-ID manuell ein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No models available. Try Refresh or enter a model ID manually."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν υπάρχουν διαθέσιμα μοντέλα. Δοκιμάστε το Refresh ή εισαγάγετε ένα αναγνωριστικό μοντέλου με μη αυτόματο τρόπο."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay modelos disponibles. Intenta Actualizar o introduce un ID de modelo manualmente."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei malleja saatavilla. Kokeile Päivitä tai anna mallin tunnus manuaalisesti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun modèle disponible. Essayez Actualiser ou entrez un ID de modèle manuellement."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אין דגמים זמינים. נסה לרענן או הזן מזהה דגם באופן ידני."
